<resources>
    <string name="systemcleaner_explanation_short">कुनै खास एप्सको नभएको अनावश्यक डेटा।</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="one">%d मिलान मेटाइयो</item>
        <item quantity="other">%d मिलानहरू मेटाइए</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="one">%d फिल्टर मेल खाएको</item>
        <item quantity="other">%d फिल्टर मेल खाएका</item>
    </plurals>
    <string name="systemcleaner_filter_custom_label">कस्टम फिल्टर</string>
    <string name="systemcleaner_filter_custom_manage_label">कस्टम फिल्टरहरू व्यवस्थापन गर्नुहोस्</string>
    <string name="systemcleaner_filter_custom_manage_summary">आफ्ना कस्टम फिल्टरहरू सिर्जना, मेटाउने, आयात र निर्यात गर्नुहोस्।</string>
    <string name="systemcleaner_filter_logfiles_label">सिस्टम लग फाइलहरू</string>
    <string name="systemcleaner_filter_logfiles_summary">विभिन्न स्थानहरूमा रहेका सिस्टम र सिस्टम सेवा लग फाइलहरू (जस्तै *.log)।</string>
    <string name="systemcleaner_filter_packagecaches_label">इन्स्टलर क्यास्ह</string>
    <string name="systemcleaner_filter_packagecaches_summary">सिस्टमको प्याकेज म्यानेजमेन्टद्वारा प्रयोग गरिने स्थापित एप्सहरूसँग सम्बन्धित क्यास्ह गरिएको डेटा।</string>
    <string name="systemcleaner_filter_advertisements_label">विज्ञापन फाइलहरू</string>
    <string name="systemcleaner_filter_advertisements_summary">विज्ञापनको लागि वा विज्ञापनद्वारा सिर्जना गरिएका फाइलहरू।</string>
    <string name="systemcleaner_filter_anr_label">ANR त्रुटिहरू</string>
    <string name="systemcleaner_filter_anr_summary">\'एप्लिकेसन जवाफ दिदैन\' घटनाहरूका ट्रेसहरू।</string>
    <string name="systemcleaner_filter_emptydirectories_label">खाली फोल्डरहरू</string>
    <string name="systemcleaner_filter_emptydirectories_summary">डिभाइसभरिबाट खाली फोल्डरहरू। नेस्टेड फोल्डरहरूलाई धेरै पास चाहिन सक्छ।</string>
    <string name="systemcleaner_filter_screenshots_label">स्क्रिनसटहरू</string>
    <string name="systemcleaner_filter_screenshots_summary">बहुविध एप्स र स्थानहरूबाट %s भन्दा पुराना स्क्रिनसटहरू।</string>
    <string name="systemcleaner_filter_trashed_label">पेटीमा फालिएका फाइलहरू</string>
    <string name="systemcleaner_filter_trashed_summary">विभिन्न एप्स र स्थानहरूका रिसाइकल बिनमा रहेका फाइलहरू जुन मेटाउनको लागि चिन्ह लगाइएको छ तर अझै सम्म हटाइएको छैन।</string>
    <string name="systemcleaner_filter_screenshots_age_label">स्क्रिनसट उमेर</string>
    <string name="systemcleaner_filter_screenshots_age_summary">स्क्रिनसटहरूलाई मेटाउनको लागि विचार गरिने न्यूनतम उमेर।</string>
    <string name="systemcleaner_filter_superfluosapks_label">अनावश्यक APK हरू</string>
    <string name="systemcleaner_filter_superfluosapks_summary">स्थापित अनुप्रयोग संस्करणहरूमा आधारित अब आवश्यक नपरेका सेटअप फाइलहरू।</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">समान संस्करण समावेश गर्नुहोस्</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">स्थापित संस्करणसँग मेल खाने APK फाइलहरूलाई पनि लक्ष्य गर्नुहोस्। पुराना संस्करणहरू मात्र हटाउन अक्षम गर्नुहोस्।</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR फोल्डरहरू</string>
    <string name="systemcleaner_filter_lostdir_summary">Android डिभाइसहरू बिच डेटा स्थानान्तरण गर्दा सिर्जना हुने अस्थायी फाइलहरू।</string>
    <string name="systemcleaner_filter_linuxfiles_label">Linux फाइलहरू</string>
    <string name="systemcleaner_filter_linuxfiles_summary">स्टोरेज Linux कम्प्युटरमा जोडिंदा सिर्जना हुने फाइल र फोल्डरहरू।</string>
    <string name="systemcleaner_filter_macfiles_label">Mac फाइलहरू</string>
    <string name="systemcleaner_filter_macfiles_summary">Apple को finder एप्ससँग स्टोरेज ब्राउज गर्दा सिर्जना हुने फाइल र फोल्डरहरू।</string>
    <string name="systemcleaner_filter_windowsfiles_label">Windows फाइलहरू</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Windows फाइल एक्सप्लोररले जोडिएको स्टोरेजमा सिर्जना गर्न सक्ने डेटा।"</string>
    <string name="systemcleaner_filter_thumbnails_label">थम्बनेल छविहरू</string>
    <string name="systemcleaner_filter_thumbnails_summary">छवि र भिडियोहरूका लागि क्यास्ह गरिएका पूर्वावलोकनहरू।</string>
    <string name="systemcleaner_filter_tempfiles_label">अस्थायी सिस्टम फाइलहरू</string>
    <string name="systemcleaner_filter_tempfiles_summary">सिस्टम सम्बन्धित अस्थायी फाइलहरू, सामान्यतया सक्रिय कार्यहरूका लागि छोटो अवधिका क्यास्हहरू।</string>
    <string name="systemcleaner_filter_analytics_label">एनालिटिक्स फाइलहरू</string>
    <string name="systemcleaner_filter_analytics_summary">एनालिटिक्स र बग ट्र्याकिँसँग सम्बन्धित डेटा।</string>
    <string name="systemcleaner_filter_downloadcache_label">डाउनलोड क्यास्ह</string>
    <string name="systemcleaner_filter_downloadcache_summary">विभिन्न कामहरूका लागि प्रयोग गरिने सिस्टम क्यास्ह फोल्डर (जस्तै OTA अपडेटहरू)।</string>
    <string name="systemcleaner_filter_localtmp_label">स्थानीय अस्थायी फाइलहरू</string>
    <string name="systemcleaner_filter_localtmp_summary">सिस्टम सम्बन्धित अस्थायी फाइलहरू (जस्तै Android Studio बाट)।</string>
    <string name="systemcleaner_filter_datalogger_label">सिस्टम लग फाइलहरू</string>
    <string name="systemcleaner_filter_datalogger_summary">सिस्टम सेवा विशिष्ट लग फाइलहरू।</string>
    <string name="systemcleaner_filter_logdropbox_label">लग ड्रप बक्स</string>
    <string name="systemcleaner_filter_logdropbox_summary">सिस्टमले लग फाइलहरू राख्ने क्षेत्र।</string>
    <string name="systemcleaner_filter_recenttasks_label">हालका कार्यहरू</string>
    <string name="systemcleaner_filter_recenttasks_summary">प्रणालीको कार्य स्विचरमा रहेको कार्यहरूको इतिहाससँग सम्बन्धित डेटा।</string>
    <string name="systemcleaner_filter_tombstones_label">प्रणाली क्र्यास अवशेष</string>
    <string name="systemcleaner_filter_tombstones_summary">यदि मूल प्रक्रियाहरू क्र्यास हुन्छन् (जस्तै खेलहरू), तब यहाँ फाइलहरू सिर्जना हुन्छन्।</string>
    <string name="systemcleaner_filter_usagestats_label">प्रयोग तथ्याङ्क</string>
    <string name="systemcleaner_filter_usagestats_summary">एप्लिकेसन प्रयोग तथ्याङ्कसँग सम्बन्धित फाइलहरू।</string>
    <string name="systemcleaner_delete_all_confirmation_message">सबै फिल्टर सामग्रीहरू मेटाउने?</string>
    <string name="systemcleaner_customfilter_label">कस्टम फिल्टर</string>
    <string name="systemcleaner_customfilter_create_hint">तपाईंको उपकरण र प्रयोग-स्थितिहरूमा अद्वितीय अतिरिक्त फाइलहरू मेटाउन कस्टम फिल्टर सिर्जना गर्नुहोस्।</string>
    <string name="systemcleaner_editor_remove_confirmation_message">यो फिल्टर हटाउने?</string>
    <string name="systemcleaner_customfilter_editor_label_label">फिल्टर लेबल</string>
    <string name="systemcleaner_customfilter_editor_warning">कस्टम फिल्टरहरू जोखिमपूर्ण हुन सक्छन्। मेटाउनु अघि तपाईंको स्क्यान परिणामहरू जाँच गर्नुहोस्!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">डेटा क्षेत्रहरू</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">यदि कुनै क्षेत्र चयन नगरिएको छ भने, सबै पहुँचयोग्य डेटा क्षेत्रहरू स्क्यान र मिलान गरिनेछ।</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">फाइल प्रकार प्रतिबन्धहरू</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">फाइलहरू</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">फोल्डरहरू</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">यदि कुनै प्रकार चयन नगरिएको छ भने, सबै प्रकारहरू मिलान गरिनेछ।</string>
    <string name="systemcleaner_customfilter_editor_path_label">पथ मापदण्डहरू</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">लक्षित पथले कम्तिमा एक प्रविष्टिसँग मेल खानुपर्छ (जस्तै \"Downloads/oldapks/game-\")। थप विकल्पहरूका लागि प्रविष्टिहरूलाई लामो समयसम्म दबाउनुहोस्।</string>
    <string name="systemcleaner_customfilter_editor_name_label">नाम मापदण्डहरू</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">लक्षित नाममा कम्तिमा एक मुख्य शब्द हुनुपर्छ (जस्तै \"-receipt\")। थप विकल्पहरूका लागि प्रविष्टिहरूलाई लामो समयसम्म दबाउनुहोस्।</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">अपवर्जनहरू</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">यदि पथ कुनै प्रविष्टिसँग मेल खान्छ भने परिणाम अपवर्जित हुनेछ (जस्तै \"DCIM\")। थप विकल्पहरूका लागि प्रविष्टिहरूलाई लामो समयसम्म दबाउनुहोस्।</string>
