    <string name="systemcleaner_filter_custom_label">Filtra te kostumizuar</string>
    <string name="systemcleaner_filter_custom_manage_label">Menaxho filtrat e personalizuar</string>
    <string name="systemcleaner_filter_custom_manage_summary">Krijoni, fshini, importoni dhe eksportoni filtrat tuaj të personalizuar.</string>
    <string name="systemcleaner_filter_logfiles_label">Skedarët e log-ut të sistemit</string>
    <string name="systemcleaner_filter_logfiles_summary">Skedarët e log-ut të sistemit dhe shërbimeve të sistemit (p.sh. *.log) në vende të ndryshme.</string>
    <string name="systemcleaner_filter_packagecaches_label">Cache-i i instaluesit</string>
    <string name="systemcleaner_filter_packagecaches_summary">Të dhëna të cache-uara lidhur me aplikacionet e instaluara që përdoren nga menaxhimi i paketave të sistemit.</string>
    <string name="systemcleaner_filter_advertisements_label">Skedarët e reklamave</string>
    <string name="systemcleaner_filter_advertisements_summary">Skedarët që janë krijuar për ose nga reklamat.</string>
    <string name="systemcleaner_filter_anr_label">Gabime ANR</string>
    <string name="systemcleaner_filter_anr_summary">Gjurmët nga ngjarjet \"aplikacioni nuk përgjigjet\".</string>
    <string name="systemcleaner_filter_emptydirectories_label">Dosjet bosh</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Zbrazni dosjet nga e gjithë pajisja. Dosjet e mbivendosura mund të kërkojnë kalime të shumta.</string>
    <string name="systemcleaner_filter_screenshots_label">Pamjet e ekranit</string>
    <string name="systemcleaner_filter_screenshots_summary">Pamje ekrani më të vjetra se %s nga aplikacione dhe vende të shumta.</string>
    <string name="systemcleaner_filter_trashed_label">Skedarët në kosh</string>
    <string name="systemcleaner_filter_trashed_summary">Skedarë në koshet e riciklimit nga aplikacione dhe vende të ndryshme që janë shënuar për fshirje por ende nuk janë hequr përgjithmonë.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Mosha e pamjeve të ekranit</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Mosha minimale për pamjet e ekranit që të konsiderohen për fshirje.</string>
    <string name="systemcleaner_filter_superfluosapks_label">APK të tepërta ose të panevojshme</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Skedarë instalimi që nuk nevojiten më bazuar në versionet e aplikacioneve të instaluara.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Përfshi të njëjtin version</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Synoni gjithashtu skedarët APK që përputhen me versionin e instaluar. Çaktivizo për të hequr vetëm versionet më të vjetra.</string>
    <string name="systemcleaner_filter_lostdir_label">Dosjet LOST.DIR</string>
    <string name="systemcleaner_filter_lostdir_summary">Skedarët e përkohshëm që krijohen gjatë transferimit të të dhënave midis pajisjeve Android.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Skedarët Linux</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Skedarët dhe dosjet që krijohen kur ruajtja është lidhur me një kompjuter linux.</string>
    <string name="systemcleaner_filter_macfiles_label">Skedarët Mac</string>
    <string name="systemcleaner_filter_macfiles_summary">Skedarët dhe dosjet që krijohen kur shfletoni hapësirën ruajtëse me aplikacionin gjetës të Apple.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Skedarët Windows</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Të dhëna që eksploreri i skedarëve të Windows mund të krijojë në ruajtjen e lidhur."</string>
    <string name="systemcleaner_filter_thumbnails_label">Imazhe miniaturë</string>
    <string name="systemcleaner_filter_thumbnails_summary">Pamje paraprake të ruajtura në memorie për imazhe dhe video.</string>
    <string name="systemcleaner_filter_tempfiles_label">Skedarët e përkohshëm të sistemit</string>
    <string name="systemcleaner_filter_tempfiles_summary">Skedarë të përkohshëm të lidhur me sistemin, zakonisht cache-e të shkurtra për operacione aktive.</string>
    <string name="systemcleaner_filter_analytics_label">Skedarët e analitikës</string>
    <string name="systemcleaner_filter_analytics_summary">Të dhëna në lidhje me analitikën dhe gjurmimin e gabimeve.</string>
    <string name="systemcleaner_filter_downloadcache_label">Shkarkoni cache</string>
    <string name="systemcleaner_filter_downloadcache_summary">Dosja e memories së sistemit që përdoret për gjëra të ndryshme (p.sh. përditësime OTA).</string>
    <string name="systemcleaner_filter_localtmp_label">Skedarët e përkohshëm lokalë</string>
    <string name="systemcleaner_filter_localtmp_summary">Skedarët e përkohshëm të lidhur me sistemin (p.sh. nga Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Skedarët e regjistrit të sistemit</string>
    <string name="systemcleaner_filter_datalogger_summary">Skedarët e regjistrit specifik të shërbimit të sistemit.</string>
    <string name="systemcleaner_filter_logdropbox_label">Kutia e lëshimit të regjistrit</string>
    <string name="systemcleaner_filter_logdropbox_summary">Një zonë në të cilën sistemi do të hedhë skedarët e regjistrave.</string>
    <string name="systemcleaner_filter_recenttasks_label">Detyrat e fundit</string>
    <string name="systemcleaner_filter_recenttasks_summary">Të dhëna që lidhen me historikun e detyrave në ndërruesin e detyrave të sistemit.</string>
    <string name="systemcleaner_filter_tombstones_label">Mbetjet nga dështimi i sistemit</string>
    <string name="systemcleaner_filter_tombstones_summary">Nëse proceset vendase prishen (p.sh. lojërat), atëherë skedarët krijohen këtu.</string>
    <string name="systemcleaner_filter_usagestats_label">Statistikat e përdorimit</string>
    <string name="systemcleaner_filter_usagestats_summary">Skedarët që lidhen me statistikat e përdorimit të aplikacionit.</string>
    <string name="systemcleaner_delete_all_confirmation_message">Të fshihet e gjithë përmbajtja e filtrit?</string>
    <string name="systemcleaner_customfilter_label">Filtri i personalizuar</string>
    <string name="systemcleaner_customfilter_create_hint">Krijoni një filtër të personalizuar për të fshirë skedarë shtesë që janë unikë për pajisjen tuaj dhe rastet e përdorimit.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">Të hiqet ky filtër?</string>
    <string name="systemcleaner_customfilter_editor_label_label">Etiketa e filtrit</string>
    <string name="systemcleaner_customfilter_editor_warning">Filtrat e personalizuar mund të jenë të rrezikshëm. Kontrolloni rezultatet e skanimit përpara se t\'i fshini!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">Zonat e të dhënave</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Nëse nuk zgjidhet asnjë zonë, atëherë të gjitha zonat e aksesueshme të të dhënave do të skanohen dhe përputhen.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">Kufizimet e llojit të skedarit</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">Skedarë</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">Dosjet</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">Nëse nuk zgjidhet asnjë lloj, atëherë të gjitha llojet do të përputhen.</string>
    <string name="systemcleaner_customfilter_editor_path_label">Kriteriumi i rrugës</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Ruga e synuar duhet të përputhet me të paktën një hyrje (p.sh. \"Shkarkime/oldapks/lojë-\"). Shtypni gjatë shënimet për më shumë opsione.</string>
    <string name="systemcleaner_customfilter_editor_name_label">Kriteret e emrit</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">Emri në fjalë duhet të përmbajë të paktën një nga fjalët kyçe (p.sh. \"-receipt\"). Shtypni gjatë shënimet për më shumë opsione.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Përjashtimet</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Rezultati do të përjashtohet nëse ruga përputhet me ndonjë hyrje (p.sh. \"DCIM\"). Shtypni gjatë shënimet për më shumë opsione.</string>
