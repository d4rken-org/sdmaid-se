<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="systemcleaner_explanation_short">특정 앱에 소유되지 않은 불필요한 데이터입니다.</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="other">%d개의 항목을 삭제했습니다</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="other">%d개의 파일 찾음</item>
    </plurals>
    <string name="systemcleaner_filter_custom_label">사용자 지정 필터</string>
    <string name="systemcleaner_filter_custom_manage_label">사용자 정의 필터 관리</string>
    <string name="systemcleaner_filter_custom_manage_summary">사용자 지정 필터를 만들거나, 삭제하거나, 불러오고 내보내세요.</string>
    <string name="systemcleaner_filter_logfiles_label">시스템 로그 파일</string>
    <string name="systemcleaner_filter_logfiles_summary">여러 위치의 시스템 및 시스템 서비스 로그 파일(예: *.log)입니다.</string>
    <string name="systemcleaner_filter_packagecaches_label">설치 프로그램 캐시</string>
    <string name="systemcleaner_filter_packagecaches_summary">시스템의 패키지 관리에서 사용하는 설치된 앱과 관련된 캐시된 데이터입니다.</string>
    <string name="systemcleaner_filter_advertisements_label">광고 파일</string>
    <string name="systemcleaner_filter_advertisements_summary">광고에 의해, 또는 광고를 위해 생성한 파일입니다.</string>
    <string name="systemcleaner_filter_anr_label">응답 없음 에러</string>
    <string name="systemcleaner_filter_anr_summary">애플리케이션이 응답이 없을 때 생성되는 추적용 파일입니다.</string>
    <string name="systemcleaner_filter_emptydirectories_label">빈 폴더</string>
    <string name="systemcleaner_filter_emptydirectories_summary">기기에 퍼져있는 빈 폴더들입니다. 다중 폴더의 경우 여러 번의 시도가 필요할 수 있습니다.</string>
    <string name="systemcleaner_filter_screenshots_label">스크린샷</string>
    <string name="systemcleaner_filter_screenshots_summary">여러 앱과 위치에서 %s보다 오래된 스크린샷입니다.</string>
    <string name="systemcleaner_filter_trashed_label">휴지통 파일</string>
    <string name="systemcleaner_filter_trashed_summary">삭제 표시되었지만 아직 영구적으로 제거되지 않은 다양한 앱과 위치의 휴지통에 있는 파일입니다.</string>
    <string name="systemcleaner_filter_screenshots_age_label">스크린샷 기간</string>
    <string name="systemcleaner_filter_screenshots_age_summary">삭제 대상으로 간주할 스크린샷의 최소 기간입니다.</string>
    <string name="systemcleaner_filter_superfluosapks_label">불필요한 APK 파일</string>
    <string name="systemcleaner_filter_superfluosapks_summary">설치된 앱 버전에 따라 더 이상 필요하지 않은 설치 파일입니다.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">동일 버전 포함</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">설치된 버전과 일치하는 APK 파일도 대상으로 합니다. 비활성화하면 이전 버전만 제거합니다.</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR 폴더</string>
    <string name="systemcleaner_filter_lostdir_summary">안드로이드 기기간 데이터를 이동할 때 생기는 임시 파일입니다.</string>
    <string name="systemcleaner_filter_linuxfiles_label">리눅스 파일</string>
    <string name="systemcleaner_filter_linuxfiles_summary">리눅스 컴퓨터에 연결할 때 생성되는 파일과 폴더들입니다.</string>
    <string name="systemcleaner_filter_macfiles_label">맥 파일</string>
    <string name="systemcleaner_filter_macfiles_summary">애플의 Finder 앱을 이용할 때 생성되는 파일 및 폴더입니다.</string>
    <string name="systemcleaner_filter_windowsfiles_label">윈도우 파일</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"연결된 저장소에서 Windows 파일 탐색기가 만들 수 있는 데이터입니다."</string>
    <string name="systemcleaner_filter_thumbnails_label">썸네일 이미지</string>
    <string name="systemcleaner_filter_thumbnails_summary">사진과 영상의 미리보기 파일입니다.</string>
    <string name="systemcleaner_filter_tempfiles_label">임시 시스템 파일</string>
    <string name="systemcleaner_filter_tempfiles_summary">시스템 관련 임시 파일로, 일반적으로 활성 작업을 위한 단기 캐시입니다.</string>
    <string name="systemcleaner_filter_analytics_label">분석 파일</string>
    <string name="systemcleaner_filter_analytics_summary">버그 추적과 분석에 사용되는 파일입니다.</string>
    <string name="systemcleaner_filter_downloadcache_label">다운로드 캐시</string>
    <string name="systemcleaner_filter_downloadcache_summary">시스템이 업데이트 등에 사용하는 임시 캐시 폴더입니다.</string>
    <string name="systemcleaner_filter_localtmp_label">로컬 임시 파일</string>
    <string name="systemcleaner_filter_localtmp_summary">시스템과 관련된 임시 파일입니다. (안드로이드 스튜디오 등에서 생성)</string>
    <string name="systemcleaner_filter_datalogger_label">시스템 로그 파일</string>
    <string name="systemcleaner_filter_datalogger_summary">시스템 서비스가 생성하는 로그 파일입니다.</string>
    <string name="systemcleaner_filter_logdropbox_label">로그 저장소</string>
    <string name="systemcleaner_filter_logdropbox_summary">시스템이 로그 파일을 저장하는 장소입니다.</string>
    <string name="systemcleaner_filter_recenttasks_label">최근 작업</string>
    <string name="systemcleaner_filter_recenttasks_summary">시스템 최근 앱 보기와 관련된 데이터입니다.</string>
    <string name="systemcleaner_filter_tombstones_label">시스템 크래시 잔여물</string>
    <string name="systemcleaner_filter_tombstones_summary">게임 등과 같은 프로세스가 크래시했을 때 생성되는 파일입니다.</string>
    <string name="systemcleaner_filter_usagestats_label">사용 통계</string>
    <string name="systemcleaner_filter_usagestats_summary">사용 통계와 관련된 임시 파일.</string>
    <string name="systemcleaner_delete_all_confirmation_message">찾은 파일들을 모두 삭제할까요?</string>
    <string name="systemcleaner_customfilter_label">사용자 정의 필터</string>
    <string name="systemcleaner_customfilter_create_hint">사용자 정의 필터를 만들어 장치 및 사용 사례에 고유한 추가 파일을 삭제할 수 있습니다.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">이 필터를 삭제하시겠습니까?</string>
    <string name="systemcleaner_customfilter_editor_label_label">필터 라벨</string>
    <string name="systemcleaner_customfilter_editor_warning">사용자 정의 필터는 위험할 수 있습니다. 삭제하기 전에 스캔 결과를 확인하세요!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">데이터 영역</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">영역을 선택하지 않으면 액세스 가능한 모든 데이터 영역이 매칭되어 스캔됩니다.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">파일 형식 제한</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">파일</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">폴더</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">유형을 선택하지 않으면 모든 유형이 매칭됩니다.</string>
    <string name="systemcleaner_customfilter_editor_path_label">경로 조건</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">대상 경로는 적어도 하나의 항목과 일치해야 합니다 (예: \"Downloads/oldapks/game-\"). 더 많은 옵션을 보려면 항목을 길게 누르세요.</string>
    <string name="systemcleaner_customfilter_editor_name_label">이룸 조건</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">대상 이름에는 키워드 중 하나 이상이 포함되어야 합니다 (예: \"-영수증\"). 더 많은 옵션을 보려면 항목을 길게 누르세요.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">제외 항목</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">경로가 어떤 항목 (예: \"DCIM\")과 일치하는 경우 결과는 제외됩니다. 더 많은 옵션을 보려면 항목을 길게 누르세요.</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_label">경로 비교 모드</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_start_label">경로가 키워드로 시작</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_contains_label">경로에 키워드 포함</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_end_label">경로가 키워드로 끝남</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">경로가 키워드와 같음</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">이름 비교 모드</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">이름이 키워드로 시작됩니다.</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">이름에 키워드가 포함되어 있습니다.</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">이름이 키워드로 종료됩니다.</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">이름이 키워드와 동일합니다.</string>
    <string name="systemcleaner_customfilter_last_edit">최종 수정: %s</string>
    <string name="systemcleaner_customfilter_editor_livesearch_label">실시간 검색</string>
    <string name="systemcleaner_customfilter_editor_size_label">크기 제한</string>
    <string name="systemcleaner_customfilter_editor_size_minimum_label">최소 크기</string>
    <string name="systemcleaner_customfilter_editor_size_maximum_label">최대 크기</string>
    <string name="systemcleaner_customfilter_editor_size_explanation">파일 크기를 기준으로 일치를 제한합니다. 모든 크기와 일치하려면 설정하지 마세요.</string>
    <string name="systemcleaner_customfilter_editor_age_label">기간 제한</string>
    <string name="systemcleaner_customfilter_editor_age_minimum_label">최소 기간</string>
    <string name="systemcleaner_customfilter_editor_age_maximum_label">최대 기간</string>
    <string name="systemcleaner_customfilter_editor_age_explanation">파일 기간(마지막 수정 시간)을 기준으로 일치를 제한합니다. 모든 기간과 일치하려면 설정하지 마세요.</string>
    <string name="systemcleaner_customfilter_import_action">새로운 필터 가져오기</string>
    <string name="systemcleaner_customfilter_export_action">선택한 필터 내보내기</string>
</resources>
