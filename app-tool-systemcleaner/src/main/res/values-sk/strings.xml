    <string name="systemcleaner_filter_custom_label">Vlastný filter</string>
    <string name="systemcleaner_filter_custom_manage_label">Spravovať vlastné filtre</string>
    <string name="systemcleaner_filter_custom_manage_summary">Vytvorte, odstráňte, importujte a exportujte svoje vlastné filtre.</string>
    <string name="systemcleaner_filter_logfiles_label">Súbory systémového protokolu</string>
    <string name="systemcleaner_filter_logfiles_summary">Súbory protokolu systému a systémových služieb (napr. *.log) na rôznych miestach.</string>
    <string name="systemcleaner_filter_packagecaches_label">Vyrovnávacia pamäť inštalátora</string>
    <string name="systemcleaner_filter_packagecaches_summary">Údaje vo vyrovnávacej pamäti súvisiace s nainštalovanými aplikáciami, ktoré používa správa balíkov systému.</string>
    <string name="systemcleaner_filter_advertisements_label">Reklamné súbory</string>
    <string name="systemcleaner_filter_advertisements_summary">Súbory, ktoré boli vytvorené pre reklamy alebo prostredníctvom reklám.</string>
    <string name="systemcleaner_filter_anr_label">ANR chyby</string>
    <string name="systemcleaner_filter_anr_summary">Sledovanie udalostí typu „aplikácia nereaguje“.</string>
    <string name="systemcleaner_filter_emptydirectories_label">Prázdne priečinky</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Vyprázdnite priečinky z celého zariadenia. Vnorené priečinky môžu vyžadovať viacero prechodov.</string>
    <string name="systemcleaner_filter_screenshots_label">Snímky obrazovky</string>
    <string name="systemcleaner_filter_screenshots_summary">Snímky obrazovky staršie ako %s z viacerých aplikácií a umiestnení.</string>
    <string name="systemcleaner_filter_trashed_label">Súbory v koši</string>
    <string name="systemcleaner_filter_trashed_summary">Súbory v odpadkových košoch z rôznych aplikácií a miest, ktoré are označené na odstránenie, ale ešte neboli natrvalo odstránené.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Vek snímky obrazovky</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Minimálny vek pre snímky obrazovky, ktoré je potrebné zvážiť na odstránenie.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Nadbytočné súbory APK</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Inštalačné súbory, ktoré už nie sú potrebné na základe nainštalovaných verzií aplikácií.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Zahrnúť rovnakú verziu</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Zamerajte sa aj na súbory APK, ktoré zodpovedajú nainštalovanej verzii. Zakážte, ak chcete odstrániť iba staršie verzie.</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR priečinky</string>
    <string name="systemcleaner_filter_lostdir_summary">Dočasné súbory, ktoré sa vytvárajú pri prenose údajov medzi zariadeniami so systémom Android.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Linux súbory</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Súbory a priečinky, ktoré sa vytvoria po pripojení úložiska k počítaču so systémom Linux.</string>
    <string name="systemcleaner_filter_macfiles_label">Mac súbory</string>
    <string name="systemcleaner_filter_macfiles_summary">Súbory a priečinky, ktoré sa vytvárajú pri prehliadaní úložiska pomocou aplikácie Apple Finder.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Windows súbory</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Údaje, ktoré môže prieskumník súborov systému Windows vytvoriť na pripojenom úložisku."</string>
    <string name="systemcleaner_filter_thumbnails_label">Náhľady obrázkov</string>
    <string name="systemcleaner_filter_thumbnails_summary">Ukážky obrázkov a videí uložené vo vyrovnávacej pamäti.</string>
    <string name="systemcleaner_filter_tempfiles_label">Dočasné systémové súbory</string>
    <string name="systemcleaner_filter_tempfiles_summary">Dočasné súbory súvisiace so systémom, zvyčajne krátkodobé vyrovnávacie pamäte pre aktívne operácie.</string>
    <string name="systemcleaner_filter_analytics_label">Analytické súbory</string>
    <string name="systemcleaner_filter_analytics_summary">Údaje súvisiace s analytikou a sledovaním chýb.</string>
    <string name="systemcleaner_filter_downloadcache_label">Vyrovnávacia pamäť sťahovania</string>
    <string name="systemcleaner_filter_downloadcache_summary">Priečinok vyrovnávacej pamäte systému používaný na rôzne veci (napr. aktualizácie OTA).</string>
    <string name="systemcleaner_filter_localtmp_label">Miestne dočasné súbory</string>
    <string name="systemcleaner_filter_localtmp_summary">Dočasné súbory súvisiace so systémom (napr. z Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Súbory denníka systému</string>
    <string name="systemcleaner_filter_datalogger_summary">Súbory denníka špecifické pre systémovú službu.</string>
    <string name="systemcleaner_filter_logdropbox_label">Odkladacia schránka denníka</string>
    <string name="systemcleaner_filter_logdropbox_summary">Oblasť, do ktorej má systém vkladať súbory denníka.</string>
    <string name="systemcleaner_filter_recenttasks_label">Nedávne úlohy</string>
    <string name="systemcleaner_filter_recenttasks_summary">Údaje súvisiace s históriou úloh v systémovom prepínači úloh.</string>
    <string name="systemcleaner_filter_tombstones_label">Zvyšky zlyhania systému</string>
    <string name="systemcleaner_filter_tombstones_summary">Ak natívne procesy zlyhajú (napr. hry), súbory sa vytvoria tu.</string>
    <string name="systemcleaner_filter_usagestats_label">Štatistiky používania</string>
    <string name="systemcleaner_filter_usagestats_summary">Súbory súvisiace so štatistikami používania aplikácie.</string>
