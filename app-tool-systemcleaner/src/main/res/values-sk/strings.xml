    <string name="systemcleaner_customfilter_editor_warning">Vlastné filtre môžu byť riskantné. Pred odstránením skontrolujte výsledky skenovania!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">Dátové oblasti</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Ak nie je vybratá žiadna oblasť, všetky dostupné dátové oblasti budú naskenované a spárované.</string>
