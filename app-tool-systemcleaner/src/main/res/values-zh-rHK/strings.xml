    <string name="systemcleaner_filter_custom_manage_summary">建立、刪除、匯入或匯出您的自訂過濾器。</string>
    <string name="systemcleaner_filter_logfiles_label">系統記錄檔</string>
    <string name="systemcleaner_filter_logfiles_summary">各種位置的系統和系統服務記錄檔（例如 *.log）。</string>
    <string name="systemcleaner_filter_packagecaches_label">安裝程式快取</string>
    <string name="systemcleaner_filter_packagecaches_summary">與已安裝應用程式相關的快取資料，由系統的套件管理使用。</string>
    <string name="systemcleaner_filter_advertisements_label">廣告檔案</string>
    <string name="systemcleaner_filter_advertisements_summary">為廣告或由廣告建立的檔案。</string>
    <string name="systemcleaner_filter_anr_label">ANR 錯誤</string>
    <string name="systemcleaner_filter_anr_summary">來自「應用程式沒有回應」活動的追蹤。</string>
    <string name="systemcleaner_filter_emptydirectories_label">空資料夾</string>
    <string name="systemcleaner_filter_emptydirectories_summary">來自裝置各處的空資料夾。巢狀資料夾可能需要多次處理。</string>
    <string name="systemcleaner_filter_screenshots_label">螢幕截圖</string>
    <string name="systemcleaner_filter_screenshots_summary">來自多個應用程式和位置的超過 %s 的螢幕截圖。</string>
    <string name="systemcleaner_filter_trashed_label">回收站檔案</string>
    <string name="systemcleaner_filter_trashed_summary">來自各種應用程式和位置的回收站中標記為刪除但尚未永久移除的檔案。</string>
    <string name="systemcleaner_filter_screenshots_age_label">螢幕截圖年齡</string>
    <string name="systemcleaner_filter_screenshots_age_summary">螢幕截圖被考慮刪除的最小年齡。</string>
    <string name="systemcleaner_filter_superfluosapks_label">非必要的 APK 檔案</string>
    <string name="systemcleaner_filter_superfluosapks_summary">根據已安裝應用程式版本而不再需要的安裝檔案。</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">包含相同版本</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">也包括與已安裝版本相符的 APK 檔案。停用以只移除舊版本。</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR 資料夾</string>
    <string name="systemcleaner_filter_lostdir_summary">在 Android 裝置之間傳輸資料時建立的暫存檔案。</string>
    <string name="systemcleaner_filter_linuxfiles_label">Linux 檔案</string>
    <string name="systemcleaner_filter_linuxfiles_summary">儲存裝置連接至 Linux 電腦時建立的檔案和資料夾。</string>
    <string name="systemcleaner_filter_macfiles_label">Mac 檔案</string>
    <string name="systemcleaner_filter_macfiles_summary">使用 Apple 的 Finder 應用程式瀏覽儲存裝置時建立的檔案和資料夾。</string>
    <string name="systemcleaner_filter_windowsfiles_label">Windows 檔案</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Windows 檔案總管可在連接的儲存空間上建立的資料。"</string>
    <string name="systemcleaner_filter_thumbnails_label">縮圖影像</string>
    <string name="systemcleaner_filter_thumbnails_summary">圖片和影片的快取預覽。</string>
    <string name="systemcleaner_filter_tempfiles_label">臨時系統檔案</string>
    <string name="systemcleaner_filter_tempfiles_summary">與系統相關的臨時檔案，通常是活動操作的短期快取。</string>
    <string name="systemcleaner_filter_analytics_label">分析檔案</string>
    <string name="systemcleaner_filter_analytics_summary">與分析和錯誤追縱相關的資料。</string>
    <string name="systemcleaner_filter_downloadcache_label">下載快取</string>
    <string name="systemcleaner_filter_downloadcache_summary">用於各種作業的系統快取 (例如 OTA 更新)。</string>
    <string name="systemcleaner_filter_localtmp_label">本機暫存檔案</string>
    <string name="systemcleaner_filter_localtmp_summary">與系統相關的暫存檔案 (例如來自 Android Studio)。</string>
    <string name="systemcleaner_filter_datalogger_label">系統記錄檔案</string>
    <string name="systemcleaner_filter_datalogger_summary">系統服務特定的記錄檔案。</string>
    <string name="systemcleaner_filter_logdropbox_label">記錄投寄箱</string>
    <string name="systemcleaner_filter_logdropbox_summary">用於系統投寄記錄檔案的區域。</string>
    <string name="systemcleaner_filter_recenttasks_label">最近工作</string>
    <string name="systemcleaner_filter_recenttasks_summary">與系統的工作切換器中的工作歷史記錄相關的資料。</string>
    <string name="systemcleaner_filter_tombstones_label">系統當機殘留</string>
    <string name="systemcleaner_filter_tombstones_summary">如果原生處理程序當機 (例如遊戲)，檔案將在此建立。</string>
    <string name="systemcleaner_filter_usagestats_label">使用量統計資料</string>
