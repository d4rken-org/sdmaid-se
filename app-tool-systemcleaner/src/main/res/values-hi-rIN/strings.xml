<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="systemcleaner_explanation_short">अनावश्यक डेटा जो किसी विशिष्ट ऐप से संबंधित नहीं है।</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="one">%d सिस्टम जंक आइटम मिटाया गया</item>
        <item quantity="other">%d सिस्टम जंक आइटम मिटाए गए</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="one">%d फ़िल्टर अनुरूप</item>
        <item quantity="other">%d फ़िल्टर अनुरूप हुआ</item>
    </plurals>
    <string name="systemcleaner_filter_custom_label">उपयोगानुसार फिल्टर</string>
    <string name="systemcleaner_filter_custom_manage_label">उपयोगानुसार फ़िल्टर प्रबंधित करें</string>
    <string name="systemcleaner_filter_custom_manage_summary">अपने उपयोगानुसार फ़िल्टर बनाएं, मिटाएं, आयात और निर्यात करें।</string>
    <string name="systemcleaner_filter_logfiles_label">सिस्टम लॉग फ़ाइलें</string>
    <string name="systemcleaner_filter_logfiles_summary">डिबगिंग या लॉगिंग के लिए उत्पन्न की गई फ़ाइलें।</string>
    <string name="systemcleaner_filter_packagecaches_label">इंस्टॉलर कैश</string>
    <string name="systemcleaner_filter_packagecaches_summary">इंस्टॉल किए गए ऐप्स से संबंधित कैश डेटा जो सिस्टम के पैकेज प्रबंधन द्वारा उपयोग किया जाता है।</string>
    <string name="systemcleaner_filter_advertisements_label">विज्ञापन की फाइलें</string>
    <string name="systemcleaner_filter_advertisements_summary">फ़ाइलें जो विज्ञापनों के लिए या उनके द्वारा बनाई गई हैं।</string>
    <string name="systemcleaner_filter_anr_label">ANR त्रुटी</string>
    <string name="systemcleaner_filter_anr_summary">आयोजन के अनुसार \'ऐप जवाब नहीं दे रहा है\'</string>
    <string name="systemcleaner_filter_emptydirectories_label">खाली फ़ोल्डर</string>
    <string name="systemcleaner_filter_emptydirectories_summary">डिवाइस भर से खाली फ़ोल्डर। नेस्टेड फ़ोल्डर के लिए कई पास की आवश्यकता हो सकती है।</string>
    <string name="systemcleaner_filter_screenshots_label">स्क्रीनशॉट</string>
    <string name="systemcleaner_filter_screenshots_summary">कई ऐप्स और स्थानों से %s से पुराने स्क्रीनशॉट।</string>
    <string name="systemcleaner_filter_trashed_label">कचरे में डाली गई फ़ाइलें</string>
    <string name="systemcleaner_filter_trashed_summary">विभिन्न ऐप्स और स्थानों से रीसायकल बिन में फ़ाइलें जो मिटाने के लिए चिह्नित हैं लेकिन अभी तक स्थायी रूप से हटाई नहीं गई हैं।</string>
    <string name="systemcleaner_filter_screenshots_age_label">स्क्रीनशॉट की आयु</string>
    <string name="systemcleaner_filter_screenshots_age_summary">स्क्रीनशॉट को मिटाने के लिए विचार करने के लिए न्यूनतम आयु।</string>
    <string name="systemcleaner_filter_superfluosapks_label">अत्यधिक APKs</string>
    <string name="systemcleaner_filter_superfluosapks_summary">इंस्टॉल किए गए एप संस्करणों के आधार पर अब आवश्यक नहीं रहे सेटअप फ़ाइलें।</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">समान संस्करण शामिल करें</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">स्थापित संस्करण से मेल खाने वाली APK फ़ाइलों को भी लक्षित करें। केवल पुराने संस्करण हटाने के लिए अक्षम करें।</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR फोल्डर</string>
    <string name="systemcleaner_filter_lostdir_summary">अस्थायी फ़ाइलें जो एंड्रॉयड उपकरणों के बीच डेटा स्थानांतरित करते समय बनाई जाती हैं।</string>
    <string name="systemcleaner_filter_linuxfiles_label">Linux फाइल</string>
    <string name="systemcleaner_filter_linuxfiles_summary">फ़ाइलें और फ़ोल्डर जो तब बनते हैं जब स्टोरेज को Linux कंप्यूटर से जोड़ा जाता है।</string>
    <string name="systemcleaner_filter_macfiles_label">Mac फाइल</string>
    <string name="systemcleaner_filter_macfiles_summary">फ़ाइलें और फ़ोल्डर जो Apple के finder ऐप के साथ स्टोरेज ब्राउज़ करते समय बनते हैं।</string>
    <string name="systemcleaner_filter_windowsfiles_label">विंडो फाइल</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"डेटा जो Windows फ़ाइल एक्सप्लोरर कनेक्टेड स्टोरेज पर बना सकता है।"</string>
    <string name="systemcleaner_filter_thumbnails_label">थंबनेल छवियां</string>
    <string name="systemcleaner_filter_thumbnails_summary">छवियों और वीडियो के लिए कैश्ड पूर्वावलोकन।</string>
    <string name="systemcleaner_filter_tempfiles_label">अस्थायी सिस्टम फ़ाइलें</string>
    <string name="systemcleaner_filter_tempfiles_summary">अस्थायी फ़ाइलें जो आमतौर पर ऐप बंद होने पर मिट जाती हैं।</string>
    <string name="systemcleaner_filter_analytics_label">विश्लेषिकी फ़ाइलें</string>
    <string name="systemcleaner_filter_analytics_summary">विश्लेषिकी और बग ट्रैकिंग से संबंधित डेटा।</string>
    <string name="systemcleaner_filter_downloadcache_label">कैश डाउनलोड करें</string>
    <string name="systemcleaner_filter_downloadcache_summary">विभिन्न चीजों के लिए उपयोग किया जाने वाला सिस्टम कैश फोल्डर (जैसे OTA अद्यतन)।</string>
    <string name="systemcleaner_filter_localtmp_label">स्थानीय अस्थायी फ़ाइलें</string>
    <string name="systemcleaner_filter_localtmp_summary">सिस्टम से संबंधित अस्थायी फ़ाइलें (जैसे एंड्रॉयड स्टूडियो से)।</string>
    <string name="systemcleaner_filter_datalogger_label">सिस्टम लॉग फाइल्स</string>
    <string name="systemcleaner_filter_datalogger_summary">सिस्टम सेवा विशिष्ट लॉग फ़ाइलें।</string>
    <string name="systemcleaner_filter_logdropbox_label">लॉग ड्रॉप बॉक्स</string>
    <string name="systemcleaner_filter_logdropbox_summary">सिस्टम के लिए एक क्षेत्र जिसमें लॉग फाइल डाली जाती है।</string>
    <string name="systemcleaner_filter_recenttasks_label">हाल के कार्य</string>
    <string name="systemcleaner_filter_recenttasks_summary">सिस्टम के कार्य बदलाव में कार्य इतिहास से संबंधित डेटा।</string>
    <string name="systemcleaner_filter_tombstones_label">सिस्टम क्रैश अवशेष</string>
    <string name="systemcleaner_filter_tombstones_summary">यदि मूल कार्य क्रैश होता है (जैसे कि गेम्स), तब फाइलें यहां बनाई जाती हैं।</string>
    <string name="systemcleaner_filter_usagestats_label">उपयोग के आँकड़े</string>
    <string name="systemcleaner_filter_usagestats_summary">एप्लिकेशन उपयोग आंकड़ों से संबंधित फ़ाइलें।</string>
    <string name="systemcleaner_delete_all_confirmation_message">सभी फ़िल्टर सामग्री मिटाएं?</string>
    <string name="systemcleaner_customfilter_label">कस्टम फ़िल्टर</string>
    <string name="systemcleaner_customfilter_create_hint">आपके डिवाइस और उपयोग-मामलों के लिए अनूठी अतिरिक्त फ़ाइलों को मिटाने के लिए एक कस्टम फ़िल्टर बनाएं।</string>
    <string name="systemcleaner_editor_remove_confirmation_message">इस फ़िल्टर को हटाएं?</string>
    <string name="systemcleaner_customfilter_editor_label_label">फ़िल्टर लेबल</string>
    <string name="systemcleaner_customfilter_editor_warning">कस्टम फ़िल्टर जोखिम भरे हो सकते हैं। मिटाने से पहले अपने स्कैन परिणामों की जांच करें!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">डेटा क्षेत्र</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">यदि कोई क्षेत्र चयनित नहीं है, तो सभी पहुंच योग्य डेटा क्षेत्रों को स्कैन और मिलान किया जाएगा।</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">फ़ाइल प्रकार प्रतिबंध</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">फ़ाइलें</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">डायरेक्टरी</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">फ़ाइल प्रकार प्रतिबंध केवल उस प्रकार के लिए मैचिंग को सीमित करते हैं। यदि कोई चयन नहीं किया गया है, तो दोनों प्रकार मैच करेंगे।</string>
    <string name="systemcleaner_customfilter_editor_path_label">पथ मानदंड</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">लक्ष्य पथ को कम से कम एक प्रविष्टि से मेल खाना चाहिए (जैसे \"Downloads/oldapks/game-\")। अधिक विकल्पों के लिए प्रविष्टियों को लंबे समय तक दबाएं।</string>
    <string name="systemcleaner_customfilter_editor_name_label">नाम मानदंड</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">लक्ष्य नाम में कम से कम एक कीवर्ड होना चाहिए (जैसे \"-receipt\")। अधिक विकल्पों के लिए प्रविष्टियों को लंबे समय तक दबाएं।</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">बहिष्करण</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">यदि पथ किसी प्रविष्टि से मेल खाता है तो परिणाम को बाहर कर दिया जाएगा (जैसे \"DCIM\")। अधिक विकल्पों के लिए प्रविष्टियों को लंबे समय तक दबाएं।</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_label">पथ तुलना मोड</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_start_label">पथ कीवर्ड से शुरू होता है</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_contains_label">पथ में कीवर्ड शामिल है</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_end_label">पथ कीवर्ड पर समाप्त होता है</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">पथ कीवर्ड के बराबर है</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">नाम तुलना मोड</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">नाम कीवर्ड से शुरू होता है</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">नाम में कीवर्ड शामिल है</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">नाम कीवर्ड पर समाप्त होता है</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">नाम कीवर्ड के बराबर है</string>
    <string name="systemcleaner_customfilter_last_edit">अंतिम संपादन: %s</string>
    <string name="systemcleaner_customfilter_editor_livesearch_label">लाइव खोज</string>
    <string name="systemcleaner_customfilter_editor_size_label">आकार प्रतिबंध</string>
    <string name="systemcleaner_customfilter_editor_size_minimum_label">न्यूनतम आकार</string>
    <string name="systemcleaner_customfilter_editor_size_maximum_label">अधिकतम आकार</string>
    <string name="systemcleaner_customfilter_editor_size_explanation">फ़ाइल आकार के आधार पर मिलान सीमित करें। किसी भी आकार से मिलान के लिए खाली छोड़ें।</string>
    <string name="systemcleaner_customfilter_editor_age_label">आयु प्रतिबंध</string>
    <string name="systemcleaner_customfilter_editor_age_minimum_label">न्यूनतम आयु</string>
    <string name="systemcleaner_customfilter_editor_age_maximum_label">अधिकतम आयु</string>
    <string name="systemcleaner_customfilter_editor_age_explanation">फ़ाइल आयु (अंतिम संशोधित समय) के आधार पर मिलान सीमित करें। किसी भी आयु से मिलान के लिए खाली छोड़ें।</string>
    <string name="systemcleaner_customfilter_import_action">नया फ़िल्टर आयात करें</string>
    <string name="systemcleaner_customfilter_export_action">चयनित फ़िल्टर निर्यात करें</string>
