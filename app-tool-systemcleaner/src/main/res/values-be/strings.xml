    <string name="systemcleaner_filter_custom_label">Карыстальніцкі фільтр</string>
    <string name="systemcleaner_filter_custom_manage_label">Кіраванне карыстальніцкімі фільтрамі</string>
    <string name="systemcleaner_filter_custom_manage_summary">Стварайце, выдаляйце, імпартуйце і экспартуйце вашы карыстальніцкія фільтры.</string>
    <string name="systemcleaner_filter_logfiles_label">Файлы сістэмнага журнала</string>
    <string name="systemcleaner_filter_logfiles_summary">Файлы журнала сістэмы і сістэмных службаў (напрыклад, *.log) у розных месцах.</string>
    <string name="systemcleaner_filter_packagecaches_label">Кэш усталёўшчыка</string>
    <string name="systemcleaner_filter_packagecaches_summary">Кэшаваныя даныя, звязаныя з усталяванымі праграмамі, якія выкарыстоўваюцца сістэмай кіравання пакетамі.</string>
    <string name="systemcleaner_filter_advertisements_label">Файлы рэкламы</string>
    <string name="systemcleaner_filter_advertisements_summary">Файлы, якія былі створаны для або з дапамогай рэкламы.</string>
    <string name="systemcleaner_filter_anr_label">Памылкі адказу праграм (ANR)</string>
    <string name="systemcleaner_filter_anr_summary">Сляды памылак тыпу \'праграма не адказвае\'.</string>
    <string name="systemcleaner_filter_emptydirectories_label">Пустыя папкі</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Пустыя папкі з усёй прылады. Для выяўлення ўкладзеных папак можа спатрэбіцца некалькі праходаў.</string>
    <string name="systemcleaner_filter_screenshots_label">Здымкі экрана</string>
    <string name="systemcleaner_filter_screenshots_summary">Здымкі экрана, старэйшыя за %s, з розных праграм і месцаў.</string>
    <string name="systemcleaner_filter_trashed_label">Выдаленыя файлы</string>
    <string name="systemcleaner_filter_trashed_summary">Файлы ў сметніцы з разнастайных праграм і месцаў, якія былі пазначаны да выдалення, але не выдалены канчаткова.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Час стварэння здымкаў экрана</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Мінімальны час стварэння для выдалення здымкаў экрана.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Лішнія файлы APK</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Наладзіць файлы, якія больш не патрэбныя ў залежнасці ад усталяваных версій праграм.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Уключаць тую ж версію</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Таксама апрацоўваць APK-файлы, якія адпавядаюць усталяванай версіі. Каб выдаляць толькі старыя версіі адключыце гэтую опцыю.</string>
    <string name="systemcleaner_filter_lostdir_label">Папкі LOST.DIR</string>
    <string name="systemcleaner_filter_lostdir_summary">Часовыя файлы, якія ствараюцца пры перадачы даных паміж прыладамі Android.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Файлы Linux</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Файлы і папкі, якія ствараюцца пры падключэнні сховішча да камп\'ютараў з сістэмай Linux.</string>
    <string name="systemcleaner_filter_macfiles_label">Файлы Mac</string>
    <string name="systemcleaner_filter_macfiles_summary">Файлы і папкі, якія ствараюцца пры праглядзе сховішча з дапамогай праграмы Apple Finder.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Файлы Windows</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Даныя, якія праграма Windows Explorer можа ствараць на падключаным сховішчы."</string>
    <string name="systemcleaner_filter_thumbnails_label">Эскізы выяў</string>
    <string name="systemcleaner_filter_thumbnails_summary">Кэшаваныя эскізы выяў і відэафайлаў.</string>
    <string name="systemcleaner_filter_tempfiles_label">Часовыя сістэмныя файлы</string>
    <string name="systemcleaner_filter_tempfiles_summary">Звязаныя з сістэмай часовыя файлы, якія звычайна змяшчаюць кароткачасовы кэш для актыўных аперацый.</string>
    <string name="systemcleaner_filter_analytics_label">Файлы аналітыкі</string>
    <string name="systemcleaner_filter_analytics_summary">Даныя, звязаныя з аналітыкай і адсочваннем памылак.</string>
    <string name="systemcleaner_filter_downloadcache_label">Кэш спамповак</string>
    <string name="systemcleaner_filter_downloadcache_summary">Папка з сістэмным кэшам, якая выкарыстоўваецца для розных аперацый (напрыклад, OTA-абнаўленняў).</string>
    <string name="systemcleaner_filter_localtmp_label">Лакальныя часовыя файлы</string>
    <string name="systemcleaner_filter_localtmp_summary">Часовыя файлы, звязаныя з сістэмай (напрыклад, з Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Файлы сістэмнага журнала</string>
    <string name="systemcleaner_filter_datalogger_summary">Файлы журналаў сістэмных службаў.</string>
    <string name="systemcleaner_filter_logdropbox_label">Размяшчэнне журналаў</string>
    <string name="systemcleaner_filter_logdropbox_summary">Вобласць, куды сістэма змяшчае файлы журналаў.</string>
    <string name="systemcleaner_filter_recenttasks_label">Нядаўнія задачы</string>
    <string name="systemcleaner_filter_recenttasks_summary">Даныя, звязаныя з гісторыяй задач у сістэмным пераключальніку задач.</string>
    <string name="systemcleaner_filter_tombstones_label">Рэшткі пасля сістэмных збояў</string>
    <string name="systemcleaner_filter_tombstones_summary">Калі ўнутраныя працэсы выходзяць з ладу (напрыклад, гульні), тут ствараюцца файлы.</string>
    <string name="systemcleaner_filter_usagestats_label">Статыстыка выкарыстання</string>
    <string name="systemcleaner_filter_usagestats_summary">Файлы, звязаныя са статыстыкай выкарыстання праграм.</string>
    <string name="systemcleaner_delete_all_confirmation_message">Выдаліць усё змесціва фільтра?</string>
    <string name="systemcleaner_customfilter_label">Карыстальніцкі фільтр</string>
    <string name="systemcleaner_customfilter_create_hint">Стварыце карыстальніцкі фільтр для выдалення дадатковых файлаў і спосабаў выкарыстання, характэрных для вашай прылады.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">Выдаліць гэты фільтр?</string>
    <string name="systemcleaner_customfilter_editor_label_label">Метка фільтра</string>
    <string name="systemcleaner_customfilter_editor_warning">Выкарыстанне карыстальніцкіх фільтраў можа быць рызыкоўным. Праверце вынікі сканіравання перад выдаленнем!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">Вобласці даных</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Калі ніводная вобласць не выбрана, сканіраванне і супастаўленне закране ўсе даступныя вобласці даных.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">Абмежаванні паводле тыпаў файлаў</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">Файлы</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">Папкі</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">Калі тып не выбраны, супадаць будуць усе тыпы.</string>
    <string name="systemcleaner_customfilter_editor_path_label">Крытэрый шляху</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Мэтавы шлях павінен адпавядаць прынамсі аднаму запісу (напр., \"Downloads/oldapks/game-\"). Доўгае націсканне на запісы адкрые дадатковыя опцыі.</string>
    <string name="systemcleaner_customfilter_editor_name_label">Крытэрый назвы</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">Мэтавая назва павінна змяшчаць хаця б адно з ключавых слоў (напр., \"-receipt\"). Доўгае націсканне на запісы адкрые дадатковыя опцыі.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Выключэнні</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Рэзультат будзе выключаны, калі шлях змяшчае любы з запісаў (напр., \"DCIM\"). Доўгае націсканне на запісы адкрые дадатковыя опцыі.</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_label">Рэжым параўнання шляхоў</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_start_label">Шлях пачынаецца з ключавога слова</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_contains_label">Шлях змяшчае ключавое слова</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_end_label">Шлях заканчваецца на ключавое слова</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">Шлях адпавядае ключавому слову</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">Рэжым параўнання назваў</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">Назва пачынаецца з ключавога слова</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">Назва змяшчае ключавое слова</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">Назва заканчваецца на ключавое слова</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">Назва адпавядае ключавому слову</string>
    <string name="systemcleaner_customfilter_last_edit">Апошняе змяненне: %s</string>
    <string name="systemcleaner_customfilter_editor_livesearch_label">Жывы пошук</string>
    <string name="systemcleaner_customfilter_editor_size_label">Абмежаванні паводле памеру</string>
    <string name="systemcleaner_customfilter_editor_size_minimum_label">Мінімальны памер</string>
    <string name="systemcleaner_customfilter_editor_size_maximum_label">Максімальны памер</string>
    <string name="systemcleaner_customfilter_editor_size_explanation">Абмежаванне супадзенняў у залежнасці ад памеру файла. Не запаўняйце гэта значэнне, калі памер улічваць не трэба.</string>
    <string name="systemcleaner_customfilter_editor_age_label">Абмежаванні паводле тэрмінаў</string>
    <string name="systemcleaner_customfilter_editor_age_minimum_label">Мінімальны час стварэння</string>
    <string name="systemcleaner_customfilter_editor_age_maximum_label">Максімальны час стварэння</string>
    <string name="systemcleaner_customfilter_editor_age_explanation">Абмежаванне супадзенняў паводле часу стварэння файла (часу апошняга змянення). Не запаўняйце гэта значэнне, калі тэрмін улічваць не трэба.</string>
    <string name="systemcleaner_customfilter_import_action">Імпартаваць новы фільтр</string>
    <string name="systemcleaner_customfilter_export_action">Экспартаваць выбраны фільтр</string>
</resources>
