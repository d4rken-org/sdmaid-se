<resources>
    <string name="systemcleaner_explanation_short">Лішнія даныя, якія не адносяцца да пэўнай праграмы.</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="one">Выдалена %d супадзенне</item>
        <item quantity="few">Выдалена %d супадзення</item>
        <item quantity="many">Выдалена %d супадзенняў</item>
        <item quantity="other">Выдалена %d супадзенняў</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="one">Супаў %d фільтр</item>
        <item quantity="few">Супала %d фільтры</item>
