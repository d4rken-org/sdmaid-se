    <string name="systemcleaner_filter_logfiles_label">Amafayela okurekhoda esistimu</string>
    <string name="systemcleaner_filter_logfiles_summary">Amafayela okurekhoda esistimu nezinsiza zesistimu (isib. *.log) ezindaweni ezahlukene.</string>
    <string name="systemcleaner_filter_packagecaches_label">I-cache yesifaki</string>
    <string name="systemcleaner_filter_packagecaches_summary">Idatha egciniwe ehlobene nezinhlelo zokusebenza ezifakiwe esetshenziswa ukuphatha amaphakethe esistimu.</string>
    <string name="systemcleaner_filter_advertisements_label">Amafayela ezikhangiso</string>
    <string name="systemcleaner_filter_advertisements_summary">Amafayela adalwe izikhangiso noma ngenxa yezikhangiso.</string>
    <string name="systemcleaner_filter_anr_label">Amaphutha e-ANR</string>
    <string name="systemcleaner_filter_anr_summary">Imisila evela kuma-\'uhlelo alukho lukaphendula\' ezehlakalo.</string>
    <string name="systemcleaner_filter_emptydirectories_label">Amafolda angenalutho</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Amafolda angenalutho avela kuyo yonke idivayisi. Amafolda angaphakathinya angase adinge izinyathelo eziningi.</string>
    <string name="systemcleaner_filter_screenshots_label">Izithombe zesikrini</string>
    <string name="systemcleaner_filter_screenshots_summary">Izithombe zesikrini ezindala kuno-%s ezivela ezinhlelweni zokusebenza nezindaweni eziningi.</string>
    <string name="systemcleaner_filter_trashed_label">Amafayela alahlwe</string>
    <string name="systemcleaner_filter_trashed_summary">Amafayela amakatsha okugaywa kabusha avela ezinhlelweni zokusebenza nezindaweni ezahlukene amakwa ukususwa kodwa angakasuswa unomphela.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Iminyaka Yesithombe Sesikrini</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Iminyaka encane yezithombe zesikrini ukuze zicatshangelwe ukususwa.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Ama-APK angadingeki</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Amafayela okufaka angasadingeki ngokuya kwezinguqulo zohlelo ezifakiwe.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Faka inguqulo efanayo</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Futhi bhekelela amafayela e-APK afana neguqulo efakiwe. Khubaza ukususa kuphela izinguqulo ezindala.</string>
    <string name="systemcleaner_filter_lostdir_label">Amafolda e-LOST.DIR</string>
    <string name="systemcleaner_filter_lostdir_summary">Amafayela esikhashana adalwa lapho kudluliselwa idatha phakathi kwamadivayisi e-Android.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Amafayela e-Linux</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Amafayela namafolda adalwa lapho isitoreji sixhunywe kukhomputha we-linux.</string>
    <string name="systemcleaner_filter_macfiles_label">Amafayela e-Mac</string>
    <string name="systemcleaner_filter_macfiles_summary">Amafayela namafolda adalwa lapho uzingcungcuthekisa isitoreji nge-finder app ye-Apple.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Amafayela e-Windows</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Idatha i-Windows file explorer ekwazi ukuyidala esitorejini esixhunyiwe."</string>
    <string name="systemcleaner_filter_thumbnails_label">Izithombe ezincane</string>
    <string name="systemcleaner_filter_thumbnails_summary">Ukubuka kuqala okugciniwe kwezithombe namavidiyo.</string>
    <string name="systemcleaner_filter_tempfiles_label">Amafayela esikhashana esistimu</string>
    <string name="systemcleaner_filter_tempfiles_summary">Amafayela esikhashana ahlobene nesistimu, ngokuvamile ama-cache ahlala isikhathi esincane emisebenzini esebenzayo.</string>
    <string name="systemcleaner_filter_analytics_label">Amafayela okuhlunga</string>
    <string name="systemcleaner_filter_analytics_summary">Idatha ehlobene nokuhlunga nokulandela amaphutha.</string>
    <string name="systemcleaner_filter_downloadcache_label">I-cache yokulanda</string>
    <string name="systemcleaner_filter_downloadcache_summary">Ifolda ye-cache yesistimu esetshenziswa kuzinto ezahlukahlukene (isib. izibuyekezo ze-OTA).</string>
    <string name="systemcleaner_filter_localtmp_label">Amafayela esikhashana endawo</string>
    <string name="systemcleaner_filter_localtmp_summary">Amafayela esikhashana ahlobene nesistimu (isib. avela ku-Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Amafayela okurekhoda esistimu</string>
    <string name="systemcleaner_filter_datalogger_summary">Amafayela okurekhoda athile ensiza yesistimu.</string>
    <string name="systemcleaner_filter_logdropbox_label">Ibhokisi lokubeka amarekhodi</string>
    <string name="systemcleaner_filter_logdropbox_summary">Indawo yesistimu yokubeka amafayela okurekhoda.</string>
    <string name="systemcleaner_filter_recenttasks_label">Imisebenzi yamuva</string>
    <string name="systemcleaner_filter_recenttasks_summary">Idatha ehlobene nomlando wemisebenzi kumshintshi wemisebenzi yesistimu.</string>
    <string name="systemcleaner_filter_tombstones_label">Insalela yokuphahla kwesistimu</string>
    <string name="systemcleaner_filter_tombstones_summary">Uma izinqubo zesiinzalo ziphahla (isib. imidlalo), khona-ke amafayela adalwa lapha.</string>
    <string name="systemcleaner_filter_usagestats_label">Izibalo zokusetshenziswa</string>
    <string name="systemcleaner_filter_usagestats_summary">Amafayela ahlobene nezibalo zokusetshenziswa kohlelo.</string>
