    <string name="systemcleaner_customfilter_editor_name_explanation">Igama eliqondiwe kufanele liqukethe okungenani elinye lamagatsha angukhiye (isib. \"-receipt\"). Cindezelela isikhathi eside okufakiwe ukuze uthole izinketho eziningi.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Okukhishiwe</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Umphumela uzokhonjiswa uma indlela ifana nanoma yisiphi isingu (isib. \"DCIM\"). Cindezelela isikhathi eside okufakiwe ukuze uthole izinketho eziningi.</string>
