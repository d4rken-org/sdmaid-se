    <string name="systemcleaner_customfilter_editor_path_label">Imigangatho yendlela</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Indlela eqondiwe kufanele ifane nokuncono isingu (isib. \"Downloads/oldapks/game-\"). Cindezelela isikhathi eside okufakiwe ukuze uthole izinketho eziningi.</string>
