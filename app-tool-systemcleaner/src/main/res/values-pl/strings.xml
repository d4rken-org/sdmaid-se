    <string name="systemcleaner_customfilter_editor_name_explanation">Nazwa docelowa musi zawierać co najmniej jedno ze słów kluczowych (np. \"-paragon\"). Dotknij dłużej wpisu, aby uzyskać więcej opcji.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Wykluczenia</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Wynik zostanie wykluczony, jeśli ścieżka pasuje do dowolnego wpisu (np. \"DCIM\"). Dotknij dłużej wpisu, aby uzyskać więcej opcji.</string>
