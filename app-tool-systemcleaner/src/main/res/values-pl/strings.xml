    <string name="systemcleaner_filter_emptydirectories_label">Puste foldery</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Puste foldery z całego urządzenia. Zagnieżdżone foldery mogą wymagać wielu przebiegów.</string>
    <string name="systemcleaner_filter_screenshots_label">Zrzuty ekranu</string>
    <string name="systemcleaner_filter_screenshots_summary">Zrzuty ekranu starsze niż %s z wielu aplikacji i lokalizacji.</string>
    <string name="systemcleaner_filter_trashed_label">Pliki w koszu</string>
    <string name="systemcleaner_filter_trashed_summary">Pliki w koszu z różnych aplikacji i lokalizacji, które są oznaczone do usunięcia, ale nie zostały jeszcze trwale usunięte.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Data zrzutu ekranu</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Minimalny wiek, od którego zacznie się usuwanie.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Zbędne pliki APK</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Konfiguruj pliki, które nie są już potrzebne na podstawie zainstalowanych wersji aplikacji.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Dołącz tę samą wersję</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Zamieść również pliki APK, które pasują do zainstalowanej wersji. Wyłącz, aby usunąć tylko starsze wersje.</string>
    <string name="systemcleaner_filter_lostdir_label">Foldery LOST.DIR</string>
    <string name="systemcleaner_filter_lostdir_summary">Tymczasowe pliki, które są tworzone podczas przesyłania danych między urządzeniami z Androidem.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Pliki systemu Linux</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Pliki i foldery, które są tworzone po podłączeniu pamięci masowej do komputera z systemem Linux.</string>
    <string name="systemcleaner_filter_macfiles_label">Pliki systemu MacOS</string>
    <string name="systemcleaner_filter_macfiles_summary">Pliki i foldery, które są tworzone podczas przeglądania pamięci masowej za pomocą aplikacji Finder firmy Apple.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Pliki systemu Windows</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Dane, które eksplorator plików systemu Windows może tworzyć na podłączonym nośniku."</string>
    <string name="systemcleaner_filter_thumbnails_label">Miniatury obrazów</string>
    <string name="systemcleaner_filter_thumbnails_summary">Zapisane w pamięci podręcznej podglądy obrazów i filmów.</string>
    <string name="systemcleaner_filter_tempfiles_label">Tymczasowe pliki systemowe</string>
    <string name="systemcleaner_filter_tempfiles_summary">Pliki tymczasowe związane z systemem, zwykle krótkotrwałe pamięci podręczne dla aktywnych operacji.</string>
    <string name="systemcleaner_filter_analytics_label">Pliki analityki</string>
    <string name="systemcleaner_filter_analytics_summary">Dane związane z analizą i śledzeniem błędów.</string>
    <string name="systemcleaner_filter_downloadcache_label">Pamięć podręczna pobierania</string>
    <string name="systemcleaner_filter_downloadcache_summary">Folder pamięci podręcznej systemu używany do różnych rzeczy (np. aktualizacji OTA).</string>
    <string name="systemcleaner_filter_localtmp_label">Lokalne pliki tymczasowe</string>
    <string name="systemcleaner_filter_localtmp_summary">Tymczasowe pliki systemowe (np. z Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Pliki dziennika systemowego</string>
    <string name="systemcleaner_filter_datalogger_summary">Pliki dziennika specyficzne dla usług systemowych.</string>
    <string name="systemcleaner_filter_logdropbox_label">Skrzynka na dzienniki</string>
    <string name="systemcleaner_filter_logdropbox_summary">Obszar, w którym system może umieszczać pliki dziennika.</string>
    <string name="systemcleaner_filter_recenttasks_label">Ostatnie zadania</string>
    <string name="systemcleaner_filter_recenttasks_summary">Dane związane z historią zadań w przełączniku zadań systemowych.</string>
    <string name="systemcleaner_filter_tombstones_label">Pozostałość po awarii systemu</string>
    <string name="systemcleaner_filter_tombstones_summary">Jeśli natywne procesy ulegają awarii (np. gry), tutaj są tworzone pliki.</string>
    <string name="systemcleaner_filter_usagestats_label">Statystyki użytkowania</string>
    <string name="systemcleaner_filter_usagestats_summary">Pliki związane ze statystykami użytkowania aplikacji.</string>
