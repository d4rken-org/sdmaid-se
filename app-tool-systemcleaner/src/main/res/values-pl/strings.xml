    <string name="systemcleaner_customfilter_editor_filetypes_hint">Jeśli żaden typ nie jest zaznaczony, wszystkie typy będą dopasowane.</string>
    <string name="systemcleaner_customfilter_editor_path_label">Kryteria ścieżki</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Ścieżka docelowa musi pasować co najmniej do jednego wpisu (np. „Pobrane/stare pliki/gry-”). Naciśnij i przytrzymaj wpisy, aby uzyskać więcej opcji.</string>
