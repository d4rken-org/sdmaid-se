    <string name="systemcleaner_filter_logfiles_summary">Pliki dziennika systemowego i usług systemowych (np. *.log) w różnych lokalizacjach.</string>
    <string name="systemcleaner_filter_packagecaches_label">Pamięć podręczna instalatora</string>
    <string name="systemcleaner_filter_packagecaches_summary">Buforowane dane związane z zainstalowanymi aplikacjami, które są używane przez zarządzanie pakietami systemu.</string>
    <string name="systemcleaner_filter_advertisements_label">Pliki reklam</string>
    <string name="systemcleaner_filter_advertisements_summary">Pliki, które zostały utworzone dla lub przez reklamy.</string>
    <string name="systemcleaner_filter_anr_label">Błędy ANR</string>
