<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="systemcleaner_explanation_short">Περιττά δεδομένα που δεν ανήκουν σε καμία συγκεκριμένη εφαρμογή.</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="one">%d αντιστοίχιση διαγράφηκε</item>
        <item quantity="other">%d αντιστοιχίες διαγράφηκαν</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="one">%d αντιστοίχιση φίλτρου</item>
        <item quantity="other">%d αντιστοιχίσεις φίλτρων</item>
    </plurals>
    <string name="systemcleaner_filter_custom_label">Προσαρμοσμένο φίλτρο</string>
    <string name="systemcleaner_filter_custom_manage_label">Διαχείριση προσαρμοσμένων φίλτρων</string>
    <string name="systemcleaner_filter_custom_manage_summary">Δημιουργία, διαγραφή, εισαγωγή και εξαγωγή των προσαρμοσμένων φίλτρων σας.</string>
    <string name="systemcleaner_filter_logfiles_label">Αρχεία καταγραφής συστήματος</string>
    <string name="systemcleaner_filter_logfiles_summary">Αρχεία καταγραφής υπηρεσιών συστήματος και συστήματος (π.χ. *.log) σε διάφορες τοποθεσίες.</string>
    <string name="systemcleaner_filter_packagecaches_label">Προσωρινή μνήμη προγράμματος εγκατάστασης</string>
    <string name="systemcleaner_filter_packagecaches_summary">Προσωρινά αποθηκευμένα δεδομένα σχετικά με εγκατεστημένες εφαρμογές που χρησιμοποιούνται από τη διαχείριση πακέτων του συστήματος.</string>
    <string name="systemcleaner_filter_advertisements_label">Αρχεία διαφήμισης</string>
    <string name="systemcleaner_filter_advertisements_summary">Αρχεία που έχουν δημιουργηθεί για ή από διαφημίσεις.</string>
    <string name="systemcleaner_filter_anr_label">ANR σφάλματα</string>
    <string name="systemcleaner_filter_anr_summary">Ίχνη από συμβάντα \"η εφαρμογή δεν ανταποκρίνεται\".</string>
    <string name="systemcleaner_filter_emptydirectories_label">Άδειοι φάκελοι</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Κενοί φάκελοι από όλη τη συσκευή. Οι ένθετοι φάκελοι ενδέχεται να απαιτούν πολλαπλά περάσματα.</string>
    <string name="systemcleaner_filter_screenshots_label">Στιγμιότυπα οθόνης</string>
    <string name="systemcleaner_filter_screenshots_summary">Στιγμιότυπα παλαιότερα από %s από πολλαπλές εφαρμογές και τοποθεσίες.</string>
    <string name="systemcleaner_filter_trashed_label">Αρχεία στον κάδο απορριμμάτων</string>
    <string name="systemcleaner_filter_trashed_summary">Αρχεία σε κάδους ανακύκλωσης από διάφορες εφαρμογές και τοποθεσίες που έχουν επισημανθεί για διαγραφή αλλά δεν έχουν ακόμη αφαιρεθεί οριστικά.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Ηλικία Στιγμιότυπου</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Ελάχιστη ηλικία για στιγμιότυπα οθόνης που πρέπει να λαμβάνονται υπόψη για διαγραφή.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Περιττά APK</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Αρχεία εγκατάστασης που δεν χρειάζονται πλέον με βάση τις εγκατεστημένες εκδόσεις εφαρμογών.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Συμπερίληψη ίδιας έκδοσης</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Στόχευση και αρχείων APK που αντιστοιχούν στην εγκατεστημένη έκδοση. Απενεργοποιήστε για αφαίρεση μόνο παλαιότερων εκδόσεων.</string>
    <string name="systemcleaner_filter_lostdir_label">Φάκελοι LOST.DIR</string>
    <string name="systemcleaner_filter_lostdir_summary">Προσωρινά αρχεία που δημιουργούνται κατά τη μεταφορά δεδομένων μεταξύ συσκευών Android.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Αρχεία Linux</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Αρχεία και φάκελοι που δημιουργούνται όταν ο χώρος έχει συνδεθεί σε υπολογιστή linux.</string>
    <string name="systemcleaner_filter_macfiles_label">Αρχεία Mac</string>
    <string name="systemcleaner_filter_macfiles_summary">Αρχεία και φάκελοι που δημιουργούνται κατά την περιήγηση στο χώρο αποθήκευσης με την εφαρμογή finder της Apple.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Αρχεία Windows</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Δεδομένα που μπορεί να δημιουργήσει η Εξερεύνηση αρχείων των Windows σε συνδεδεμένο χώρο αποθήκευσης."</string>
    <string name="systemcleaner_filter_thumbnails_label">Εικόνες μικρογραφίας</string>
    <string name="systemcleaner_filter_thumbnails_summary">Προσωρινά αποθηκευμένες προεπισκοπήσεις για εικόνες και βίντεο.</string>
    <string name="systemcleaner_filter_tempfiles_label">Προσωρινά αρχεία συστήματος</string>
    <string name="systemcleaner_filter_tempfiles_summary">Προσωρινά αρχεία που σχετίζονται με το σύστημα, συνήθως προσωρινές μνήμες μικρής διάρκειας για ενεργές λειτουργίες.</string>
    <string name="systemcleaner_filter_analytics_label">Αρχεία ανάλυσης</string>
    <string name="systemcleaner_filter_analytics_summary">Δεδομένα που σχετίζονται με την ανάλυση και την παρακολούθηση σφαλμάτων.</string>
    <string name="systemcleaner_filter_downloadcache_label">Προσωρινή μνήμη λήψεων</string>
    <string name="systemcleaner_filter_downloadcache_summary">Φάκελος προσωρινής μνήμης συστήματος που χρησιμοποιείται για διάφορα πράγματα (π.χ. ενημερώσεις OTA).</string>
    <string name="systemcleaner_filter_localtmp_label">Τοπικά προσωρινά αρχεία</string>
    <string name="systemcleaner_filter_localtmp_summary">Προσωρινά αρχεία που σχετίζονται με το σύστημα (π.χ. από το Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Αρχεία καταγραφής συστήματος</string>
    <string name="systemcleaner_filter_datalogger_summary">Αρχεία καταγραφής ειδικά για την υπηρεσία συστήματος.</string>
    <string name="systemcleaner_filter_logdropbox_label">Περιοχή αρχείων καταγραφής</string>
    <string name="systemcleaner_filter_logdropbox_summary">Μια περιοχή για να εναποθέσει αρχεία καταγραφής το σύστημα.</string>
    <string name="systemcleaner_filter_recenttasks_label">Πρόσφατες εργασίες</string>
    <string name="systemcleaner_filter_recenttasks_summary">Δεδομένα που σχετίζονται με το ιστορικό εργασιών στον επιλογέα εργασιών του συστήματος.</string>
    <string name="systemcleaner_filter_tombstones_label">Υπολείμματα κατάρρευσης συστήματος</string>
    <string name="systemcleaner_filter_tombstones_summary">Εάν καταρρεύσουν εγγενείς διεργασίες (π.χ. παιχνίδια), τότε δημιουργούνται αρχεία εδώ.</string>
    <string name="systemcleaner_filter_usagestats_label">Στατιστικά χρήσης</string>
    <string name="systemcleaner_filter_usagestats_summary">Αρχεία που σχετίζονται με στατιστικά χρήσης εφαρμογών.</string>
    <string name="systemcleaner_delete_all_confirmation_message">Διαγραφή όλον των περιεχόμενων του φίλτρου;</string>
    <string name="systemcleaner_customfilter_label">Προσαρμοσμένο φίλτρο</string>
    <string name="systemcleaner_customfilter_create_hint">Δημιουργήστε ένα προσαρμοσμένο φίλτρο για να διαγράψετε επιπλέον αρχεία που είναι μοναδικά για τη συσκευή σας και τις περιπτώσεις χρήσης.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">Αφαίρεση αυτού του φίλτρου;</string>
    <string name="systemcleaner_customfilter_editor_label_label">Ετικέτα φίλτρου</string>
    <string name="systemcleaner_customfilter_editor_warning">Τα προσαρμοσμένα φίλτρα μπορεί να είναι επικίνδυνα. Ελέγξτε τα αποτελέσματα σάρωσης πριν διαγράψετε!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">Περιοχές δεδομένων</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Εάν δεν έχει επιλεγεί περιοχή, τότε όλες οι προσβάσιμες περιοχές δεδομένων θα σαρωθούν και θα αντιστοιχιστούν.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">Περιορισμοί τύπων αρχείων</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">Αρχεία</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">Φάκελοι</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">Εάν δεν έχει επιλεγεί τύπος, τότε όλοι οι τύποι θα ταιριάζουν.</string>
    <string name="systemcleaner_customfilter_editor_path_label">Κριτήρια διαδρομής</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Η διαδρομή προορισμού πρέπει να ταιριάζει με τουλάχιστον μία καταχώρηση (π.χ. \"Downloads/oldapks/game-\"). Πατήστε παρατεταμένα τις καταχωρήσεις για περισσότερες επιλογές.</string>
    <string name="systemcleaner_customfilter_editor_name_label">Κριτήρια ονόματος</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">Το όνομα προορισμού πρέπει να περιέχει τουλάχιστον μία από τις λέξεις-κλειδιά (π.χ. \"- απόδειξη\"). Πατήστε παρατεταμένα τις καταχωρήσεις για περισσότερες επιλογές.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Εξαιρέσεις</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Το αποτέλεσμα θα αποκλειστεί εάν η διαδρομή ταιριάζει με οποιαδήποτε καταχώρηση (π.χ. \"DCIM\"). Πατήστε παρατεταμένα τις καταχωρήσεις για περισσότερες επιλογές.</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_label">Τρόπος σύγκρισης διαδρομών</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_start_label">Η διαδρομή ξεκινά με λέξη-κλειδί</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_contains_label">Η διαδρομή περιέχει λέξη-κλειδί</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_end_label">Η διαδρομή τελειώνει με λέξη-κλειδί</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">Η διαδρομή είναι ίση με τη λέξη-κλειδί</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">Τρόπος σύγκρισης ονόματος</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">Το όνομα ξεκινά με λέξη-κλειδί</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">Το όνομα περιέχει λέξη-κλειδί</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">Το όνομα τελειώνει με λέξη-κλειδί</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">Το όνομα είναι ίσο με τη λέξη-κλειδί</string>
    <string name="systemcleaner_customfilter_last_edit">Τελευταία επεξεργασία: %s</string>
    <string name="systemcleaner_customfilter_editor_livesearch_label">Ζωντανή αναζήτηση</string>
    <string name="systemcleaner_customfilter_editor_size_label">Περιορισμοί μεγέθους</string>
    <string name="systemcleaner_customfilter_editor_size_minimum_label">Ελάχιστο μέγεθος</string>
    <string name="systemcleaner_customfilter_editor_size_maximum_label">Μέγιστο μέγεθος</string>
    <string name="systemcleaner_customfilter_editor_size_explanation">Περιορισμός αντιστοιχιών βάσει μεγέθους αρχείου. Αφήστε κενό για αντιστοίχιση οποιουδήποτε μεγέθους.</string>
    <string name="systemcleaner_customfilter_editor_age_label">Περιορισμοί ηλικίας</string>
    <string name="systemcleaner_customfilter_editor_age_minimum_label">Ελάχιστη ηλικία</string>
    <string name="systemcleaner_customfilter_editor_age_maximum_label">Μέγιστη ηλικία</string>
    <string name="systemcleaner_customfilter_editor_age_explanation">Περιορισμός αντιστοιχιών βάσει ηλικίας αρχείου (χρόνος τελευταίας τροποποίησης). Αφήστε κενό για αντιστοίχιση οποιασδήποτε ηλικίας.</string>
    <string name="systemcleaner_customfilter_import_action">Εισαγωγή νέου φίλτρου</string>
    <string name="systemcleaner_customfilter_export_action">Εξαγωγή επιλεγμένου φίλτρου</string>
</resources>
