    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">Мод поређења имена</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">Име почиње кључном речју</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">Име садржи кључну реч</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">Име завршава кључном речју</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">Име је једнако кључној речи</string>
