    <string name="systemcleaner_filter_custom_label">Прилагођени филтер</string>
    <string name="systemcleaner_filter_custom_manage_label">Управљање прилагођеним филтерима</string>
    <string name="systemcleaner_filter_custom_manage_summary">Креирајте, бришите, увозите и извозите ваше прилагођене филтере.</string>
    <string name="systemcleaner_filter_logfiles_label">Системске датотеке дневника</string>
    <string name="systemcleaner_filter_logfiles_summary">Системске и датотеке дневника системских сервиса (нпр. *.log) на различитим локацијама.</string>
    <string name="systemcleaner_filter_packagecaches_label">Кеш инсталатера</string>
    <string name="systemcleaner_filter_packagecaches_summary">Кеширани подаци везани за инсталиране апликације које користи системско управљање пакетима.</string>
    <string name="systemcleaner_filter_advertisements_label">Датотеке реклама</string>
    <string name="systemcleaner_filter_advertisements_summary">Фајлови који су креирани за или од стране реклама.</string>
    <string name="systemcleaner_filter_anr_label">ANR грешке</string>
    <string name="systemcleaner_filter_anr_summary">Трагови од \'апликација се не одазива\' догађаја.</string>
    <string name="systemcleaner_filter_emptydirectories_label">Празне фасцикле</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Празне фасцикле из целог уређаја. Угнежђене фасцикле могу захтевати више прохода.</string>
    <string name="systemcleaner_filter_screenshots_label">Снимци екрана</string>
    <string name="systemcleaner_filter_screenshots_summary">Снимци екрана старији од %s из више апликација и локација.</string>
    <string name="systemcleaner_filter_trashed_label">Обрисане датотеке</string>
    <string name="systemcleaner_filter_trashed_summary">Датотеке у корпама за отпад из различитих апликација и локација које су означене за брисање, али још нису трајно уклоњене.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Старост снимкова екрана</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Минимална старост снимкова екрана који се разматрају за брисање.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Лишни APK фајлови</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Инсталационе датотеке које више нису потребне на основу инсталираних верзија апликација.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Укључи исту верзију</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Такође циљај APK датотеке које одговарају инсталираној верзији. Онемогућите да бисте уклонили само старије верзије.</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR фасцикле</string>
    <string name="systemcleaner_filter_lostdir_summary">Привремене датотеке које се креирају приликом преноса података између Андроид уређаја.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Linux датотеке</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Датотеке и фасцикле које се креирају када је складиште повезано на Linux рачунар.</string>
    <string name="systemcleaner_filter_macfiles_label">Mac датотеке</string>
    <string name="systemcleaner_filter_macfiles_summary">Датотеке и фасцикле које се креирају при прегледању складишта помоћу Apple Finder апликације.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Windows датотеке</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Подаци које Windows истраживач датотека може креирати на повезаном складишту."</string>
    <string name="systemcleaner_filter_thumbnails_label">Сличице</string>
    <string name="systemcleaner_filter_thumbnails_summary">Кеширани прегледи слика и видео записа.</string>
    <string name="systemcleaner_filter_tempfiles_label">Привремене системске датотеке</string>
    <string name="systemcleaner_filter_tempfiles_summary">Привремене датотеке везане за систем, обично кратковеки кешови за активне операције.</string>
    <string name="systemcleaner_filter_analytics_label">Аналитичке датотеке</string>
    <string name="systemcleaner_filter_analytics_summary">Подаци везани за аналитику и праћење грешака.</string>
    <string name="systemcleaner_filter_downloadcache_label">Кеш преузимања</string>
    <string name="systemcleaner_filter_downloadcache_summary">Системска фасцикла кеша која се користи за различите сврхе (нпр. OTA ажурирања).</string>
    <string name="systemcleaner_filter_localtmp_label">Локални привремени фајлови</string>
    <string name="systemcleaner_filter_localtmp_summary">Привремене датотеке везане за систем (нпр. из Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Системске датотеке дневника</string>
    <string name="systemcleaner_filter_datalogger_summary">Датотеке дневника специфичне за системске сервисе.</string>
    <string name="systemcleaner_filter_logdropbox_label">Кутија за дневнике</string>
    <string name="systemcleaner_filter_logdropbox_summary">Област за систем да оставља датотеке дневника.</string>
    <string name="systemcleaner_filter_recenttasks_label">Недавни задаци</string>
    <string name="systemcleaner_filter_recenttasks_summary">Подаци везани за историју задатака у системском пребацивачу задатака.</string>
    <string name="systemcleaner_filter_tombstones_label">Остаци системског квара</string>
    <string name="systemcleaner_filter_tombstones_summary">Ако се нативни процеси сруше (нпр. игре), онда се овде креирају датотеке.</string>
    <string name="systemcleaner_filter_usagestats_label">Статистике коришћења</string>
    <string name="systemcleaner_filter_usagestats_summary">Датотеке везане за статистике коришћења апликација.</string>
    <string name="systemcleaner_delete_all_confirmation_message">Обрисати сав садржај филтера?</string>
    <string name="systemcleaner_customfilter_label">Прилагођени филтер</string>
    <string name="systemcleaner_customfilter_create_hint">Креирајте прилагођени филтер за брисање додатних датотека специфичних за ваш уређај и случајеве коришћења.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">Уклонити овај филтер?</string>
    <string name="systemcleaner_customfilter_editor_label_label">Ознака филтера</string>
    <string name="systemcleaner_customfilter_editor_warning">Прилагођени филтери могу бити ризични. Проверите резултате скенирања пре брисања!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">Области података</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Ако није изабрана област, онда ће све приступачне области података бити скениране и поклопљене.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">Ограничења типова датотека</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">Датотеке</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">Фасцикле</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">Ако није изабран тип, онда ће сви типови бити поклопљени.</string>
    <string name="systemcleaner_customfilter_editor_path_label">Критеријуми путање</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Циљна путања треба да одговара бар једном уносу (нпр. \"Downloads/oldapks/game-\"). Дуго притисните уносе за више опција.</string>
    <string name="systemcleaner_customfilter_editor_name_label">Критеријуми имена</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">Циљно име мора садржавати бар једну од кључних речи (нпр. \"-receipt\"). Дуго притисните уносе за више опција.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Искључења</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Резултат ће бити искључен ако путања одговара било којем уносу (нпр. \"DCIM\"). Дуго притисните уносе за више опција.</string>
