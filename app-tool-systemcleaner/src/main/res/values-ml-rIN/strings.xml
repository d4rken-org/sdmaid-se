<resources>
    <string name="systemcleaner_explanation_short">ക്രമീകൃതമാകാത്ത, യാതൊരു ആപ്പിനും സ്വന്തമല്ലാത്ത ഡേറ്റ.</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="one">%d പൊരുത്തം ഇല്ലാതാക്കി</item>
        <item quantity="other">%d പൊരുത്തങ്ങൾ ഇല്ലാതാക്കി</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="one">%d ഫിൽടർ പൊരുത്തം</item>
        <item quantity="other">%d ഫിൽടർ പൊരുത്തങ്ങൾ</item>
    </plurals>
    <string name="systemcleaner_filter_custom_label">കസ്റ്റം ഫിൽടർ</string>
    <string name="systemcleaner_filter_custom_manage_label">കസ്റ്റം ഫിൽടർുകൾ മാനേജ് ചെയ്യുക</string>
    <string name="systemcleaner_filter_custom_manage_summary">നിങ്ങളുടെ കസ്റ്റം ഫിൽടർുകൾ സൃഷ്ടിക്കുക, ഇല്ലാതാക്കുക, ഇൻപോർട് ചെയ്യുകയും എക്സ്പോർട് ചെയ്യുകയും ചെയ്യുക.</string>
    <string name="systemcleaner_filter_logfiles_label">സിസ്റം ലോഗ് ഫയലുകൾ</string>
    <string name="systemcleaner_filter_logfiles_summary">വിവിധ സ്ഥലങ്ങളിലെ സിസ്റം പ്രൊസെസ് ലോഗ് ഫയലുകൾ (ഉദ്ദേ. *.log).</string>
    <string name="systemcleaner_filter_packagecaches_label">ഇൻസ്റ്റാലർ ക്യാഷ്</string>
    <string name="systemcleaner_filter_packagecaches_summary">സിസ്റ്റം പാക്കേജ് മാനേജ്മെന്റ് ഉപയോഗിക്കുന്ന ഇൻസ്റ്റാൾ ചെയ്ത ആപ്പുകൾക്ക് സംബന്ധപ്പെട്ട ക്യാഷ് ഡേറ്റ.</string>
    <string name="systemcleaner_filter_advertisements_label">ജ്ഞാപന ഫയലുകൾ</string>
    <string name="systemcleaner_filter_advertisements_summary">ജ്ഞാപനങ്ങൾ സൃഷ്ടിക്കുകയോ ഉപയോഗിക്കുകയോ ചെയ്ത ഫയലുകൾ.</string>
    <string name="systemcleaner_filter_anr_label">ANR പിശകുകൾ</string>
    <string name="systemcleaner_filter_anr_summary">\'application not responding\' സംഭവങ്ങളിൽനിന്ന് ട്രെസുകൾ.</string>
    <string name="systemcleaner_filter_emptydirectories_label">കാലിയായ ഫോൾഡർുകൾ</string>
    <string name="systemcleaner_filter_emptydirectories_summary">ഉപകരണത്തിൽ ഉടനീളം കാലിയായ ഫോൾഡർുകൾ. നെസ്റ്റ് ചെയ്ത ഫോൾഡർുകൾക്ക് ഒന്നിലധികം പാസ് ആവശ്യമായേക്കാം.</string>
    <string name="systemcleaner_filter_screenshots_label">സ്ക്രീൻഷോട്ടുകൾ</string>
    <string name="systemcleaner_filter_screenshots_summary">ഒന്നിലധികം ആപ്പുകളിൽ നിന്ന് %s-ല് കൂടുതൽ പഴക്കമുള്ള സ്ക്രീൻഷോട്ടുകൾ.</string>
    <string name="systemcleaner_filter_trashed_label">ത്രാഷ് ചെയ്ത ഫയലുകൾ</string>
    <string name="systemcleaner_filter_trashed_summary">വിവിധ ആപ്പുകളിൽ നിന്ന് റിസൈകിൾ ബിൻന്ന് ഇല്ലാതാകാൻ അടയാളപ്പെട്ടിട്ടില്ലാത്തഫയലുകൾ.</string>
    <string name="systemcleaner_filter_screenshots_age_label">സ്ക്രീൻഷോട്ട് പള്ളി</string>
    <string name="systemcleaner_filter_screenshots_age_summary">സ്ക്രീൻഷോട്ടുകൾ ഇല്ലാതാക്കുന്നതിന് പരിഗണിക്കുന്ന കുറഞ്ഞത് പ്രായം.</string>
    <string name="systemcleaner_filter_superfluosapks_label">അധികപ്പറി ആപ്പികൺ</string>
    <string name="systemcleaner_filter_superfluosapks_summary">ഇൻസ്റ്റാൾ ചെയ്ത ആപ്പ് പതിപ്പുകൾക്ക് അനുസരിച്ച് ഇനി ആവശ്യമില്ലാത്ത സെറ്റപ്പ് ഫയലുകൾ.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">അവന്റെ അതേ പതിപ്പ് ഉൾപെടുത്തുക</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">ഇൻസ്റ്റാൾ ചെയ്ത പതിപ്പുമായി പൊരുത്തപ്പെടുന്ന APK ഫയലുകൾകൂടി ലക്ഷ്യമാക്കുക. പഴയ പതിപ്പുകൾ മാത്രം നീക്കാൻ പ്രവർത്തനം നിർത്തുക.</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR ഫോൾഡർുകൾ</string>
    <string name="systemcleaner_filter_lostdir_summary">Android ഉപകരണങ്ങൾക്കിടയിൽ ഡേറ്റ കൈമാര്മാര് ചെയ്യുമ്പോൿ സൃഷ്ടിക്കുന്ന താൽക്കാല ഫയലുകൾ.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Linux ഫയലുകൾ</string>
    <string name="systemcleaner_filter_linuxfiles_summary">സ്റ്റോറേജ് ഒരു ലിനക്സ് കമ്പ്യൂടർവിൽ ആങ്ങളായി ബന്ധിപ്പിക്കുമ്പോൿ സൃഷ്ടിക്കുന്ന ഫയലുകൺം ഫോൾഡർുകൺം.</string>
    <string name="systemcleaner_filter_macfiles_label">Mac ഫയലുകൾ</string>
    <string name="systemcleaner_filter_macfiles_summary">Appleന്റെ Finder ആപ്പുകൊണ്ട് സ്റ്റോറേജ് ബ്രോസ് ചെയ്യുമ്പോൿ സൃഷ്ടിക്കുന്ന ഫയലുകൺം ഫോൾഡർുകൺം.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Windows ഫയലുകൾ</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Windows ഫയൽ എക്സ്പ്ലോറർ ബന്ധിപ്പിച്ച സ്റ്റോറേജിൽ സൃഷ്ടിക്കാൻ പറ്റുന്ന ഡേറ്റ."</string>
    <string name="systemcleaner_filter_thumbnails_label">തിഇംബൽ ചിത്രങ്ങൾ</string>
    <string name="systemcleaner_filter_thumbnails_summary">ചിത്രങ്ങൺം വീഡിയോസുമായി ക്യാഷ് ചെയ്ത പ്രിവ്യുകൾ.</string>
    <string name="systemcleaner_filter_tempfiles_label">താൽക്കാല സിസ്റം ഫയലുകൾ</string>
    <string name="systemcleaner_filter_tempfiles_summary">സിസ്റം സംബന്ധമായ താൽക്കാല ഫയലുകൾ, സാധാരണമായി സക്രിയ പ്രവർത്തനങ്ങൾക്ക് ക്യാഷ്.</string>
    <string name="systemcleaner_filter_analytics_label">അനലിറ്റിക്സ് ഫയലുകൾ</string>
    <string name="systemcleaner_filter_analytics_summary">അനലിറ്റിക്സുമായി ബഗ് ട്രാക്കിങ്ങുമായി ബന്ധപ്പെട്ട ഡേറ്റ.</string>
    <string name="systemcleaner_filter_downloadcache_label">ഡൗൺലോഡ് ക്യാഷ്</string>
    <string name="systemcleaner_filter_downloadcache_summary">വിവിധ ആവശ്യങ്ങൾക്ക് ഉപയോഗിക്കുന്ന സിസ്റം ക്യാഷ് ഫോൾഡർ (ഉദ്ദേ. OTA അപ്ഡേറ്റുകൾ).</string>
