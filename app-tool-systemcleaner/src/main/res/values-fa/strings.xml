<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="systemcleaner_explanation_short">داده‌های اضافی که به هیچ برنامه خاصی تعلق ندارند.</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="one">%d تطابق حذف شد.</item>
        <item quantity="other">%d تطابق حذف شد.</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="one">%d تطابق با فیلتر</item>
        <item quantity="other">%d تطابق با فیلتر</item>
    </plurals>
    <string name="systemcleaner_filter_custom_label">فیلتر سفارشی</string>
    <string name="systemcleaner_filter_custom_manage_label">مدیریت فیلترهای سفارشی</string>
    <string name="systemcleaner_filter_custom_manage_summary">ایجاد، حذف، وارد کردن و صادر کردن فیلترهای سفارشی خود.</string>
    <string name="systemcleaner_filter_logfiles_label">فایل‌های گزارش سیستم</string>
    <string name="systemcleaner_filter_logfiles_summary">فایل‌های گزارش سیستم و سرویس‌های سیستم (مثلاً *.log) در مکان‌های مختلف.</string>
    <string name="systemcleaner_filter_packagecaches_label">کش نصب‌کننده</string>
    <string name="systemcleaner_filter_packagecaches_summary">داده‌های ذخیره‌شده مربوط به برنامه‌های نصب‌شده که توسط مدیریت بسته سیستم استفاده می‌شوند.</string>
    <string name="systemcleaner_filter_advertisements_label">فایلهای تبلیغات</string>
    <string name="systemcleaner_filter_advertisements_summary">فایل هایی که برای تبلیغات یا توسط تبلیغات ایجاد شده اند.</string>
    <string name="systemcleaner_filter_anr_label">خطاهای ANR</string>
    <string name="systemcleaner_filter_anr_summary">آثار مربوط به وقایع \"برنامه پاسخ نمی دهد\".</string>
    <string name="systemcleaner_filter_emptydirectories_label">پوشه‌های خالی</string>
    <string name="systemcleaner_filter_emptydirectories_summary">پوشه‌های خالی از سرتاسر دستگاه. پوشه‌های تودرتو ممکن است به چندین مرتبه بررسی نیاز داشته باشند.</string>
    <string name="systemcleaner_filter_screenshots_label">عکس‌های صفحه</string>
    <string name="systemcleaner_filter_screenshots_summary">اسکرین‌شات‌هایی که قدیمی‌تر از %s هستند از برنامه‌ها و مکان‌های مختلف.</string>
    <string name="systemcleaner_filter_trashed_label">فایل های زباله</string>
    <string name="systemcleaner_filter_trashed_summary">فایل‌هایی در سطل‌ زباله از برنامه‌ها و مکان‌های مختلف که برای حذف علامت‌گذاری شده‌اند اما هنوز به‌صورت دائمی حذف نشده‌اند.</string>
    <string name="systemcleaner_filter_screenshots_age_label">سن عکس صفحه</string>
    <string name="systemcleaner_filter_screenshots_age_summary">حداقل سن برای اسکرین‌شات‌ها که برای حذف شدن در نظر گرفته می‌شود.</string>
    <string name="systemcleaner_filter_superfluosapks_label">فایل های نصبی اضافی</string>
    <string name="systemcleaner_filter_superfluosapks_summary">فایل‌های نصب که بر اساس نسخه‌های نصب‌شده برنامه دیگر نیازی به آن‌ها نیست.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">شامل نسخه مشابه</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">فایل‌های APK که با نسخه نصب شده مطابقت دارند نیز هدف قرار بگیرند. غیرفعال کنید تا فقط نسخه‌های قدیمی‌تر حذف شوند.</string>
    <string name="systemcleaner_filter_lostdir_label">پوشه‌های LOST.DIR</string>
    <string name="systemcleaner_filter_lostdir_summary">فایل‌های موقت که هنگام انتقال داده بین دستگاه‌های اندرویدی ایجاد می‌شوند.</string>
    <string name="systemcleaner_filter_linuxfiles_label">فایل‌های لینوکس</string>
    <string name="systemcleaner_filter_linuxfiles_summary">فایل‌ها و پوشه‌هایی که هنگام اتصال فضای ذخیره‌سازی به یک کامپیوتر لینوکس ایجاد می‌شوند.</string>
    <string name="systemcleaner_filter_macfiles_label">فایل‌های مک</string>
    <string name="systemcleaner_filter_macfiles_summary">فایل‌ها و پوشه‌هایی که هنگام مرور فضای ذخیره‌سازی با استفاده از برنامه Finder اپل ایجاد می‌شوند.</string>
    <string name="systemcleaner_filter_windowsfiles_label">فایل‌های ویندوز</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"این فایل‌ها و پوشه‌ها هنگام مرور فضای ذخیره‌سازی با استفاده از کامپیوترهای ویندوز ایجاد می‌شوند."</string>
    <string name="systemcleaner_filter_thumbnails_label">تصاویر بندانگشتی</string>
    <string name="systemcleaner_filter_thumbnails_summary">تصاویر پیش‌نمایش کش شده برای تصاویر و ویدئوها.</string>
    <string name="systemcleaner_filter_tempfiles_label">فایل‌های سیستمی موقت</string>
    <string name="systemcleaner_filter_tempfiles_summary">فایل‌های موقت مربوط به سیستم، معمولاً حافظه‌های پنهان کوتاه‌مدت برای عملیات فعال.</string>
    <string name="systemcleaner_filter_analytics_label">فایل‌های تحلیلی</string>
    <string name="systemcleaner_filter_analytics_summary">داده‌های مرتبط با تحلیل‌ها و ردیابی اشکالات</string>
    <string name="systemcleaner_filter_downloadcache_label">حافظه پنهان دانلود</string>
    <string name="systemcleaner_filter_downloadcache_summary">پوشه حافظه نهان سیستم که برای موارد مختلفی مانند به‌روزرسانی‌های OTA استفاده می‌شود.</string>
    <string name="systemcleaner_filter_localtmp_label">فایل‌های موقت محلی</string>
    <string name="systemcleaner_filter_localtmp_summary">فایل‌های موقت مربوط به سیستم (مثلاً از Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">فایل‌های گزارش سیستم</string>
    <string name="systemcleaner_filter_datalogger_summary">فایل‌های خاص گزارش سیستم</string>
    <string name="systemcleaner_filter_logdropbox_label">جعبه گزارش‌ها</string>
    <string name="systemcleaner_filter_logdropbox_summary">یک منطقه در سیستم برای انداختن فایل‌های گزارش در آن.</string>
    <string name="systemcleaner_filter_recenttasks_label">آخرین وظایف</string>
    <string name="systemcleaner_filter_recenttasks_summary">داده‌های مربوط به تاریخچه وظایف در سوئیچ‌کننده وظایف سیستم.</string>
    <string name="systemcleaner_filter_tombstones_label">باقی‌مانده‌های خرابی سیستم</string>
    <string name="systemcleaner_filter_tombstones_summary">اگر فرآیندهای بومی کرش کنند (به عنوان مثال، بازی‌ها) فایل‌هایی در اینجا ایجاد می‌شوند.</string>
    <string name="systemcleaner_filter_usagestats_label">آمار استفاده</string>
    <string name="systemcleaner_filter_usagestats_summary">فایل‌های مربوط به آمار استفاده از برنامه‌ها.</string>
    <string name="systemcleaner_delete_all_confirmation_message">همه محتوای فیلترها حذف شوند؟</string>
    <string name="systemcleaner_customfilter_label">فیلتر سفارشی</string>
    <string name="systemcleaner_customfilter_create_hint">ایجاد فیلتر سفارشی برای حذف فایل‌های اضافی که به دستگاه و موارد استفاده شما منحصر به فرد هستند.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">حذف این فیلتر؟</string>
    <string name="systemcleaner_customfilter_editor_label_label">برپسب فیلتر</string>
    <string name="systemcleaner_customfilter_editor_warning">فیلترهای سفارشی می‌توانند خطرناک باشند. نتایج اسکن خود را قبل از حذف بررسی کنید!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">حوزه های داده</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">اگر هیچ ناحیه‌ای انتخاب نشود، تمام نواحی داده‌های قابل دسترسی اسکن و تطبیق داده خواهند شد.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">محدودیت‌های نوع فایل</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">فایل‌ها</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">پوشه‌ها</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">اگر هیچ نوعی انتخاب نشود، همه نوع‌ها تطبیق داده می‌شوند.</string>
    <string name="systemcleaner_customfilter_editor_path_label">معیار مسیر</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">مسیر هدف باید حداقل با یک ورودی مطابقت داشته باشد (به عنوان مثال، \"Downloads/oldapks/game-\"). برای گزینه‌های بیشتر، ورودی‌ها را طولانی فشار دهید.</string>
    <string name="systemcleaner_customfilter_editor_name_label">معیار اسم</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">نام هدف باید حداقل یکی از کلمات کلیدی را شامل شود (به عنوان مثال، \"-receipt\"). برای گزینه‌های بیشتر، ورودی‌ها را طولانی فشار دهید.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">استثنائات</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">نتیجه مستثناء خواهد شد اگر مسیر با هر یک از ورودی‌ها مطابقت داشته باشد (مثلاً \"DCIM\"). برای گزینه‌های بیشتر، ورودی‌ها را طولانی فشار دهید.</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_label">حالت مقایسه مسیر</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_start_label">مسیر با کلید‌واژه شروع می‌شود</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_contains_label">مسیر شامل کلید‌واژه</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_end_label">مسیر با کلید‌واژه به پایان می‌رسد</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">مسیر برابر با کلید‌واژه</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">حالت مقایسه نام</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">نام با کلید‌واژه شروع می‌شود</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">نام شامل کلید‌واژه</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">نام با کلید‌واژه تمام می‌‍شود</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">نام برابر با کلید‌واژه</string>
    <string name="systemcleaner_customfilter_last_edit">آخرین ویرایش: %s</string>
    <string name="systemcleaner_customfilter_editor_livesearch_label">جستجو زنده</string>
    <string name="systemcleaner_customfilter_editor_size_label">محدودیت اندازه</string>
    <string name="systemcleaner_customfilter_editor_size_minimum_label">حداقل اندازه</string>
    <string name="systemcleaner_customfilter_editor_size_maximum_label">حداکثر اندازه</string>
    <string name="systemcleaner_customfilter_editor_size_explanation">محدود کردن نتایج بر اساس اندازه فایل. برای تطبیق هر اندازه‌ای خالی بگذارید.</string>
    <string name="systemcleaner_customfilter_editor_age_label">محدودیت سن</string>
    <string name="systemcleaner_customfilter_editor_age_minimum_label">حداقل سن</string>
    <string name="systemcleaner_customfilter_editor_age_maximum_label">حداکثر سن</string>
    <string name="systemcleaner_customfilter_editor_age_explanation">محدود کردن نتایج بر اساس سن فایل (آخرین زمان تغییر). برای تطبیق هر سنی خالی بگذارید.</string>
    <string name="systemcleaner_customfilter_import_action">واردات فیلتر جدید</string>
    <string name="systemcleaner_customfilter_export_action">صادرات فیلتر انتخاب شده</string>
