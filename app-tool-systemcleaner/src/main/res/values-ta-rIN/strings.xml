<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="systemcleaner_explanation_short">எந்த குறிப்பிட்ட பயன்பாட்டுக்கும் சொந்தமில்லாத தேவையற்ற தரவு.</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="one">%d பொருத்தம் நீக்கப்பட்டது</item>
        <item quantity="other">%d பொருத்தங்கள் நீக்கப்பட்டன</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="one">%d வடிப்பான் பொருத்தம்</item>
        <item quantity="other">%d வடிப்பான் பொருத்தங்கள்</item>
    </plurals>
    <string name="systemcleaner_filter_custom_label">தனிப்பயன் வடிப்பான்</string>
    <string name="systemcleaner_filter_custom_manage_label">தனிப்பயன் வடிப்பான்களை நிர்வகி</string>
    <string name="systemcleaner_filter_custom_manage_summary">உங்கள் தனிப்பயன் வடிப்பான்களை உருவாக்கவும், நீக்கவும், இறக்குமதி செய்யவும் ஏற்றுமதி செய்யவும்.</string>
    <string name="systemcleaner_filter_logfiles_label">கணினி பதிவு கோப்புகள்</string>
    <string name="systemcleaner_filter_logfiles_summary">பல்வேறு இடங்களிலுள்ள கணினி மற்றும் கணினி சேவை பதிவு கோப்புகள் (எ.கா. *.log).</string>
    <string name="systemcleaner_filter_packagecaches_label">நிறுவி கேச்</string>
    <string name="systemcleaner_filter_packagecaches_summary">கணினியின் தொகுப்பு நிர்வாகத்தால் பயன்படுத்தப்படும் நிறுவப்பட்ட பயன்பாடுகளுடன் தொடர்புடைய கேச் செய்யப்பட்ட தரவு.</string>
    <string name="systemcleaner_filter_advertisements_label">விளம்பர கோப்புகள்</string>
    <string name="systemcleaner_filter_advertisements_summary">விளம்பரங்களுக்காக அல்லது அவற்றால் உருவாக்கப்பட்ட கோப்புகள்.</string>
    <string name="systemcleaner_filter_anr_label">ANR பிழைகள்</string>
    <string name="systemcleaner_filter_anr_summary">\'பயன்பாடு இல்லை\' நிகழ்வுகளிலிருந்து வரும் துறுவல்கள்.</string>
    <string name="systemcleaner_filter_emptydirectories_label">வெறுமை அடைவுகள்</string>
    <string name="systemcleaner_filter_emptydirectories_summary">சாதனம் முழுவதுமுள்ள வெறுமை அடைவுகள். கூடு அடைவுகளுக்கு பல முறை தேவைப்படலாம்.</string>
    <string name="systemcleaner_filter_screenshots_label">திரைப்பிடிப்புகள்</string>
    <string name="systemcleaner_filter_screenshots_summary">%s ஐ விட பழைய திரைப்பிடிப்புகள் பல பயன்பாடுகள் மற்றும் இடங்களிலிருந்து.</string>
    <string name="systemcleaner_filter_trashed_label">குப்பையில் இடப்பட்ட கோப்புகள்</string>
    <string name="systemcleaner_filter_trashed_summary">பல்வேறு பயன்பாடுகள் மற்றும் இடங்களிலிருந்து மீட்டுறுஞ்சுத்தொட்டிகளிலுள்ள கோப்புகள் நீக்குவதற்காக குறிக்கப்பட்டுள்ளன ஆனால் இன்னும் நிரந்தரமாக அகற்றப்படவில்லை.</string>
    <string name="systemcleaner_filter_screenshots_age_label">திரைப்பிடிப்பு வயது</string>
    <string name="systemcleaner_filter_screenshots_age_summary">நீக்குவதற்கு கருதப்பட வேண்டிய திரைப்பிடிப்புகளுக்கான குறைந்தபட்ச வயது.</string>
    <string name="systemcleaner_filter_superfluosapks_label">தேவையற்ற APK-கள்</string>
    <string name="systemcleaner_filter_superfluosapks_summary">நிறுவப்பட்ட செயலி பதிப்புகளின் அடிப்படையில் தேவையில்லாத நிறுவல் கோப்புகள்.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">அதே பதிப்பைச் சேர்</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">நிறுவப்பட்ட பதிப்புடன் பொருந்தும் APK கோப்புகளையும் இலக்காகக் கொள். பழைய பதிப்புகளை மட்டும் நீக்க முடக்கவும்.</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR கோப்பைகள்</string>
    <string name="systemcleaner_filter_lostdir_summary">Android சாதனங்களுக்கிடையே தரவை மாற்றும்போது உருவாக்கப்படும் தற்காலிக கோப்புகள்.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Linux கோப்புகள்</string>
    <string name="systemcleaner_filter_linuxfiles_summary">சேமிப்பகம் Linux கணினியுடன் இணைக்கப்படும்போது உருவாக்கப்படும் கோப்புகள் மற்றும் அடைவுகள்.</string>
    <string name="systemcleaner_filter_macfiles_label">Mac கோப்புகள்</string>
    <string name="systemcleaner_filter_macfiles_summary">Appleஇன் finder பயன்பாட்டுடன் சேமிப்பகத்தை உலாவும்போது உருவாக்கப்படும் கோப்புகள் மற்றும் அடைவுகள்.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Windows கோப்புகள்</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"இணைக்கப்பட்ட சேமிப்பகத்தில் Windows கோப்பு உலாவி உருவாக்கக்கூடிய தரவு."</string>
    <string name="systemcleaner_filter_thumbnails_label">சிறுபடங்கள்</string>
    <string name="systemcleaner_filter_thumbnails_summary">படங்கள் மற்றும் வீடியோக்களுக்கான பதிவிடப்பட்ட முன்னோட்டங்கள்.</string>
    <string name="systemcleaner_filter_tempfiles_label">தற்காலிக அமைப்பு கோப்புகள்</string>
    <string name="systemcleaner_filter_tempfiles_summary">அமைப்பு தொடர்பான தற்காலிக கோப்புகள், பொதுவாக செயலில் உள்ள செயல்பாடுகளுக்கான குறுகிய ஆயுள் கேச்கள்.</string>
    <string name="systemcleaner_filter_analytics_label">பகுப்பாய்வு கோப்புகள்</string>
    <string name="systemcleaner_filter_analytics_summary">பகுப்பாய்வு மற்றும் பிழை கண்காணிப்புடன் தொடர்புடைய தரவு.</string>
    <string name="systemcleaner_filter_downloadcache_label">பதிவிறக்க கேச்</string>
    <string name="systemcleaner_filter_downloadcache_summary">பல்வேறு விஷயங்களுக்கு பயன்படுத்தப்படும் அமைப்பு கேச் அடைவு (எ.கா. OTA புதுப்பிப்புகள்).</string>
    <string name="systemcleaner_filter_localtmp_label">உள்ளூர் தற்காலிக கோப்புகள்</string>
    <string name="systemcleaner_filter_localtmp_summary">அமைப்பு தொடர்பான தற்காலிக கோப்புகள் (எ.கா. Android Studioவிலிருந்து).</string>
    <string name="systemcleaner_filter_datalogger_label">அமைப்பு பதிவு கோப்புகள்</string>
    <string name="systemcleaner_filter_datalogger_summary">அமைப்பு சேவை குறிப்பிட்ட பதிவு கோப்புகள்.</string>
    <string name="systemcleaner_filter_logdropbox_label">பதிவு கைவிடு பெட்டி</string>
    <string name="systemcleaner_filter_logdropbox_summary">அமைப்பு பதிவு கோப்புகளை விட ஒரு பகுதி.</string>
    <string name="systemcleaner_filter_recenttasks_label">சமீபத்திய பணிகள்</string>
    <string name="systemcleaner_filter_recenttasks_summary">அமைப்பின் பணி மாற்றியில் உள்ள பணிகள் வரலாற்றுடன் தொடர்புடைய தரவு.</string>
    <string name="systemcleaner_filter_tombstones_label">அமைப்பு செயலிழப்பு மீதி</string>
    <string name="systemcleaner_filter_tombstones_summary">தாய் செயல்முறைகள் செயலிழந்தால் (எ.கா. விளையாட்டுகள்), இங்கு கோப்புகள் உருவாக்கப்படுகின்றன.</string>
    <string name="systemcleaner_filter_usagestats_label">பயன்பாட்டு புள்ளிவிவரங்கள்</string>
    <string name="systemcleaner_filter_usagestats_summary">பயன்பாட்டு பயன்பாட்டு புள்ளிவிவரங்களுடன் தொடர்புடைய கோப்புகள்.</string>
    <string name="systemcleaner_delete_all_confirmation_message">அனைத்து வடிகட்டி உள்ளடக்கங்களையும் நீக்கவா?</string>
    <string name="systemcleaner_customfilter_label">தனிப்பயன் வடிகட்டி</string>
    <string name="systemcleaner_customfilter_create_hint">உங்கள் சாதனம் மற்றும் பயன்பாடுகளுக்கு தனித்துவமான கூடுதல் கோப்புகளை நீக்க தனிப்பயன் வடிகட்டியை உருவாக்கவும்.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">இந்த வடிகட்டியை அகற்றவா?</string>
    <string name="systemcleaner_customfilter_editor_label_label">வடிகட்டி சீட்டு</string>
    <string name="systemcleaner_customfilter_editor_warning">தனிப்பயன் வடிகட்டிகள் ஆபத்தானதாக இருக்கலாம். நீக்குவதற்கு முன் உங்கள் ஸ்கேன் முடிவுகளை சரிபார்க்கவும்!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">தரவு பகுதிகள்</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">எந்த பகுதியும் தேர்ந்தெடுக்கப்படவில்லை என்றால், அணுகக்கூடிய அனைத்து தரவு பகுதிகளும் ஸ்கேன் செய்யப்பட்டு பொருத்தப்படும்.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">கோப்பு வகை கட்டுப்பாடுகள்</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">கோப்புகள்</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">அடைவுகள்</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">எந்த வகையும் தேர்ந்தெடுக்கப்படவில்லை என்றால், அனைத்து வகைகளும் பொருத்தப்படும்.</string>
    <string name="systemcleaner_customfilter_editor_path_label">பாதை நிபந்தனைகள்</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">இலக்கு பாதை குறைந்தது ஒரு உள்ளீட்டுடன் பொருந்த வேண்டும் (எ.கா. \"Downloads/oldapks/game-\"). மேலும் விருப்பங்களுக்கு உள்ளீடுகளை நீள அழுத்தவும்.</string>
    <string name="systemcleaner_customfilter_editor_name_label">பெயர் நிபந்தனைகள்</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">இலக்கு பெயர் குறைந்தது ஒரு முக்கிய சொற்களை கொண்டிருக்க வேண்டும் (எ.கா. \"-receipt\"). மேலும் விருப்பங்களுக்கு உள்ளீடுகளை நீள அழுத்தவும்.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">விலக்குகள்</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">பாதை ஏதேனும் உள்ளீட்டுடன் பொருந்தினால் முடிவு விலக்கப்படும் (எ.கா. \"DCIM\"). மேலும் விருப்பங்களுக்கு உள்ளீடுகளை நீள அழுத்தவும்.</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_label">பாதை ஒப்பீட்டு முறை</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_start_label">பாதை முக்கிய சொல்லுடன் தொடங்குகிறது</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_contains_label">பாதை முக்கிய சொல்லைக் கொண்டுள்ளது</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_end_label">பாதை முக்கிய சொல்லுடன் முடிகிறது</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">பாதை முக்கிய சொல்லுக்கு சமமானது</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">பெயர் ஒப்பீட்டு முறை</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">பெயர் முக்கிய சொல்லுடன் தொடங்குகிறது</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">பெயர் முக்கிய சொல்லைக் கொண்டுள்ளது</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">பெயர் முக்கிய சொல்லுடன் முடிகிறது</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">பெயர் முக்கிய சொல்லுக்கு சமமானது</string>
    <string name="systemcleaner_customfilter_last_edit">கடைசி திருத்தம்: %s</string>
    <string name="systemcleaner_customfilter_editor_livesearch_label">நேரலை தேடல்</string>
    <string name="systemcleaner_customfilter_editor_size_label">அளவு வரம்புகள்</string>
    <string name="systemcleaner_customfilter_editor_size_minimum_label">குறைந்தபட்ச அளவு</string>
    <string name="systemcleaner_customfilter_editor_size_maximum_label">அதிகபட்ச அளவு</string>
    <string name="systemcleaner_customfilter_editor_size_explanation">கோப்பு அளவின் அடிப்படையில் பொருத்தங்களை வரம்பிடு. எந்த அளவிலும் பொருத்த அமைக்காமல் விடவும்.</string>
    <string name="systemcleaner_customfilter_editor_age_label">வயது வரம்புகள்</string>
    <string name="systemcleaner_customfilter_editor_age_minimum_label">குறைந்தபட்ச வயது</string>
    <string name="systemcleaner_customfilter_editor_age_maximum_label">அதிகபட்ச வயது</string>
    <string name="systemcleaner_customfilter_editor_age_explanation">கோப்பு வயது (கடைசி மாற்றிய நேரம்) அடிப்படையில் பொருத்தங்களை வரம்பிடு. எந்த வயதிலும் பொருத்த அமைக்காமல் விடவும்.</string>
