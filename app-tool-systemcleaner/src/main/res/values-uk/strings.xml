    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">Шлях дорівнює ключовому слову</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">Режим порівняння імен</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">Ім\'я починається з ключового слова</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">Ім\'я містить ключове слово</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">Ім\'я закінчується ключовим словом</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">Ім\'я дорівнює ключовому слову</string>
