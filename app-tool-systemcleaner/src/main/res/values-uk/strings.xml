    <string name="systemcleaner_filter_custom_label">Власний фільтр</string>
    <string name="systemcleaner_filter_custom_manage_label">Керування власними фільтрами</string>
    <string name="systemcleaner_filter_custom_manage_summary">Створюйте, видаляйте, імпортуйте та експортуйте власні фільтри.</string>
    <string name="systemcleaner_filter_logfiles_label">Файли системного журналу</string>
    <string name="systemcleaner_filter_logfiles_summary">Файли журналів системи та системних служб (наприклад, *.log) у різних місцях.</string>
    <string name="systemcleaner_filter_packagecaches_label">Кеш встановлювача додатків</string>
    <string name="systemcleaner_filter_packagecaches_summary">Кешовані дані, пов’язані з установленими додатками, які використовуються системою керування пакетами.</string>
    <string name="systemcleaner_filter_advertisements_label">Рекламні файли</string>
    <string name="systemcleaner_filter_advertisements_summary">Файли, що створені рекламними додатками.</string>
    <string name="systemcleaner_filter_anr_label">Помилки ANR</string>
    <string name="systemcleaner_filter_anr_summary">Сліди від подій \"додаток не відповідає\".</string>
    <string name="systemcleaner_filter_emptydirectories_label">Порожні папки</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Порожні папки з усього пристрою. Для вкладених папок може знадобитися кілька проходів.</string>
    <string name="systemcleaner_filter_screenshots_label">Знімки екрану</string>
    <string name="systemcleaner_filter_screenshots_summary">Знімки екрану старші за %s з різних додатків і місць.</string>
    <string name="systemcleaner_filter_trashed_label">Видалені файли</string>
    <string name="systemcleaner_filter_trashed_summary">Файли в кошику з різних додатків і місць, які позначені для видалення, але ще не видалені остаточно.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Вік знімка екрану</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Мінімальний вік для знімків екрану, які можуть бути видалені.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Зайві додатки APK</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Налаштуйте файли, які більше не потрібні, виходячи з версій встановлених додатків.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Включити ту саму версію</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Також виберіть APK-файли, які відповідають встановленій версії. Вимкніть цю опцію, щоб видалити тільки старі версії.</string>
    <string name="systemcleaner_filter_lostdir_label">Папки LOST.DIR</string>
    <string name="systemcleaner_filter_lostdir_summary">Тимчасові файли, які створюються під час передачі даних між пристроями Android.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Файли Linux</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Файли та папки, створені під час підключення сховища до комп\'ютера з Linux.</string>
    <string name="systemcleaner_filter_macfiles_label">Файли Mac</string>
    <string name="systemcleaner_filter_macfiles_summary">Файли та папки, створені під час перегляду сховища за допомогою програми Finder від Apple.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Файли Windows</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Дані, які провідник файлів Windows може створювати на підключеному сховищі."</string>
    <string name="systemcleaner_filter_thumbnails_label">Ескізи зображень</string>
    <string name="systemcleaner_filter_thumbnails_summary">Кешовані прев\'ю для зображень та відео.</string>
    <string name="systemcleaner_filter_tempfiles_label">Тимчасові системні файли</string>
    <string name="systemcleaner_filter_tempfiles_summary">Системні тимчасові файли, як правило, короткочасні кеші для активних операцій.</string>
    <string name="systemcleaner_filter_analytics_label">Файли аналітики</string>
    <string name="systemcleaner_filter_analytics_summary">Дані, пов\'язані з аналітикою та відстеженням помилок.</string>
    <string name="systemcleaner_filter_downloadcache_label">Завантаження кешу</string>
    <string name="systemcleaner_filter_downloadcache_summary">Папка системного кешу, яка використовується для різних речей (наприклад, OTA оновлень).</string>
    <string name="systemcleaner_filter_localtmp_label">Локальні тимчасові файли</string>
    <string name="systemcleaner_filter_localtmp_summary">Тимчасові файли, пов\'язані з системою (наприклад, з Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Файли системного журналу</string>
    <string name="systemcleaner_filter_datalogger_summary">Файли журналів системних служб.</string>
    <string name="systemcleaner_filter_logdropbox_label">Випадаюче вікно журналу</string>
    <string name="systemcleaner_filter_logdropbox_summary">Область, в яку система може скидати файли журналів.</string>
    <string name="systemcleaner_filter_recenttasks_label">Нещодавні завдання</string>
    <string name="systemcleaner_filter_recenttasks_summary">Дані, пов\'язані з історією завдань в системному перемикачі завдань.</string>
    <string name="systemcleaner_filter_tombstones_label">Залишки аварійного завершення системи</string>
    <string name="systemcleaner_filter_tombstones_summary">Якщо власні процеси завершуються (наприклад, ігри), то файли створюються тут.</string>
    <string name="systemcleaner_filter_usagestats_label">Статистика користування</string>
    <string name="systemcleaner_filter_usagestats_summary">Файли зі статистикою використання додатків.</string>
    <string name="systemcleaner_delete_all_confirmation_message">Видалити весь вміст фільтра?</string>
    <string name="systemcleaner_customfilter_label">Власний фільтр</string>
    <string name="systemcleaner_customfilter_create_hint">Створіть власний фільтр, щоб видалити зайві файли, які є унікальними для вашого пристрою та сценаріїв використання.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">Видалити цей фільтр?</string>
    <string name="systemcleaner_customfilter_editor_label_label">Фільтрувати мітку</string>
    <string name="systemcleaner_customfilter_editor_warning">Користувацькі фільтри можуть бути ризикованими. Перевірте результати сканування перед видаленням!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">Області даних</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Якщо жодна область не вибрана, то будуть проскановані та зіставлені всі доступні області даних.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">Обмеження типів файлів</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">Файли</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">Папки</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">Якщо жоден тип не вибрано, то будуть зіставлені всі типи.</string>
    <string name="systemcleaner_customfilter_editor_path_label">Критерії шляху</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Цільовий шлях має збігатися принаймні з одним записом (наприклад, \"Downloads/oldapks/game-\"). Довго натискайте записи для отримання додаткових опцій.</string>
    <string name="systemcleaner_customfilter_editor_name_label">Критерії назви</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">Ім\'я цілі має містити принаймні одне з ключових слів (наприклад, \"-receipt\"). Довго натискайте записи для отримання додаткових опцій.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Винятки</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Результат буде виключено, якщо шлях збігається з будь-яким записом (наприклад, \"DCIM\"). Довго натискайте записи для отримання додаткових опцій.</string>
