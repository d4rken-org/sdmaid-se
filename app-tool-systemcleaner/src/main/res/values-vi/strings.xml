    <string name="systemcleaner_customfilter_editor_areas_label">Vùng dữ liệu</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Nếu không có khu vực nào được chọn, thì tất cả các khu vực dữ liệu có thể truy cập sẽ được quét và so khớp.</string>
