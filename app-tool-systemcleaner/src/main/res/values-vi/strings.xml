    <string name="systemcleaner_filter_custom_label">Bộ lọc tùy chỉnh</string>
    <string name="systemcleaner_filter_custom_manage_label">Quản lý bộ lọc tùy chỉnh</string>
    <string name="systemcleaner_filter_custom_manage_summary">Tạo, xóa, nhập và xuất các bộ lọc tùy chỉnh của bạn.</string>
    <string name="systemcleaner_filter_logfiles_label">Tệp nhật ký hệ thống</string>
    <string name="systemcleaner_filter_logfiles_summary">Tệp nhật ký hệ thống và dịch vụ hệ thống (ví dụ: *.log) ở nhiều vị trí khác nhau.</string>
    <string name="systemcleaner_filter_packagecaches_label">Bộ nhớ đệm cài đặt</string>
    <string name="systemcleaner_filter_packagecaches_summary">Dữ liệu được lưu trong bộ nhớ đệm liên quan đến các ứng dụng đã cài đặt được quản lý gói của hệ thống sử dụng.</string>
    <string name="systemcleaner_filter_advertisements_label">Tệp quảng cáo</string>
    <string name="systemcleaner_filter_advertisements_summary">Các tệp đã được tạo cho hoặc bởi quảng cáo.</string>
    <string name="systemcleaner_filter_anr_label">Lỗi ANR</string>
    <string name="systemcleaner_filter_anr_summary">Dấu vết từ sự kiện \'ứng dụng không phản hồi\'.</string>
    <string name="systemcleaner_filter_emptydirectories_label">Thư mục trống</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Thư mục trống từ khắp nơi trên thiết bị. Các thư mục lồng nhau có thể yêu cầu nhiều lượt.</string>
    <string name="systemcleaner_filter_screenshots_label">Ảnh chụp màn hình</string>
    <string name="systemcleaner_filter_screenshots_summary">Ảnh chụp màn hình cũ hơn %s từ nhiều ứng dụng và vị trí.</string>
    <string name="systemcleaner_filter_trashed_label">Các tập tin đã xóa</string>
    <string name="systemcleaner_filter_trashed_summary">Các tệp trong thùng rác từ nhiều ứng dụng và vị trí khác nhau được đánh dấu để xóa nhưng chưa bị xóa vĩnh viễn.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Tuổi ảnh chụp màn hình</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Thời gian tối thiểu để xem xét xóa ảnh chụp màn hình.</string>
    <string name="systemcleaner_filter_superfluosapks_label">APK thừa</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Các tập tin cài đặt không còn cần thiết dựa trên phiên bản ứng dụng đã cài đặt.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Bao gồm cùng phiên bản</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Cũng nhắm mục tiêu đến các tệp APK phù hợp với phiên bản đã cài đặt. Vô hiệu hóa tùy chọn này để chỉ xóa các phiên bản cũ hơn.</string>
    <string name="systemcleaner_filter_lostdir_label">Các thư mục LOST.DIR</string>
    <string name="systemcleaner_filter_lostdir_summary">Các tệp tạm thời được tạo khi truyền dữ liệu giữa các thiết bị Android.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Tệp Linux</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Các tệp và thư mục được tạo khi lưu trữ đã được kết nối với máy tính linux.</string>
    <string name="systemcleaner_filter_macfiles_label">Mac files</string>
    <string name="systemcleaner_filter_macfiles_summary">Các tệp và thư mục được tạo khi duyệt bộ nhớ bằng ứng dụng tìm kiếm của Apple.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Tệp Windows</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Dữ liệu mà trình duyệt tệp Windows có thể tạo trên bộ lưu trữ được kết nối."</string>
    <string name="systemcleaner_filter_thumbnails_label">Hình thu nhỏ</string>
    <string name="systemcleaner_filter_thumbnails_summary">Bản xem trước được lưu trong bộ nhớ cache cho hình ảnh và video.</string>
    <string name="systemcleaner_filter_tempfiles_label">Các tập tin hệ thống tạm thời</string>
    <string name="systemcleaner_filter_tempfiles_summary">Các tệp tạm thời liên quan đến hệ thống, thường là bộ nhớ đệm tồn tại trong thời gian ngắn cho các hoạt động đang diễn ra.</string>
    <string name="systemcleaner_filter_analytics_label">Tệp phân tích</string>
    <string name="systemcleaner_filter_analytics_summary">Dữ liệu liên quan đến phân tích và theo dõi lỗi.</string>
    <string name="systemcleaner_filter_downloadcache_label">Bộ đệm tải xuống</string>
    <string name="systemcleaner_filter_downloadcache_summary">Thư mục bộ đệm hệ thống được sử dụng cho nhiều thứ khác nhau (ví dụ: cập nhật OTA).</string>
    <string name="systemcleaner_filter_localtmp_label">Tệp tạm thời cục bộ</string>
    <string name="systemcleaner_filter_localtmp_summary">Các tệp tạm thời liên quan đến hệ thống (ví dụ: từ Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Tệp nhật ký hệ thống</string>
    <string name="systemcleaner_filter_datalogger_summary">Tệp nhật ký dành riêng cho dịch vụ hệ thống.</string>
    <string name="systemcleaner_filter_logdropbox_label">Nhật ký drop box</string>
    <string name="systemcleaner_filter_logdropbox_summary">Một khu vực để hệ thống thả các tệp nhật ký vào.</string>
    <string name="systemcleaner_filter_recenttasks_label">Tác vụ gần đây</string>
    <string name="systemcleaner_filter_recenttasks_summary">Dữ liệu liên quan đến lịch sử nhiệm vụ trong trình chuyển đổi tác vụ của hệ thống.</string>
    <string name="systemcleaner_filter_tombstones_label">Dư lượng sự cố hệ thống</string>
    <string name="systemcleaner_filter_tombstones_summary">Nếu các tiến trình gốc gặp sự cố (ví dụ: trò chơi), thì các tệp sẽ được tạo tại đây.</string>
    <string name="systemcleaner_filter_usagestats_label">Thống kê sử dụng</string>
    <string name="systemcleaner_filter_usagestats_summary">Các tệp liên quan đến số liệu thống kê sử dụng ứng dụng.</string>
    <string name="systemcleaner_delete_all_confirmation_message">Xóa tất cả nội dung bộ lọc?</string>
