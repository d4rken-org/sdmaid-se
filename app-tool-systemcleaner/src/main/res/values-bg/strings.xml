<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="systemcleaner_explanation_short">Излишни данни, които не принадлежат на никое конкретно приложение.</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="one">%d съвпадение изтрито</item>
        <item quantity="other">%d съвпадения изтрити</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="one">%d съвпадение на филтър</item>
        <item quantity="other">%d съвпадения на филтър</item>
    </plurals>
    <string name="systemcleaner_filter_custom_label">Персонализиран филтър</string>
    <string name="systemcleaner_filter_custom_manage_label">Управление на персонализирани филтри</string>
    <string name="systemcleaner_filter_custom_manage_summary">Създавайте, изтривайте, импортирайте и експортирайте вашите персонализирани филтри.</string>
    <string name="systemcleaner_filter_logfiles_label">Системни лог файлове</string>
    <string name="systemcleaner_filter_logfiles_summary">Лог файлове на системата и системните услуги (напр. *.log) на различни места.</string>
    <string name="systemcleaner_filter_packagecaches_label">Кеш на инсталатора</string>
    <string name="systemcleaner_filter_packagecaches_summary">Кеширани данни, свързани с инсталирани приложения, които се използват от системното управление на пакети.</string>
    <string name="systemcleaner_filter_advertisements_label">Рекламни файлове</string>
    <string name="systemcleaner_filter_advertisements_summary">Файлове, които са създадени за или от реклами.</string>
    <string name="systemcleaner_filter_anr_label">ANR грешки</string>
    <string name="systemcleaner_filter_anr_summary">Следи от събития \'приложението не отговаря\'.</string>
    <string name="systemcleaner_filter_emptydirectories_label">Празни папки</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Празни папки от цялото устройство. Вложените папки може да изискват няколко прохода.</string>
    <string name="systemcleaner_filter_screenshots_label">Екранни снимки</string>
    <string name="systemcleaner_filter_screenshots_summary">Екранни снимки по-стари от %s от множество приложения и места.</string>
    <string name="systemcleaner_filter_trashed_label">Изхвърлени файлове</string>
    <string name="systemcleaner_filter_trashed_summary">Файлове в кошчета за отпадъци от различни приложения и места, които са маркирани за изтриване, но още не са окончателно премахнати.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Възраст на екранните снимки</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Минимална възраст за екранни снимки, за да бъдат разгледани за изтриване.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Излишни APK файлове</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Инсталационни файлове, които вече не са необходими на база инсталираните версии на приложенията.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Включване на същата версия</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Също така насочване към APK файлове, които съвпадат с инсталираната версия. Деактивирайте, за да премахвате само по-стари версии.</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR папки</string>
    <string name="systemcleaner_filter_lostdir_summary">Временни файлове, които се създават при прехвърляне на данни между Android устройства.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Linux файлове</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Файлове и папки, които се създават когато хранилището е свързано към linux компютър.</string>
    <string name="systemcleaner_filter_macfiles_label">Mac файлове</string>
    <string name="systemcleaner_filter_macfiles_summary">Файлове и папки, които се създават при разглеждане на хранилището с приложението finder на Apple.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Windows файлове</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Данни, които Windows file explorer може да създаде на свързано хранилище."</string>
    <string name="systemcleaner_filter_thumbnails_label">Миниатюрни изображения</string>
    <string name="systemcleaner_filter_thumbnails_summary">Кеширани прегледи за изображения и видеа.</string>
    <string name="systemcleaner_filter_tempfiles_label">Временни системни файлове</string>
    <string name="systemcleaner_filter_tempfiles_summary">Системни временни файлове, обикновено краткотрайни кешове за активни операции.</string>
    <string name="systemcleaner_filter_analytics_label">Аналитични файлове</string>
    <string name="systemcleaner_filter_analytics_summary">Данни, свързани с аналитика и проследяване на грешки.</string>
    <string name="systemcleaner_filter_downloadcache_label">Кеш за изтегляния</string>
    <string name="systemcleaner_filter_downloadcache_summary">Системна кеш папка, използвана за различни неща (напр. OTA актуализации).</string>
    <string name="systemcleaner_filter_localtmp_label">Локални временни файлове</string>
    <string name="systemcleaner_filter_localtmp_summary">Системни временни файлове (напр. от Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Системни лог файлове</string>
    <string name="systemcleaner_filter_datalogger_summary">Специфични лог файлове за системни услуги.</string>
    <string name="systemcleaner_filter_logdropbox_label">Лог drop box</string>
    <string name="systemcleaner_filter_logdropbox_summary">Област за системата да пуска лог файлове.</string>
    <string name="systemcleaner_filter_recenttasks_label">Скорошни задачи</string>
    <string name="systemcleaner_filter_recenttasks_summary">Данни, свързани с историята на задачите в системния превключвател на задачи.</string>
    <string name="systemcleaner_filter_tombstones_label">Остатъци от системни сривове</string>
    <string name="systemcleaner_filter_tombstones_summary">Ако нативни процеси се сринат (напр. игри), тогава тук се създават файлове.</string>
    <string name="systemcleaner_filter_usagestats_label">Статистики за използване</string>
    <string name="systemcleaner_filter_usagestats_summary">Файлове, свързани със статистиките за използване на приложения.</string>
    <string name="systemcleaner_delete_all_confirmation_message">Изтриване на цялото съдържание на филтъра?</string>
    <string name="systemcleaner_customfilter_label">Персонализиран филтър</string>
    <string name="systemcleaner_customfilter_create_hint">Създайте персонализиран филтър за изтриване на допълнителни файлове, които са уникални за вашето устройство и случаи на употреба.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">Премахване на този филтър?</string>
    <string name="systemcleaner_customfilter_editor_label_label">Етикет на филтъра</string>
    <string name="systemcleaner_customfilter_editor_warning">Персонализираните филтри могат да бъдат рискови. Проверете резултатите от сканирането преди изтриване!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">Области с данни</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Ако не е избрана област, тогава всички достъпни области с данни ще бъдат сканирани и съпоставени.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">Ограничения за типове файлове</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">Файлове</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">Папки</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">Ако не е избран тип, тогава всички типове ще бъдат съпоставени.</string>
    <string name="systemcleaner_customfilter_editor_path_label">Критерии за път</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Целевият път трябва да съвпада с поне един запис (напр. \"Downloads/oldapks/game-\"). Дълго натискане на записи за повече опции.</string>
    <string name="systemcleaner_customfilter_editor_name_label">Критерии за име</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">Целевото име трябва да съдържа поне една от ключовите думи (напр. \"-receipt\"). Дълго натискане на записи за повече опции.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Изключения</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Резултатът ще бъде изключен, ако пътят съвпада с някой запис (напр. \"DCIM\"). Дълго натискане на записи за повече опции.</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_label">Режим на сравнение на път</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_start_label">Пътят започва с ключова дума</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_contains_label">Пътят съдържа ключова дума</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_end_label">Пътят завършва с ключова дума</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">Пътят е равен на ключовата дума</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">Режим на сравнение на име</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">Името започва с ключова дума</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">Името съдържа ключова дума</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">Името завършва с ключова дума</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">Името е равно на ключовата дума</string>
    <string name="systemcleaner_customfilter_last_edit">Последна редакция: %s</string>
    <string name="systemcleaner_customfilter_editor_livesearch_label">Търсене в реално време</string>
    <string name="systemcleaner_customfilter_editor_size_label">Ограничения по размер</string>
    <string name="systemcleaner_customfilter_editor_size_minimum_label">Минимален размер</string>
    <string name="systemcleaner_customfilter_editor_size_maximum_label">Максимален размер</string>
    <string name="systemcleaner_customfilter_editor_size_explanation">Ограничаване на съвпаденията по размер на файла. Оставете незададено за съвпадение с всякакъв размер.</string>
    <string name="systemcleaner_customfilter_editor_age_label">Ограничения по възраст</string>
    <string name="systemcleaner_customfilter_editor_age_minimum_label">Минимална възраст</string>
    <string name="systemcleaner_customfilter_editor_age_maximum_label">Максимална възраст</string>
    <string name="systemcleaner_customfilter_editor_age_explanation">Ограничаване на съвпаденията по възраст на файла (последна модификация). Оставете незададено за съвпадение с всякаква възраст.</string>
    <string name="systemcleaner_customfilter_import_action">Импортиране на нов филтър</string>
    <string name="systemcleaner_customfilter_export_action">Експортиране на избрания филтър</string>
</resources>
