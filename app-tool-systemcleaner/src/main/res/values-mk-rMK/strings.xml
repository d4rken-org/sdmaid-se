<resources>
    <string name="systemcleaner_explanation_short">Непотребни податоци кои не припаѓаат на ниедна конкретна апликација.</string>
    <plurals name="systemcleaner_result_x_items_deleted">
        <item quantity="one">%d совпаѓање избришано</item>
        <item quantity="other">%d совпаѓања избришани</item>
    </plurals>
    <plurals name="systemcleaner_result_x_items_found">
        <item quantity="one">%d совпаѓање со филтер</item>
        <item quantity="other">%d совпаѓања со филтер</item>
    </plurals>
    <string name="systemcleaner_filter_custom_label">Прилагоден филтер</string>
    <string name="systemcleaner_filter_custom_manage_label">Управувај со прилагодени филтри</string>
    <string name="systemcleaner_filter_custom_manage_summary">Создади, избриши, увези и извези ги вашите прилагодени филтри.</string>
    <string name="systemcleaner_filter_logfiles_label">Системски дневнички датотеки</string>
    <string name="systemcleaner_filter_logfiles_summary">Дневнички датотеки на системски услуги и системот (пр. *.log) на различни локации.</string>
    <string name="systemcleaner_filter_packagecaches_label">Кеш на инсталатор на пакети</string>
    <string name="systemcleaner_filter_packagecaches_summary">Кеширани податоци за инсталирани апликации користени од системскиот менаџер на пакети.</string>
    <string name="systemcleaner_filter_advertisements_label">Рекламни датотеки</string>
    <string name="systemcleaner_filter_advertisements_summary">Датотеки создадени за или од реклами.</string>
    <string name="systemcleaner_filter_anr_label">ANR грешки</string>
    <string name="systemcleaner_filter_anr_summary">Траги од настани \"апликацијата не реагира\".</string>
    <string name="systemcleaner_filter_emptydirectories_label">Празни папки</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Празни папки од целиот уред. Вгнездени папки може да бараат повеќе поминувања.</string>
    <string name="systemcleaner_filter_screenshots_label">Слики од екранот</string>
    <string name="systemcleaner_filter_screenshots_summary">Слики од екранот постари од %s од повеќе апликации и локации.</string>
    <string name="systemcleaner_filter_trashed_label">Фрлени датотеки</string>
    <string name="systemcleaner_filter_trashed_summary">Датотеки во корпи за отпадоци од различни апликации и локации кои се означени за бришење но сè уште не се трајно отстранети.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Старост на слика од екранот</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Минимална старост за слики од екранот кои треба да се разгледаат за бришење.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Непотребни APK</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Инсталациски датотеки кои повеќе не се потребни врз основа на инсталираните верзии на апликации.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Вклучи иста верзија</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">Исто така целај APK датотеки кои одговараат на инсталираната верзија. Исклучи за отстранување само на постари верзии.</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR папки</string>
    <string name="systemcleaner_filter_lostdir_summary">Привремени датотеки создадени при пренос на податоци меѓу Android уреди.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Linux датотеки</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Датотеки и папки создадени кога складирањето е монтирано на Linux компјутер.</string>
    <string name="systemcleaner_filter_macfiles_label">Mac датотеки</string>
    <string name="systemcleaner_filter_macfiles_summary">Датотеки и папки создадени при прегледување на складирањето со Apple Finder.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Windows датотеки</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Податоци кои Windows Explorer може да ги создаде на поврзано складирање."</string>
    <string name="systemcleaner_filter_thumbnails_label">Сликички</string>
    <string name="systemcleaner_filter_thumbnails_summary">Кеширани прегледи за слики и видеа.</string>
    <string name="systemcleaner_filter_tempfiles_label">Привремени системски датотеки</string>
    <string name="systemcleaner_filter_tempfiles_summary">Привремени датотеки поврзани со системот, обично краткотрајни кешови за активни операции.</string>
    <string name="systemcleaner_filter_analytics_label">Аналитички датотеки</string>
    <string name="systemcleaner_filter_analytics_summary">Податоци поврзани со аналитика и следење на грешки.</string>
    <string name="systemcleaner_filter_downloadcache_label">Кеш за преземања</string>
    <string name="systemcleaner_filter_downloadcache_summary">Папка за системски кеш користена за различни работи (пр. OTA ажурирања).</string>
    <string name="systemcleaner_filter_localtmp_label">Локални привремени датотеки</string>
    <string name="systemcleaner_filter_localtmp_summary">Привремени датотеки поврзани со системот (пр. од Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Системски дневнички датотеки</string>
    <string name="systemcleaner_filter_datalogger_summary">Дневнички датотеки специфични за системски услуги.</string>
    <string name="systemcleaner_filter_logdropbox_label">Дневничка област</string>
    <string name="systemcleaner_filter_logdropbox_summary">Област каде системот складира дневнички датотеки.</string>
    <string name="systemcleaner_filter_recenttasks_label">Скорешни задачи</string>
    <string name="systemcleaner_filter_recenttasks_summary">Податоци поврзани со историјата на задачи во системскиот менаџер на задачи.</string>
    <string name="systemcleaner_filter_tombstones_label">Остатоци од системски падови</string>
    <string name="systemcleaner_filter_tombstones_summary">Ако нативните процеси паднат (пр. игри), тогаш датотеки се создаваат тука.</string>
    <string name="systemcleaner_filter_usagestats_label">Статистика на користење</string>
    <string name="systemcleaner_filter_usagestats_summary">Датотеки поврзани со статистиката на користење на апликации.</string>
    <string name="systemcleaner_delete_all_confirmation_message">Избриши ја целата содржина на филтерот?</string>
    <string name="systemcleaner_customfilter_label">Прилагоден филтер</string>
    <string name="systemcleaner_customfilter_create_hint">Создадете прилагоден филтер за бришење дополнителни датотеки уникатни за вашиот уред и употреба.</string>
    <string name="systemcleaner_editor_remove_confirmation_message">Отстрани го овој филтер?</string>
    <string name="systemcleaner_customfilter_editor_label_label">Етикета на филтер</string>
    <string name="systemcleaner_customfilter_editor_warning">Прилагодените филтри може да бидат опасни. Проверете ги резултатите од скенирањето пред бришење!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">Области со податоци</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Ако не е избрана област, тогаш сите достапни области со податоци ќе бидат скенирани и совпаднати.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">Ограничувања на типови датотеки</string>
    <string name="systemcleaner_customfilter_editor_filetypes_files_label">Датотеки</string>
    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">Папки</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">Ако не е избран тип, тогаш сите типови ќе совпаднат.</string>
    <string name="systemcleaner_customfilter_editor_path_label">Критериуми за патека</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Целната патека мора да совпадне со барем еден запис (пр. \"Downloads/oldapks/game-\"). Долго притиснете записи за повеќе опции.</string>
    <string name="systemcleaner_customfilter_editor_name_label">Критериуми за име</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">Целното име мора да содржи барем еден од клучните зборови (пр. \"- receipt\"). Долго притиснете записи за повеќе опции.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Исклучоци</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Резултатот ќе биде исклучен ако патеката совпадне со било кој запис (пр. \"DCIM\"). Долго притиснете записи за повеќе опции.</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_label">Режим на споредување на патека</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_start_label">Патеката почнува со клучен збор</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_contains_label">Патеката содржи клучен збор</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_end_label">Патеката завршува со клучен збор</string>
    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">Патеката е еднаква на клучниот збор</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">Режим на споредување на име</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">Името почнува со клучен збор</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">Името содржи клучен збор</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">Името завршува со клучен збор</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">Името е еднакво на клучниот збор</string>
    <string name="systemcleaner_customfilter_last_edit">Последна промена: %s</string>
    <string name="systemcleaner_customfilter_editor_livesearch_label">Пребарување во живо</string>
    <string name="systemcleaner_customfilter_editor_size_label">Ограничувања на големина</string>
    <string name="systemcleaner_customfilter_editor_size_minimum_label">Минимална големина</string>
    <string name="systemcleaner_customfilter_editor_size_maximum_label">Максимална големина</string>
    <string name="systemcleaner_customfilter_editor_size_explanation">Ограничи совпаѓања врз основа на големина на датотека. Оставете го непоставено за совпаѓање на било која големина.</string>
    <string name="systemcleaner_customfilter_editor_age_label">Ограничувања на старост</string>
    <string name="systemcleaner_customfilter_editor_age_minimum_label">Минимална старост</string>
    <string name="systemcleaner_customfilter_editor_age_maximum_label">Максимална старост</string>
    <string name="systemcleaner_customfilter_editor_age_explanation">Ограничи совпаѓања врз основа на старост на датотека (време на последна промена). Оставете го непоставено за совпаѓање на било која старост.</string>
    <string name="systemcleaner_customfilter_import_action">Увези нов филтер</string>
    <string name="systemcleaner_customfilter_export_action">Извези избран филтер</string>
</resources>
