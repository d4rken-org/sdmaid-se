    <string name="systemcleaner_customfilter_editor_warning">Ang mga custom filter ay maaaring mapanganib. Tingnan ang mga resulta ng scan bago mag-delete!</string>
    <string name="systemcleaner_customfilter_editor_areas_label">Mga data area</string>
    <string name="systemcleaner_customfilter_editor_areas_explanation">Kung walang napilingi na area, lahat ng ma-access na data area ay i-scan at i-match.</string>
    <string name="systemcleaner_customfilter_editor_filetypes_label">Mga paghahadlang sa uri ng file</string>
