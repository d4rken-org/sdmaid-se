    <string name="systemcleaner_customfilter_editor_filetypes_directories_label">Mga folder</string>
    <string name="systemcleaner_customfilter_editor_filetypes_hint">Kung walang napilingi na uri, lahat ng uri ay i-match.</string>
    <string name="systemcleaner_customfilter_editor_path_label">Mga criteria ng path</string>
    <string name="systemcleaner_customfilter_editor_path_explanation">Ang target path ay kailangan tumugma sa kahit isang entry (hal. \"Downloads/oldapks/game-\"). Long press ang mga entry para sa higit pang opsyon.</string>
    <string name="systemcleaner_customfilter_editor_name_label">Mga criteria ng pangalan</string>
    <string name="systemcleaner_customfilter_editor_name_explanation">Ang target name ay dapat maglaman ng kahit isa sa mga keyword (hal. \"-receipt\"). Long press ang mga entry para sa higit pang opsyon.</string>
    <string name="systemcleaner_customfilter_editor_exclusions_label">Mga exclusion</string>
    <string name="systemcleaner_customfilter_editor_exclusions_explanation">Ang resulta ay hindi isasama kung tumugma ang path sa anumang entry (hal. \"DCIM\"). Long press ang mga entry para sa higit pang opsyon.</string>
