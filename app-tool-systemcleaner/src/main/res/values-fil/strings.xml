    <string name="systemcleaner_filter_custom_label">Pasadya na Salaan</string>
    <string name="systemcleaner_filter_custom_manage_label">Pamahalaan ang mga custom filter</string>
    <string name="systemcleaner_filter_custom_manage_summary">Gumawa, tanggalin, mag-import at mag-export ng inyong mga custom filter.</string>
    <string name="systemcleaner_filter_logfiles_label">Mga system log file</string>
    <string name="systemcleaner_filter_logfiles_summary">Mga system at system service log file (hal. *.log) sa iba\'t ibang lokasyon.</string>
    <string name="systemcleaner_filter_packagecaches_label">Cache ng installer</string>
    <string name="systemcleaner_filter_packagecaches_summary">Naka-cache na data na nauugnay sa mga naka-install na app na ginagamit ng package management ng system.</string>
    <string name="systemcleaner_filter_advertisements_label">Ad files</string>
    <string name="systemcleaner_filter_advertisements_summary">Mga files na nagawa o para sa patalastas.</string>
    <string name="systemcleaner_filter_anr_label">ANR errors</string>
    <string name="systemcleaner_filter_anr_summary">Bakas mula sa \'application not responding\' na mga pangyayari.</string>
    <string name="systemcleaner_filter_emptydirectories_label">Mga walang lamang folder</string>
    <string name="systemcleaner_filter_emptydirectories_summary">Mga walang lamang folder mula sa buong device. Maaaring kailangan ng maraming passes ang mga nested folder.</string>
    <string name="systemcleaner_filter_screenshots_label">Mga screenshot</string>
    <string name="systemcleaner_filter_screenshots_summary">Mga screenshot na mas matanda sa %s mula sa maraming app at lokasyon.</string>
    <string name="systemcleaner_filter_trashed_label">Mga naitapon na file</string>
    <string name="systemcleaner_filter_trashed_summary">Mga file sa recycle bin mula sa iba\'t ibang app at lokasyon na namarkahan para sa deletion pero hindi pa permanent na natanggal.</string>
    <string name="systemcleaner_filter_screenshots_age_label">Edad ng Screenshot</string>
    <string name="systemcleaner_filter_screenshots_age_summary">Minimum na edad para sa mga screenshot na dapat isaalang-alang para sa deletion.</string>
    <string name="systemcleaner_filter_superfluosapks_label">Mga sobrang APK</string>
    <string name="systemcleaner_filter_superfluosapks_summary">Mga setup file na hindi na kailangan batay sa mga naka-install na bersyon ng app.</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_label">Isama ang parehong bersyon</string>
    <string name="systemcleaner_filter_superfluosapks_includesameversion_summary">I-target din ang mga APK file na tumutugma sa naka-install na bersyon. I-disable upang tanggalin lang ang mga mas lumang bersyon.</string>
    <string name="systemcleaner_filter_lostdir_label">LOST.DIR folders</string>
    <string name="systemcleaner_filter_lostdir_summary">Mga pansamantalang file na ginagawa kapag naglilipat ng data sa pagitan ng mga Android device.</string>
    <string name="systemcleaner_filter_linuxfiles_label">Mga Linux file</string>
    <string name="systemcleaner_filter_linuxfiles_summary">Mga file at folder na ginagawa kapag nakaconnect ang storage sa isang linux computer.</string>
    <string name="systemcleaner_filter_macfiles_label">Mga Mac file</string>
    <string name="systemcleaner_filter_macfiles_summary">Mga file at folder na ginagawa kapag nagbi-browse ng storage gamit ang Apple finder app.</string>
    <string name="systemcleaner_filter_windowsfiles_label">Mga Windows file</string>
    <string name="systemcleaner_filter_windowsfiles_summary">"Data na maaaring gawin ng Windows file explorer sa nakaconnect na storage."</string>
    <string name="systemcleaner_filter_thumbnails_label">Mga thumbnail na larawan</string>
    <string name="systemcleaner_filter_thumbnails_summary">Naka-cache na preview para sa mga larawan at video.</string>
    <string name="systemcleaner_filter_tempfiles_label">Mga pansamantalang system file</string>
    <string name="systemcleaner_filter_tempfiles_summary">System-related na pansamantalang file, karaniwang panandaliang cache para sa mga aktibong operasyon.</string>
    <string name="systemcleaner_filter_analytics_label">Mga analytics file</string>
    <string name="systemcleaner_filter_analytics_summary">Data na nauugnay sa analytics at bug tracking.</string>
    <string name="systemcleaner_filter_downloadcache_label">Cache ng download</string>
    <string name="systemcleaner_filter_downloadcache_summary">System cache folder na ginagamit para sa iba\'t ibang bagay (hal. OTA update).</string>
    <string name="systemcleaner_filter_localtmp_label">Mga lokal na pansamantalang file</string>
    <string name="systemcleaner_filter_localtmp_summary">System-related na pansamantalang file (hal. mula sa Android Studio).</string>
    <string name="systemcleaner_filter_datalogger_label">Mga system log file</string>
    <string name="systemcleaner_filter_datalogger_summary">System service specific na log file.</string>
    <string name="systemcleaner_filter_logdropbox_label">Log drop box</string>
    <string name="systemcleaner_filter_logdropbox_summary">Lugar para sa system na maglagay ng mga log file.</string>
    <string name="systemcleaner_filter_recenttasks_label">Mga kamakailang gawain</string>
    <string name="systemcleaner_filter_recenttasks_summary">Data na nauugnay sa kasaysayan ng mga gawain sa task switcher ng system.</string>
    <string name="systemcleaner_filter_tombstones_label">Mga natira ng system crash</string>
    <string name="systemcleaner_filter_tombstones_summary">Kung mag-crash ang mga native process (hal. mga laro), ginagawa dito ang mga file.</string>
    <string name="systemcleaner_filter_usagestats_label">Mga usage stats</string>
    <string name="systemcleaner_filter_usagestats_summary">Mga file na nauugnay sa application usage stats.</string>
    <string name="systemcleaner_delete_all_confirmation_message">Tanggalin ang lahat ng laman ng filter?</string>
    <string name="systemcleaner_customfilter_label">Custom na filter</string>
    <string name="systemcleaner_customfilter_create_hint">Gumawa ng custom filter para tanggalin ang mga karagdagang file na natatangi sa inyong device at mga gamit.</string>
