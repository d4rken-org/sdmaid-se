    <string name="systemcleaner_customfilter_editor_segments_matching_mode_equal_label">Путь соответствует ключевому слову</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_label">Режим сравнения имен</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_start_label">Имя начинается с ключевого слова</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_contains_label">Имя содержит ключевое слово</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_end_label">Имя заканчивается ключевым словом</string>
    <string name="systemcleaner_customfilter_editor_name_matching_mode_equal_label">Имя соответствует ключевому слову</string>
    <string name="systemcleaner_customfilter_last_edit">Последнее изменение: %s</string>
    <string name="systemcleaner_customfilter_editor_livesearch_label">Живой поиск</string>
    <string name="systemcleaner_customfilter_editor_size_label">Ограничения по размеру</string>
    <string name="systemcleaner_customfilter_editor_size_minimum_label">Минимальный размер</string>
    <string name="systemcleaner_customfilter_editor_size_maximum_label">Максимальный размер</string>
    <string name="systemcleaner_customfilter_editor_size_explanation">Ограничение совпадений в зависимости от размера файла. Оставьте пустым для любого размера.</string>
    <string name="systemcleaner_customfilter_editor_age_label">Ограничения по возрасту</string>
    <string name="systemcleaner_customfilter_editor_age_minimum_label">Минимальный возраст</string>
    <string name="systemcleaner_customfilter_editor_age_maximum_label">Максимальный возраст</string>
    <string name="systemcleaner_customfilter_editor_age_explanation">Ограничение совпадений на основе возраста файла (времени последнего изменения). Оставьте пустым для любого возраста.</string>
    <string name="systemcleaner_customfilter_import_action">Импорт нового фильтра</string>
