<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="appcleaner_explanation_short">Izlietojami dati, kas pieder konkrētām lietotnēm.</string>
    <string name="appcleaner_filter_defaultcachespublic_label">Publiskie noklusuši kešatmiņas</string>
    <string name="appcleaner_filter_defaultcachespublic_summary">Noklusētie publiskie lietotnes kešatmiņas. Pieejami mapē Android/data vecākās Android versijās. Tiek dzēsti, pieskaroties \"Notīrīt kešatmiņu\" sistēmas iestatījumos.</string>
    <string name="appcleaner_filter_defaultcachesprivate_label">Privātie noklusuši kešatmiņas</string>
    <string name="appcleaner_filter_defaultcachesprivate_summary">Noklusētie privātie lietotnes kešatmiņas. Tiek dzēsti, pieskaroties \"Notīrīt kešatmiņu\" sistēmas iestatījumos.</string>
    <string name="appcleaner_include_systemapps_label">Iekļaut sistēmas lietotnes</string>
    <string name="appcleaner_include_systemapps_summary">Iekļaut sistēmas lietotnes skenēšanā.</string>
    <string name="appcleaner_include_runningapps_label">Iekļaut darbošos lietotnes</string>
    <string name="appcleaner_include_runningapps_summary">Iekļaujas lietotnes, kas pašlaik darbojas un var radīt traucējumus.</string>
    <string name="appcleaner_include_inaccessible_label">Iekļaut nepieejamās kešatmiņas</string>
    <string name="appcleaner_include_inaccessible_summary">Iekļaut datus, kam nevar piekļūt tieši, bet kurus var dzēst caur sistēmas iestatījumiem un automatizēt, izmantojot pieejamības pakalpojumu.</string>
    <string name="appcleaner_include_minimumsize_label">Minimālais izmērs</string>
    <string name="appcleaner_include_minimumsize_summary">Izlaist lietotnes, kurās iztērējamo datu kopsumma ir zemāka par minimālo.</string>
    <string name="appcleaner_include_minimumage_label">Minimālais vecums</string>
    <string name="appcleaner_include_minimumage_summary">Izlaist failus, kas ir jaunāki par minimālo vecumu.</string>
    <string name="appcleaner_automation_romtype_detection_label">Operētājsistēmas noteikšana</string>
    <string name="appcleaner_automation_romtype_detection_summary">Automātizācija, kuras pamats ir pieejamība, var neizdoties, ja SD Maid nenosaka jūsu OS pareizi. Izmantojiet šo iestatījumu, lai pārrakstītu noteikto OS.</string>
    <string name="appcleaner_filter_codecache_label">Koda kešatmiņa</string>
    <string name="appcleaner_filter_codecache_summary">JVM koda kešatmiņa. Baitu koda bloki, kas kompilēti natīvajā kodā.</string>
    <string name="appcleaner_filter_advertisement_label">Reklamu dati</string>
    <string name="appcleaner_filter_advertisement_summary">Ar reklamām saistīti faili, piem., kešotā multivide.</string>
    <string name="appcleaner_filter_bugreporting_label">Kļūdu ziņošana</string>
    <string name="appcleaner_filter_bugreporting_summary">Ar kļūdu ziņošanu saistīti dati, piem., kļūdu žurnāli vai avArijas izgrāmpojumi.</string>
    <string name="appcleaner_filter_analytics_label">Analītika</string>
    <string name="appcleaner_filter_analytics_summary">Ar analītiku saistīti dati, piem., kešotā statistika par to, ko pieskaraties lietotnē.</string>
    <string name="appcleaner_filter_hiddencaches_label">Slēptās kešatmiņas</string>
    <string name="appcleaner_filter_hiddencaches_summary">Vispārēja lietojuma kešatmiņas, kas saglabātas ārpus sistēmas sasniedzamības.</string>
    <string name="appcleaner_filter_thumbnails_label">Multivides sauknīčas</string>
    <string name="appcleaner_filter_thumbnails_summary">Attēlu, video un audio priekšskatījuma sauknīčas.</string>
    <string name="appcleaner_filter_gamefiles_label">Spēļu faili</string>
    <string name="appcleaner_filter_gamefiles_summary">Ar spēli saistīti resursi, kurus spēle pēc nepieciešamības ielādēs no jauna nākamajā palaisanā reizē.</string>
    <string name="appcleaner_filter_offlinecache_label">Beļlīnijadarba kešatmiņa</string>
    <string name="appcleaner_filter_offlinecache_summary">Faili, kas saglabāti lietošanai bez interneta, piem., kartes plāksnes.</string>
    <string name="appcleaner_filter_recyclebins_label">Atkritumu grozs</string>
    <string name="appcleaner_filter_recyclebins_summary">Dzesti faili, kas novietoti īpašā mapē, lai tos varētu atjaunot.</string>
    <string name="appcleaner_filter_webview_label">Webview faili</string>
    <string name="appcleaner_filter_webview_summary">Faili, ko kešo Webview instances, ko izmanto lietotnēs.</string>
    <string name="appcleaner_filter_shortcutservice_label">Lietotnes saiteņu ikonas</string>
    <string name="appcleaner_filter_shortcutservice_summary">Kešotas ikonas lietotnes saitainošanai un koplietošanas izvēlnēm.</string>
    <string name="appcleaner_filter_whatsapp_backups_label">WhatsApp rezerves kopijas</string>
    <string name="appcleaner_filter_whatsapp_backups_summary">Dzēst papildu WhatsApp rezerves kopiju eksemplārus un saglabāt tikai jaunako.</string>
    <string name="appcleaner_filter_whatsapp_received_summary">Faili, ko saņēmāt no citiem cilvekēm, izmantojot WhatsApp.</string>
    <string name="appcleaner_filter_whatsapp_received_label">WhatsApp saņemtie faili</string>
    <string name="appcleaner_filter_whatsapp_sent_label">WhatsApp nosūtītie faili</string>
    <string name="appcleaner_filter_whatsapp_sent_summary">Faili, kas nosūtīti no WhatsApp citiem.</string>
    <string name="appcleaner_filter_telegram_label">Telegram multivides faili</string>
    <string name="appcleaner_filter_telegram_summary">Faili, kas saņemti vai nosūtīti, izmantojot Telegram.</string>
    <string name="appcleaner_filter_threema_label">Threema</string>
    <string name="appcleaner_filter_threema_summary">Faili, kas saņemti, izmantojot Threema.</string>
    <string name="appcleaner_filter_wechat_label">WeChat</string>
    <string name="appcleaner_filter_wechat_summary">Nosūtītie vai saņemtie faili saraksŸ un WeChat momentu.</string>
    <string name="appcleaner_filter_viber_label">Viber</string>
    <string name="appcleaner_filter_viber_summary">Kešoti multivides faili, kas tiek lejupielādēti atkārtoti, skatot tos tērzetājā.</string>
    <string name="appcleaner_filter_qqchat_label">QQ tērzetāja</string>
    <string name="appcleaner_filter_qqchat_summary">Nosūtītie vai saņemtie faili QQ tērzetāja saraksŸ.</string>
