    <string name="appcleaner_filter_whatsapp_sent_summary">您通过 WhatsApp 发送给其他人的文件</string>
    <string name="appcleaner_filter_telegram_label">Telegram 媒体文件</string>
    <string name="appcleaner_filter_telegram_summary">通过 Telegram 接收或发送的文件。</string>
    <string name="appcleaner_filter_threema_label">Threema</string>
    <string name="appcleaner_filter_threema_summary">通过 Threema 接收的文件。</string>
    <string name="appcleaner_filter_wechat_label">微信</string>
    <string name="appcleaner_filter_wechat_summary">在微信聊天和朋友圈中发送或接收的文件。</string>
    <string name="appcleaner_filter_viber_label">Viber</string>
    <string name="appcleaner_filter_viber_summary">在聊天中查看时会再次下载的缓存媒体文件</string>
    <string name="appcleaner_filter_qqchat_label">QQ 聊天</string>
    <string name="appcleaner_filter_qqchat_summary">QQ 聊天对话中发送或收到的文件</string>
