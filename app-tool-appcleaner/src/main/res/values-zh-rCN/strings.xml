<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="appcleaner_explanation_short">某些应用的可删除数据。</string>
    <string name="appcleaner_filter_defaultcachespublic_label">公共默认缓存</string>
    <string name="appcleaner_filter_defaultcachespublic_summary">默认公共应用程序缓存。在旧版本的 Android 系统中，可以在 Android/data 下访问。在系统设置中点击“清除缓存”即可删除。</string>
    <string name="appcleaner_filter_defaultcachesprivate_label">私有默认缓存</string>
    <string name="appcleaner_filter_defaultcachesprivate_summary">默认私有应用程序缓存。在系统设置中点击“清除缓存”即可删除。</string>
    <string name="appcleaner_include_systemapps_label">包含系统应用</string>
    <string name="appcleaner_include_systemapps_summary">在扫描中包含系统应用。</string>
    <string name="appcleaner_include_runningapps_label">包含正在运行的应用</string>
    <string name="appcleaner_include_runningapps_summary">包含正在运行的应用，这可能造成干扰。</string>
    <string name="appcleaner_include_inaccessible_label">包含无法访问的缓存</string>
    <string name="appcleaner_include_inaccessible_summary">包含无法被直接访问的数据，但是这些数据可以通过系统设置删除，也可以通过无障碍服务自动处理。 </string>
    <string name="appcleaner_include_minimumsize_label">最小文件大小</string>
    <string name="appcleaner_include_minimumsize_summary">当可删除数据总大小低于最低值时跳过应用。</string>
    <string name="appcleaner_include_minimumage_label">最短时间</string>
    <string name="appcleaner_include_minimumage_summary">跳过低于最短时间的文件。</string>
    <string name="appcleaner_automation_romtype_detection_label">操作系统类型</string>
    <string name="appcleaner_automation_romtype_detection_summary">如果 SD Maid 没有正确识别您的系统环境，基于无障碍功能的自动化可能会无法工作。因此，您需要在此手动选择你的系统类型。</string>
    <string name="appcleaner_filter_codecache_label">代码缓存</string>
    <string name="appcleaner_filter_codecache_summary">JVM 代码缓存。将字节码块编译成本机代码。</string>
    <string name="appcleaner_filter_advertisement_label">广告数据</string>
    <string name="appcleaner_filter_advertisement_summary">与广告相关的文件，如缓存的媒体文件。</string>
    <string name="appcleaner_filter_bugreporting_label">Bug 反馈</string>
    <string name="appcleaner_filter_bugreporting_summary">与 Bug 反馈有关的数据，如错误日志或故障转储。</string>
    <string name="appcleaner_filter_analytics_label">分析</string>
    <string name="appcleaner_filter_analytics_summary">分析相关数据，例如，您在应用中点击内容的缓存统计信息。</string>
    <string name="appcleaner_filter_hiddencaches_label">隐藏缓存</string>
    <string name="appcleaner_filter_hiddencaches_summary">储存在系统范围之外的通用缓存。</string>
    <string name="appcleaner_filter_thumbnails_label">媒体缩略图</string>
    <string name="appcleaner_filter_thumbnails_summary">图像、视频和音频预览缩略图。</string>
    <string name="appcleaner_filter_gamefiles_label">游戏文件</string>
    <string name="appcleaner_filter_gamefiles_summary">游戏相关的资源文件，在下次启动需要时会重新加载。</string>
    <string name="appcleaner_filter_offlinecache_label">离线缓存</string>
    <string name="appcleaner_filter_offlinecache_summary">为脱机使用的文件，如地图图块。</string>
    <string name="appcleaner_filter_recyclebins_label">回收站</string>
    <string name="appcleaner_filter_recyclebins_summary">删除后被移动到特定文件夹以备恢复的文件。</string>
    <string name="appcleaner_filter_webview_label">Webview 文件</string>
    <string name="appcleaner_filter_webview_summary">应用内置浏览器的缓存文件。</string>
    <string name="appcleaner_filter_shortcutservice_label">应用快捷方式图标</string>
    <string name="appcleaner_filter_shortcutservice_summary">应用快捷方式和分享菜单的缓存图标。</string>
