<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="appcleaner_explanation_short">屬於特定應用程式的無關緊要的檔案。</string>
    <string name="appcleaner_filter_defaultcachespublic_label">公用預設快取</string>
    <string name="appcleaner_filter_defaultcachespublic_summary">預設公用應用程式快取。在較早的 Android 版本上可在 Android/data 下存取，在系統設定中輕觸「清除快取」時將會被刪除。</string>
    <string name="appcleaner_filter_defaultcachesprivate_label">私人預設快取</string>
    <string name="appcleaner_filter_defaultcachesprivate_summary">預設私人應用程式快取。在系統設定中輕觸「清除快取」時將會被刪除。</string>
    <string name="appcleaner_include_systemapps_label">包含系統應用程式</string>
    <string name="appcleaner_include_systemapps_summary">掃描時包含系統應用程式。</string>
    <string name="appcleaner_include_runningapps_label">包含正在執行中的應用程式</string>
    <string name="appcleaner_include_runningapps_summary">包含目前正在執行的應用程式，可能會造成干擾。</string>
    <string name="appcleaner_include_inaccessible_label">包含無法存取的快取</string>
    <string name="appcleaner_include_inaccessible_summary">包含無法直接存取但可以透過系統設定和自動使用無障礙服務刪除的資料。 </string>
    <string name="appcleaner_include_minimumsize_label">最小大小</string>
    <string name="appcleaner_include_minimumsize_summary">跳過無關緊要的資料總和低於最小大小的應用程式。</string>
    <string name="appcleaner_include_minimumage_label">最小期限</string>
    <string name="appcleaner_include_minimumage_summary">跳過存在時間低於最小期限的檔案。</string>
    <string name="appcleaner_automation_romtype_detection_label">作業系統偵測</string>
    <string name="appcleaner_automation_romtype_detection_summary">如果無法正確辨識您的作業系統，SD 女僕以無障礙服務為基礎的自動化動作可能會失敗。使用此設定來覆寫作業系統偵測。</string>
    <string name="appcleaner_filter_codecache_label">程式碼快取</string>
    <string name="appcleaner_filter_codecache_summary">JVM 程式碼快取，被編譯為機器碼的位元組程式碼區塊。</string>
    <string name="appcleaner_filter_advertisement_label">廣告資料</string>
    <string name="appcleaner_filter_advertisement_summary">與廣告相關的檔案，例如已快取的媒體。</string>
    <string name="appcleaner_filter_bugreporting_label">錯誤報告</string>
    <string name="appcleaner_filter_bugreporting_summary">與資料相關的錯誤報告，例如錯誤記錄或當機傾印。</string>
    <string name="appcleaner_filter_analytics_label">分析</string>
    <string name="appcleaner_filter_analytics_summary">與分析相關的資料，例如您在一個應用程式中進行動作而快取的統計資料。</string>
    <string name="appcleaner_filter_hiddencaches_label">已隱藏的快取</string>
    <string name="appcleaner_filter_hiddencaches_summary">儲存在系統可及範圍之外的一般用途快取。</string>
    <string name="appcleaner_filter_thumbnails_label">媒體縮圖</string>
    <string name="appcleaner_filter_thumbnails_summary">圖像、影片和音訊預覽縮圖圖片。</string>
    <string name="appcleaner_filter_gamefiles_label">遊戲檔案</string>
    <string name="appcleaner_filter_gamefiles_summary">與遊戲相關的資源，如果有必要，遊戲將在下次啟動時重新載入。</string>
    <string name="appcleaner_filter_offlinecache_label">離線快取</string>
    <string name="appcleaner_filter_offlinecache_summary">在離線時快取的檔案，例如地圖底圖。</string>
    <string name="appcleaner_filter_recyclebins_label">資源回收桶</string>
    <string name="appcleaner_filter_recyclebins_summary">已被刪除的檔案，但被存放在一個特殊的資料夾中，以允許將它們還原。</string>
    <string name="appcleaner_filter_webview_label">Webview 檔案</string>
    <string name="appcleaner_filter_webview_summary">應用程式中使用 Webview 執行個體所快取的檔案。</string>
    <string name="appcleaner_filter_shortcutservice_label">應用程式捷徑圖示</string>
    <string name="appcleaner_filter_shortcutservice_summary">用於應用程式捷徑與分享選單的快取圖示。</string>
    <string name="appcleaner_filter_whatsapp_backups_label">WhatsApp 備份</string>
    <string name="appcleaner_filter_whatsapp_backups_summary">刪除 WhatsApp 備份的額外複本，僅保留最新的備份。</string>
    <string name="appcleaner_filter_whatsapp_received_summary">您透過 WhatsApp 收到的檔案。</string>
    <string name="appcleaner_filter_whatsapp_received_label">WhatsApp 收到的檔案</string>
    <string name="appcleaner_filter_whatsapp_sent_label">WhatsApp 傳送的檔案</string>
    <string name="appcleaner_filter_whatsapp_sent_summary">從 WhatsApp 向其他人傳送的檔案。</string>
    <string name="appcleaner_filter_telegram_label">Telegram 媒體檔案</string>
    <string name="appcleaner_filter_telegram_summary">透過 Telegram 接收或傳送的檔案。</string>
    <string name="appcleaner_filter_threema_label">Threema</string>
    <string name="appcleaner_filter_threema_summary">透過 Threema 接收的檔案。</string>
    <string name="appcleaner_filter_wechat_label">WeChat</string>
    <string name="appcleaner_filter_wechat_summary">在聊天中傳送或接收的檔案和 WeChat 朋友圈。</string>
    <string name="appcleaner_filter_viber_label">Viber</string>
    <string name="appcleaner_filter_viber_summary">在聊天中檢視時會再次下載的快取媒體檔案。</string>
    <string name="appcleaner_filter_qqchat_label">QQ 聊天</string>
    <string name="appcleaner_filter_qqchat_summary">QQ 聊天對話中傳送或接收的檔案。</string>
