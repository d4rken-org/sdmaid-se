<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="appcleaner_explanation_short">특정 앱과 관련된 제거 가능한 데이터</string>
    <string name="appcleaner_filter_defaultcachespublic_label">공개 기본 캐시</string>
    <string name="appcleaner_filter_defaultcachespublic_summary">기본적인 공개 캐시입니다. 이전 버전의 안드로이드에서는 Android/data에서 접근할 수 있습니다. 시스템 설정에서 \"캐시 삭제\"를 누를 때 제거됩니다.</string>
    <string name="appcleaner_filter_defaultcachesprivate_label">비공개 기본 캐시</string>
    <string name="appcleaner_filter_defaultcachesprivate_summary">공개되지 않은 캐시 파일들입니다. 시스템 설정에서 \"캐시 제거\"를 누르면 제거됩니다.</string>
    <string name="appcleaner_include_systemapps_label">시스템 앱 포함</string>
    <string name="appcleaner_include_systemapps_summary">스캔에 시스템 앱을 포함합니다.</string>
    <string name="appcleaner_include_runningapps_label">실행 중인 앱 포함</string>
    <string name="appcleaner_include_runningapps_summary">스캔 과정에서 영향을 받을 수 있는 실행 중인 앱들을 포함합니다.</string>
    <string name="appcleaner_include_inaccessible_label">접근 불가한 캐시 포함</string>
    <string name="appcleaner_include_inaccessible_summary">직접 접근할 수는 없지만 시스템 설정과 접근성 권한을 이용해 삭제를 자동화할 수 있는 데이터를 포함합니다. </string>
    <string name="appcleaner_include_minimumsize_label">최소 크기</string>
    <string name="appcleaner_include_minimumsize_summary">지정한 크기보다 작은 파일 건너뛰기.</string>
    <string name="appcleaner_include_minimumage_label">최소 기간</string>
    <string name="appcleaner_include_minimumage_summary">선택한 기간보다 짧은 시간동안 존재한 파일을 건너뜁니다.</string>
    <string name="appcleaner_automation_romtype_detection_label">운영 체제 감지</string>
    <string name="appcleaner_automation_romtype_detection_summary">SD Maid가 운영 체제를 바르게 찾지 않았다면 접근성 기반 자동화가 실패할 수 있습니다. 이 설정을 사용하여 감지된 OS를 재정의하세요.</string>
    <string name="appcleaner_filter_codecache_label">앱 코드 내 캐시</string>
    <string name="appcleaner_filter_codecache_summary">JVM 코드 캐시로, 네이티브 코드로 컴파일된 바이트코드 블럭들입니다.</string>
    <string name="appcleaner_filter_advertisement_label">광고 데이터</string>
    <string name="appcleaner_filter_advertisement_summary">다운로드 받아진 광고 영상과 같이 광고와 관련된 데이터입니다.</string>
    <string name="appcleaner_filter_bugreporting_label">버그 리포트</string>
    <string name="appcleaner_filter_bugreporting_summary">에러 로그나 크래시 덤프와 같이 버그 리포트와 관련된 데이터입니다.</string>
    <string name="appcleaner_filter_analytics_label">통계 파일</string>
    <string name="appcleaner_filter_analytics_summary">앱의 사용 통계를 분석하기 위해 만들어진 파일.</string>
    <string name="appcleaner_filter_hiddencaches_label">숨겨진 캐시</string>
    <string name="appcleaner_filter_hiddencaches_summary">시스템이 접근하기 어려운 곳에 저장된 일반적인 캐시 파일입니다.</string>
    <string name="appcleaner_filter_thumbnails_label">미디어 미리보기</string>
    <string name="appcleaner_filter_thumbnails_summary">사진, 영상, 오디오 파일의 미리보기.</string>
    <string name="appcleaner_filter_gamefiles_label">게임 파일</string>
    <string name="appcleaner_filter_gamefiles_summary">다음 실행 때 필요하면 게임이 다시 생성할 파일입니다.</string>
    <string name="appcleaner_filter_offlinecache_label">오프라인 캐시</string>
    <string name="appcleaner_filter_offlinecache_summary">오프라인 상태일 때 사용하기 위해 저장된 파일입니다.</string>
    <string name="appcleaner_filter_recyclebins_label">휴지통</string>
    <string name="appcleaner_filter_recyclebins_summary">삭제되었지만 다시 복구할 때를 대비해 특수 폴더에 저장된 파일입니다.</string>
    <string name="appcleaner_filter_webview_label">웹뷰 파일</string>
    <string name="appcleaner_filter_webview_summary">인앱 브라우저(웹뷰)에서 만들어진 캐시입니다.</string>
    <string name="appcleaner_filter_shortcutservice_label">앱 바로가기 아이콘</string>
    <string name="appcleaner_filter_shortcutservice_summary">앱 바로가기 및 공유 메뉴용 캐시된 아이콘.</string>
    <string name="appcleaner_filter_whatsapp_backups_label">WhatsApp 백업</string>
    <string name="appcleaner_filter_whatsapp_backups_summary">오래된 WhatsApp 백업을 지우고 최신 버전만 남깁니다.</string>
    <string name="appcleaner_filter_whatsapp_received_summary">WhatsApp을 통해 다른 사람으로부터 받은 파일입니다.</string>
    <string name="appcleaner_filter_whatsapp_received_label">WhatsApp 수신 파일</string>
    <string name="appcleaner_filter_whatsapp_sent_label">WhatsApp에서 보낸 파일</string>
    <string name="appcleaner_filter_whatsapp_sent_summary">WhatsApp에서 다른 곳으로 파일 보내</string>
    <string name="appcleaner_filter_telegram_label">텔레그램 미디어 파일</string>
    <string name="appcleaner_filter_telegram_summary">텔레그램에서 보내거나 받은 파일입니다.</string>
    <string name="appcleaner_filter_threema_label">Threema</string>
    <string name="appcleaner_filter_threema_summary">Threema에서 받은 파일입니다.</string>
    <string name="appcleaner_filter_wechat_label">위챗</string>
    <string name="appcleaner_filter_wechat_summary">위챗 대화나 모멘트에서 주고받은 파일들입니다.</string>
    <string name="appcleaner_filter_viber_label">바이버</string>
    <string name="appcleaner_filter_viber_summary">채팅을 열게 되면 자동으로 다운로드되는 캐시된 미디어 파일입니다.</string>
    <string name="appcleaner_filter_qqchat_label">QQ 채팅</string>
    <string name="appcleaner_filter_qqchat_summary">QQ 채팅 대화에서 보내거나 받은 파일입니다.</string>
    <string name="appcleaner_delete_all_confirmation_message">모든 앱의 임시 파일을 제거할까요?</string>
    <plurals name="appcleaner_result_x_items_deleted">
        <item quantity="other">%d개의 불필요한 항목을 삭제했습니다</item>
    </plurals>
    <plurals name="appcleaner_result_x_items_found">
        <item quantity="other">임시 파일 %d개 감지</item>
    </plurals>
    <string name="appcleaner_automation_title">앱정리기 자동화</string>
    <string name="appcleaner_automation_subtitle_default_caches">기본 캐시를 정리하고 있습니다…</string>
    <string name="appcleaner_automation_progress_open_settings">설정 화면 여는 중 (키워드: %s)</string>
    <string name="appcleaner_automation_progress_find_storage">“저장소” 항목 찾는 중 (키워드: %s)</string>
    <string name="appcleaner_automation_progress_find_clear_data">“자료 삭제” 버튼 찾는 중 (키워드: %s)</string>
    <string name="appcleaner_automation_progress_find_clear_cache">“캐시 삭제” 버튼 찾는 중 (키워드: %s)</string>
    <string name="appcleaner_item_caches_inaccessible_title">기본 캐시</string>
    <string name="appcleaner_item_caches_inaccessible_body">앱의 캐시 파일입니다. 직접적인 접근은 어렵지만, 접근성 서비스 등을 통해 간접적으로 지울 수 있습니다.</string>
    <string name="appcleaner_automation_unavailable_title">접근성 서비스를 사용할 수 없습니다.</string>
    <string name="appcleaner_automation_unavailable_body">직접 접근할 수 없는 캐시를 지우려면 SD Maid의 접근성 서비스가 필요하지만, 사용할 수 없었습니다. 사용하고 싶지 않다면 \"접근 불가한 캐시 포함\" 옵션을 꺼주세요.</string>
    <string name="appcleaner_junk_userprofile_label">사용자</string>
    <string name="appcleaner_delete_confirmation_message_x">%s의 임시 파일을 제거할까요?</string>
    <plurals name="appcleaner_delete_confirmation_message_selected_x_items">
        <item quantity="other">%d 개의 선택된 앱의 임시 파일을 제거할까요?</item>
    </plurals>
    <string name="appcleaner_progress_shizuku_deleting_caches">Shizuku를 이용해 캐시 삭제 중</string>
    <string name="appcleaner_progress_determining_inaccessible_caches">접근할 수 없는 캐시 확인 중</string>
    <string name="appcleaner_automation_error_locked_appcache_title">캐시 지우기를 사용할 수 없음</string>
    <string name="appcleaner_automation_error_locked_appcache_body">시스템이 이 앱의 \"캐시 지우기\" 버튼을 비활성화했습니다. 캐시 지우기 속도를 높이려면 제외하세요.</string>
    <string name="appcleaner_automation_error_securitycenter_permission_title">시스템 앱이 잘못 구성됨</string>
    <string name="appcleaner_automation_error_securitycenter_permission_body">HyperOS의 보안 앱(com.miui.securitycenter)에 사용 통계 권한(GET_USAGE_STATS)이 없습니다. 이로 인해 앱 세부정보의 \"데이터 지우기\"와 접근성을 통한 캐시 지우기 등의 기능이 손상됩니다. 전체 기능을 복원하려면 권한을 부여하세요.</string>
    <string name="appcleaner_forcestop_before_clearing_label">삭제 전 강제 종료</string>
    <string name="appcleaner_forcestop_before_clearing_summary">캐시를 삭제하기 전에 앱을 강제 종료합니다. 일부 앱의 캐시를 삭제하는 데 도움이 될 수 있지만, 앱이 오작동하거나 수동 재시작이 필요할 수 있습니다.</string>
    <string name="appcleaner_progress_force_stopping">앱 강제 종료 중…</string>
</resources>
