    <string name="appcleaner_automation_title">பயன்பாட்டு சுத்தி தானியங்கியமாக்கம்</string>
    <string name="appcleaner_automation_subtitle_default_caches">இயல்புநிலை துளையகங்களை அழிக்கிறது…</string>
    <string name="appcleaner_automation_progress_find_storage">\"சேமிப்பிடம்\" பதிவைத் தேடுகிறது (சொல்தொடர்கள்: %s)</string>
    <string name="appcleaner_automation_progress_find_clear_data">\"தரவுகளை அழிக்கும்\" பட்டனைத் தேடுகிறது (சொல்தொடர்கள்: %s)</string>
    <string name="appcleaner_automation_progress_find_clear_cache">\"துளையகத்தை அழிக்கும்\" பட்டனைத் தேடுகிறது (சொல்தொடர்கள்: %s)</string>
    <string name="appcleaner_item_caches_inaccessible_title">இயல்பு கேச்கள்</string>
    <string name="appcleaner_item_caches_inaccessible_body">பொது மற்றும் தனியார் இயல்புநிலை துளையகங்கள். நேரடியாக அணுகலாம் இல்லை, ஆனால் மற்றவாறு நீக்கலாம் (உதா.: அக்செஸிபிலிட்டி சேவை மூலம்).</string>
    <string name="appcleaner_automation_unavailable_title">அணுகல் சேவை கிடைக்கவில்லை</string>
    <string name="appcleaner_automation_unavailable_body">அணுக முடியாத கேச்களை நீக்குவதற்கு SD Maid இன் அணுகல் சேவை தேவை, ஆனால் அது கிடைக்கவில்லை. நீங்கள் அதைப் பயன்படுத்த விரும்பவில்லை என்றால்: \"அணுக முடியாத கேச்களை சேர்க்கவும்\" விருப்பத்தை அவலாக்கவும்.</string>
    <string name="appcleaner_delete_confirmation_message_x">%s க்கான தேவையில்லாத கோப்புகளை நீக்கவுமா?</string>
    <plurals name="appcleaner_delete_confirmation_message_selected_x_items">
        <item quantity="one">%d தேர்ந்தெடுத்த பயன்பாடுக்கான தேவையில்லாத கோப்புகளை நீக்கவுமா?</item>
        <item quantity="other">%d தேர்ந்தெடுத்த பயன்பாடுகளுக்கான தேவையில்லாத கோப்புகளை நீக்கவுமா?</item>
    </plurals>
    <string name="appcleaner_progress_shizuku_deleting_caches">Shizuku பயன்படுத்தி துளையகங்களை நீக்குகிறது</string>
    <string name="appcleaner_progress_determining_inaccessible_caches">அணுக முடியாத கேச்களை தீர்மானிக்கிறது</string>
    <string name="appcleaner_automation_error_locked_appcache_title">கேச் நீக்குதல் கிடைக்கவில்லை</string>
    <string name="appcleaner_automation_error_locked_appcache_body">ஈ பயன்பாடுக்கான \"துளையகத்தை அழிக்கும்\" பட்டனை கணிநி முடக்கியுள்ளது. துளையக அழிப்பை வேகப்படுத்த இதை விலக்கி வைக்கவும்.</string>
    <string name="appcleaner_automation_error_securitycenter_permission_title">கணினி பயன்பாடு தவறாக அமைக்கப்பட்டுள்ளது</string>
    <string name="appcleaner_automation_error_securitycenter_permission_body">HyperOS இன் பாதுகாப்பு பயன்பாட்டில் (com.miui.securitycenter) பயன்பாட்டு புள்ளிவிவர அனுமதி (GET_USAGE_STATS) இல்லை. இது பயன்பாட்டு விவரங்களில் \"தரவை அழி\" மற்றும் அணுகல் வழியாக கேச் அழிப்பு போன்ற அம்சங்களை உடைக்கிறது. முழு செயல்பாட்டை மீட்டமைக்க அனுமதியை வழங்கவும்.</string>
    <string name="appcleaner_forcestop_before_clearing_label">அழிக்கும் முன் கட்டாய நிறுத்தம்</string>
    <string name="appcleaner_forcestop_before_clearing_summary">தற்காலிக சேமிப்பை அழிக்கும் முன் செயலிகளை கட்டாயமாக நிறுத்து. சில செயலிகளின் தற்காலிக சேமிப்பை அழிக்க உதவலாம், ஆனால் செயலிகள் தவறாக செயல்படலாம் மற்றும் கைமுறையாக மறுதொடக்கம் தேவைப்படலாம்.</string>
    <string name="appcleaner_progress_force_stopping">செயலிகளை கட்டாயமாக நிறுத்துகிறது…</string>
</resources>
