<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="appcleaner_explanation_short">குறிப்பிட்ட பயன்பாடுகளுக்கு செல்லும் தேவையில்லாத தரவுகள்.</string>
    <string name="appcleaner_filter_defaultcachespublic_label">பொது இயல்பு கேச்கள்</string>
    <string name="appcleaner_filter_defaultcachespublic_summary">இயல்பு பொது பயன்பாட்டு கேச்கள். பழைய Android பதிப்புகளில் Android/data கீழ் அணுகக்கூடியது. கணினி அமைப்புகளில் \"கேச் நீக்கு\" என்பதை தட்டும்போது நீக்கப்படும்.</string>
    <string name="appcleaner_filter_defaultcachesprivate_label">தனியார் இயல்பு கேச்கள்</string>
    <string name="appcleaner_filter_defaultcachesprivate_summary">இயல்பு தனியார் பயன்பாட்டு கேச்கள். கணினி அமைப்புகளில் \"கேச் நீக்கு\" என்பதை தட்டும்போது நீக்கப்படும்.</string>
    <string name="appcleaner_include_systemapps_label">கணினி பயன்பாடுகளை சேர்க்கவும்</string>
    <string name="appcleaner_include_systemapps_summary">ஸ்கேனில் கணினி பயன்பாடுகளை சேர்க்கவும்.</string>
    <string name="appcleaner_include_runningapps_label">இயங்கும் பயன்பாடுகளை சேர்க்கவும்</string>
    <string name="appcleaner_include_runningapps_summary">தற்போது இயங்கும் பயன்பாடுகளை சேர்க்கவும், இது தடையை ஏற்படுத்தலாம்.</string>
    <string name="appcleaner_include_inaccessible_label">அணுக முடியாத கேச்களை சேர்க்கவும்</string>
    <string name="appcleaner_include_inaccessible_summary">நேரடியாக அணுக முடியாத மற்றும் கணினி அமைப்புகள் வழியாகவும் அணுகல் சேவையைப் பயன்படுத்தி தானியங்கியமாக்கவும் நீக்க முடியும் தரவை சேர்க்கவும். </string>
    <string name="appcleaner_include_minimumsize_label">குறைந்தபட்ச அளவு</string>
    <string name="appcleaner_include_minimumsize_summary">செலவிடக்கூடிய தரவின் கூட்டுத்தொகை குறைந்தபட்சத்தை விட குறைவாக உள்ள பயன்பாடுகளை தவிர்க்கவும்.</string>
    <string name="appcleaner_include_minimumage_label">குறைந்தபட்ச வயது</string>
    <string name="appcleaner_include_minimumage_summary">குறைந்தபட்ச வயதை விட இளைய கோப்புகளை தவிர்க்கவும்.</string>
    <string name="appcleaner_automation_romtype_detection_label">இயக்க கணினி கண்டறிதல்</string>
    <string name="appcleaner_automation_romtype_detection_summary">SD Maid உங்கள் OS ஐ சரியாக கண்டறியவில்லை என்றால் அணுகல் அடிப்படையிலான தானியங்கவழி தேற்றத்தில் இருக்கலாம். கண்டறியப்பட்ட OS ஐ மீற இந்த அமைப்பைப் பயன்படுத்தவும்.</string>
    <string name="appcleaner_filter_codecache_label">குறியீடு கேச்</string>
    <string name="appcleaner_filter_codecache_summary">JVM கோட் துளையகம். நேடிவ் கோட்டாக தொகுக்கப்பட்ட பைட்ட்கோட் தொகுப்புகள்.</string>
    <string name="appcleaner_filter_advertisement_label">விளம்பர தரவு</string>
    <string name="appcleaner_filter_advertisement_summary">விளம்பரங்களுடன் தொடர்புடைய கோப்புகள், உதா.: துளையகமுற்படுத்தப்பட்ட மீடியா.</string>
    <string name="appcleaner_filter_bugreporting_label">பிழை அறிக்கையிடல்</string>
    <string name="appcleaner_filter_bugreporting_summary">பிழை பதிவு தொடர்புடைய தரவுகள், உதா.: பிழை பதிவுகள் அல்லது க்ராஷ் டம்ப்கள்.</string>
    <string name="appcleaner_filter_analytics_label">பகுப்பாய்வு</string>
    <string name="appcleaner_filter_analytics_summary">ஆய்வுக்கு தொடர்புடைய தரவுகள், உதா.: நீங்கள் ஒரு பயன்பாடில் தடவுகிறது வரெயில்லான தத்தல் ஆங்கிலம் துளையகமுற்படுத்தப்பட்டது.</string>
    <string name="appcleaner_filter_hiddencaches_label">மறைந்த கேச்கள்</string>
    <string name="appcleaner_filter_hiddencaches_summary">கணினியின் அளவில் வெளியே சேமிக்கப்பட்ட பொது நோக்க கேச்கள்.</string>
    <string name="appcleaner_filter_thumbnails_label">ஊடக சிறுபடங்கள்</string>
    <string name="appcleaner_filter_thumbnails_summary">படம், விடியோ மற்றும் ஆடியோ முன்னோட்ட கிளைக்குறி படம்.</string>
    <string name="appcleaner_filter_gamefiles_label">விளையாட்டு கோப்புகள்</string>
    <string name="appcleaner_filter_gamefiles_summary">விளையாட்டு தொடர்புடைய வளங்குகள், தேவையேற்பட்டால் விளையாட்டு அடுத்த தொடக்கத்தில் முற்படி ஏற்றும்.</string>
    <string name="appcleaner_filter_offlinecache_label">ஆஃப்லைன் கேச்</string>
    <string name="appcleaner_filter_offlinecache_summary">ஆஃலைன் மானிலையில் பயன்படுத்துவதற்காக சேமிக்கப்பட்ட கோப்புகள், உதா.: வரைபட தில்கள்.</string>
    <string name="appcleaner_filter_recyclebins_label">மீட்டுறுஞ்சு தொட்டிகள்</string>
    <string name="appcleaner_filter_recyclebins_summary">நீக்கப்பட்ட ஆனால் மீள்பெற அனுமதிக்க ஒரு சிறப்பு கோப்பையில் இடப்பட்ட கோப்புகள்.</string>
    <string name="appcleaner_filter_webview_label">Webview கோப்புகள்</string>
    <string name="appcleaner_filter_webview_summary">பயன்பாடுகள் உள்ளே பயன்படுத்தப்படும் Webview நிகழ்வுகளால் துளையகமுற்படுத்தப்பட்ட கோப்புகள்.</string>
    <string name="appcleaner_filter_shortcutservice_label">செயலி குறுக்குவழி சின்னங்கள்</string>
    <string name="appcleaner_filter_shortcutservice_summary">செயலி குறுக்குவழிகள் மற்றும் பகிர்வு மெனுக்களுக்கான தற்காலிக சின்னங்கள்.</string>
    <string name="appcleaner_filter_whatsapp_backups_label">WhatsApp கிட்டுப்பிட்டு நகல்கள்</string>
    <string name="appcleaner_filter_whatsapp_backups_summary">WhatsApp கிட்டுப்பிட்டு நகல்களின் கூடுதலான பதிப்புகளை நீக்கி செம்மையானதை மட்டும் வைத்திருக்கவும்.</string>
    <string name="appcleaner_filter_whatsapp_received_summary">WhatsApp ମனவர் மூலம் உங்களுக்கு வந்த கோப்புகள்.</string>
    <string name="appcleaner_filter_whatsapp_received_label">WhatsApp பெற்ற கோப்புகள்</string>
    <string name="appcleaner_filter_whatsapp_sent_label">WhatsApp அனுப்பிய கோப்புகள்</string>
    <string name="appcleaner_filter_whatsapp_sent_summary">WhatsApp இருந்து மற்றவர்களுக்கு அனுப்பப்பட்ட கோப்புகள்.</string>
    <string name="appcleaner_filter_telegram_label">Telegram ஊடக கோப்புகள்</string>
    <string name="appcleaner_filter_telegram_summary">Telegram வழியாக பெற்றது அல்லது அனுப்பிய கோப்புகள்.</string>
    <string name="appcleaner_filter_threema_label">Threema</string>
    <string name="appcleaner_filter_threema_summary">Threema வழியாக பெற்ற கோப்புகள்.</string>
    <string name="appcleaner_filter_wechat_label">WeChat</string>
    <string name="appcleaner_filter_wechat_summary">உரையாடல்களில் மற்றும் WeChat தறுணிகளில் அனுப்பிய அல்லது பெற்ற கோப்புகள்.</string>
    <string name="appcleaner_filter_viber_label">Viber</string>
    <string name="appcleaner_filter_viber_summary">சாட்டில் பார்க்கும்போது மீண்டும் இறக்கடுக்கப்படும் துளையகமுற்படுத்தப்பட்ட மீடியா கோப்புகள்.</string>
    <string name="appcleaner_filter_qqchat_label">QQ சாட்</string>
    <string name="appcleaner_filter_qqchat_summary">QQ சாட் உரையாடல்களில் அனுப்பிய அல்லது பெற்ற கோப்புகள்.</string>
    <string name="appcleaner_delete_all_confirmation_message">அனைத்து பயன்பாடுகளுக்கும் தேவையில்லாத பொருட்களை நீக்கவுமா?</string>
