<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="appcleaner_explanation_short">Aplikazio jakin batzuei dagozkien datu soberakinak.</string>
    <string name="appcleaner_filter_defaultcachespublic_label">Cache lehenetsiak publikoak</string>
    <string name="appcleaner_filter_defaultcachespublic_summary">Aplikazioen cache lehenetsiak publikoak. Android/data atalean eskuragarri Android bertsio zaharretan. Ezabatuta \"Garbitu cachea\" sakatzean sistemaren ezarpenetan.</string>
    <string name="appcleaner_filter_defaultcachesprivate_label">Cache lehenetsiak pribatuak</string>
    <string name="appcleaner_filter_defaultcachesprivate_summary">Aplikazioen cache lehenetsiak pribatuak. Ezabatuta \"Garbitu cachea\" sakatzean sistemaren ezarpenetan.</string>
    <string name="appcleaner_include_systemapps_label">Sartu sistema-aplikazioak</string>
    <string name="appcleaner_include_systemapps_summary">Sartu sistema-aplikazioak eskanaketara.</string>
    <string name="appcleaner_include_runningapps_label">Sartu exekutatzen ari diren aplikazioak</string>
    <string name="appcleaner_include_runningapps_summary">Sartu egun exekutatzen ari diren aplikazioak, interferentziak sor ditzaketenak.</string>
    <string name="appcleaner_include_inaccessible_label">Sartu cache eskuraezinakoak</string>
    <string name="appcleaner_include_inaccessible_summary">Sartu zuzenean eskuratu ezin daitekeen baina sistemaren ezarpenen bidez ezabatu eta irisgarritasun-zerbitzu baten bidez automatizatu daitekeen datua.</string>
    <string name="appcleaner_include_minimumsize_label">Gutxieneko tamaina</string>
    <string name="appcleaner_include_minimumsize_summary">Saltatu aplikazioak non datu soberakinen batura gutxienekoa baino txikiagoa den.</string>
    <string name="appcleaner_include_minimumage_label">Gutxieneko adina</string>
    <string name="appcleaner_include_minimumage_summary">Saltatu gutxieneko adina baino gazteak diren fitxategiak.</string>
    <string name="appcleaner_automation_romtype_detection_label">Sistema eragilearen detekzioa</string>
    <string name="appcleaner_automation_romtype_detection_summary">Irisgarritasunean oinarritutako automatizazioak huts egin dezake SD Maid-ek zure SE zuzen detektatzen ez badu. Erabili ezarpen hau detektatutako SE gainidazteko.</string>
    <string name="appcleaner_filter_codecache_label">Kode-cachea</string>
    <string name="appcleaner_filter_codecache_summary">JVMren kode-cachea. Kode natibotan konpilatutako bytecode blokeak.</string>
    <string name="appcleaner_filter_advertisement_label">Iragarki-datuak</string>
    <string name="appcleaner_filter_advertisement_summary">Iragarkiekin lotutako fitxategiak, adibidez, cachean gordetako multimedia.</string>
    <string name="appcleaner_filter_bugreporting_label">Errore-txostena</string>
    <string name="appcleaner_filter_bugreporting_summary">Errore-txostenarekin lotutako datuak, adibidez, errore-erregistroak edo crash-dumpak.</string>
    <string name="appcleaner_filter_analytics_label">Analitika</string>
    <string name="appcleaner_filter_analytics_summary">Analitikarekin lotutako datuak, adibidez, aplikazioan sakatzen duzunaren estatistika cacheatuak.</string>
    <string name="appcleaner_filter_hiddencaches_label">Cache ezkutuak</string>
    <string name="appcleaner_filter_hiddencaches_summary">Sistemaren irispidez kanpo gordeta dauden helburu orokorreko cacheak.</string>
    <string name="appcleaner_filter_thumbnails_label">Multimediaren miniaturak</string>
    <string name="appcleaner_filter_thumbnails_summary">Irudi, bideo eta audio aurrebistako miniatura irudiak.</string>
    <string name="appcleaner_filter_gamefiles_label">Joko-fitxategiak</string>
    <string name="appcleaner_filter_gamefiles_summary">Jokoak hurrengo abiaraztean beharrezkoa bada berriro kargatuko lituzkeen jokoarekin lotutako baliabideak.</string>
    <string name="appcleaner_filter_offlinecache_label">Lineaz kanpoko cachea</string>
    <string name="appcleaner_filter_offlinecache_summary">Lineaz kanpo erabiltzeko gordeta dauden fitxategiak, adibidez, mapa-lautak.</string>
    <string name="appcleaner_filter_recyclebins_label">Birziklapen-ontziak</string>
    <string name="appcleaner_filter_recyclebins_summary">Ezabatu diren baina karpeta berezi batera eraman diren fitxategiak, berreskuratu ahal izateko.</string>
    <string name="appcleaner_filter_webview_label">Webview fitxategiak</string>
    <string name="appcleaner_filter_webview_summary">Aplikazioetan erabilitako Webview instantziek cacheatu dituzten fitxategiak.</string>
    <string name="appcleaner_filter_shortcutservice_label">Aplikazio-lasterbideen ikonoak</string>
    <string name="appcleaner_filter_shortcutservice_summary">Aplikazio-lasterbideen eta partekatu-menuen ikono cacheatuak.</string>
    <string name="appcleaner_filter_whatsapp_backups_label">WhatsApp-en babeskopiak</string>
    <string name="appcleaner_filter_whatsapp_backups_summary">Ezabatu WhatsApp-en babeskopien ale soberakinak eta gorde azkenekoa bakarrik.</string>
    <string name="appcleaner_filter_whatsapp_received_summary">WhatsApp-en bidez jaso dituzun fitxategiak.</string>
    <string name="appcleaner_filter_whatsapp_received_label">WhatsApp-en bidez jasotako fitxategiak</string>
    <string name="appcleaner_filter_whatsapp_sent_label">WhatsApp-en bidez bidalitako fitxategiak</string>
    <string name="appcleaner_filter_whatsapp_sent_summary">WhatsApp-etik besteei bidalitako fitxategiak.</string>
    <string name="appcleaner_filter_telegram_label">Telegram-eko multimedia-fitxategiak</string>
    <string name="appcleaner_filter_telegram_summary">Telegram-en bidez jasotako edo bidalitako fitxategiak.</string>
    <string name="appcleaner_filter_threema_label">Threema</string>
    <string name="appcleaner_filter_threema_summary">Threema-ren bidez jasotako fitxategiak.</string>
    <string name="appcleaner_filter_wechat_label">WeChat</string>
    <string name="appcleaner_filter_wechat_summary">WeChat-eko elkarrizketetan eta momentuetan bidalitako edo jasotako fitxategiak.</string>
    <string name="appcleaner_filter_viber_label">Viber</string>
    <string name="appcleaner_filter_viber_summary">Cachean gordetako multimedia-fitxategiak, txatean ikustean berriro deskargatzen direnak.</string>
    <string name="appcleaner_filter_qqchat_label">QQ txata</string>
    <string name="appcleaner_filter_qqchat_summary">QQ txateko elkarrizketetan bidalitako edo jasotako fitxategiak.</string>
    <string name="appcleaner_delete_all_confirmation_message">Ezabatu aplikazio guztietako datu soberakinak?</string>
    <plurals name="appcleaner_result_x_items_deleted">
        <item quantity="one">%d datu soberakin ezabatu da</item>
        <item quantity="other">%d datu soberakin ezabatu dira</item>
    </plurals>
    <plurals name="appcleaner_result_x_items_found">
        <item quantity="one">%d datu soberakin aurkitu da</item>
        <item quantity="other">%d datu soberakin aurkitu dira</item>
    </plurals>
    <string name="appcleaner_automation_title">AppCleaner-en automatizazioa</string>
    <string name="appcleaner_automation_subtitle_default_caches">Cache lehenetsiak garbitzen…</string>
    <string name="appcleaner_automation_progress_find_storage">\"Biltegiratzea\" sarrera bilatzen (gako-hitzak: %s)</string>
    <string name="appcleaner_automation_progress_find_clear_data">\"Garbitu datuak\" botoia bilatzen (gako-hitzak: %s)</string>
    <string name="appcleaner_automation_progress_find_clear_cache">\"Garbitu cachea\" botoia bilatzen (gako-hitzak: %s)</string>
    <string name="appcleaner_item_caches_inaccessible_title">Cache lehenetsiak</string>
    <string name="appcleaner_item_caches_inaccessible_body">Cache lehenetsi publikoak eta pribatuak. Ez dira zuzenean eskuragarri, baina zeharka ezabatu daitezke (adibidez, irisgarritasun-zerbitzuaren bidez).</string>
    <string name="appcleaner_automation_unavailable_title">Irisgarritasun-zerbitzua erabilgarri ez</string>
    <string name="appcleaner_automation_unavailable_body">Cache eskuraezinakoak garbitzeak SD Maid-en irisgarritasun-zerbitzua eskatzen du, baina erabilgarri ez zegoen. Ez baduzu erabili nahi: Desgaitu \"Sartu cache eskuraezinakoak\" aukera.</string>
    <string name="appcleaner_delete_confirmation_message_x">Ezabatu %s-ren datu soberakinak?</string>
    <plurals name="appcleaner_delete_confirmation_message_selected_x_items">
        <item quantity="one">Ezabatu %d hautatutako aplikazioaren datu soberakinak?</item>
        <item quantity="other">Ezabatu %d hautatutako aplikazioen datu soberakinak?</item>
    </plurals>
    <string name="appcleaner_progress_shizuku_deleting_caches">Cacheak ezabatzen Shizuku erabiliz</string>
    <string name="appcleaner_progress_determining_inaccessible_caches">Cache eskuraezinakoak zehaztea</string>
    <string name="appcleaner_automation_error_locked_appcache_title">Cachea garbitzea erabilgarri ez</string>
    <string name="appcleaner_automation_error_locked_appcache_body">Sistemak \"Garbitu cachea\" botoia desgaitu du aplikazio honentzat. Baztertu cachea garbitzea azkartasunez egiteko.</string>
    <string name="appcleaner_automation_error_securitycenter_permission_title">Sistema-aplikazioa gaizki konfiguratuta</string>
    <string name="appcleaner_automation_error_securitycenter_permission_body">HyperOS-en Segurtasun aplikazioak (com.miui.securitycenter) GET_USAGE_STATS (Erabilera-estatistikak) baimena falta du. Honek aplikazioaren xehetasunetan \"Garbitu datuak\" bezalako funtzioak eta irisgarritasun bidezko cachea garbitzea hausten du. Eman baimena funtzionaltasun osoa berreskuratzeko.</string>
    <string name="appcleaner_forcestop_before_clearing_label">Behartu gelditzera garbitu aurretik</string>
    <string name="appcleaner_forcestop_before_clearing_summary">Behartu aplikazioak gelditzera haien cachea garbitu aurretik. Zenbait aplikazioren cacheak garbitzen lagun dezake, baina aplikazioak gaizki funtziona dezakete eta eskuz berrabiarazi behar izatea eragin dezake.</string>
    <string name="appcleaner_progress_force_stopping">Aplikazioak geldiarazten…</string>
</resources>
