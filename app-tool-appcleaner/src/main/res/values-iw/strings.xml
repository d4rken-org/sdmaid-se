    <string name="appcleaner_item_caches_inaccessible_title">מטמון ברירת מחדל</string>
    <string name="appcleaner_item_caches_inaccessible_body">מטמון ברירת מחדל ציבורי ופרטי. לא נגיש ישירות, אבל ניתן למחוק בעקיפין (למשל באמצעות שירות נגישות).</string>
    <string name="appcleaner_automation_unavailable_title">שירות הנגישות לא זמין</string>
    <string name="appcleaner_automation_unavailable_body">ניקוי מטמונים בלתי נגישים מצריך את שירות הנגישות של SD Maid, אך הוא לא היה זמין. אם אינך רוצה להשתמש בו: השבת את האפשרות \"כלול מטמונים בלתי נגישים\".</string>
