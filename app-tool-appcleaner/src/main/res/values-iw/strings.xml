<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="appcleaner_explanation_short">נתונים זמניים השייכים לאפליקציות ספציפיות.</string>
    <string name="appcleaner_filter_defaultcachespublic_label">מטמון ברירת מחדל ציבורי</string>
    <string name="appcleaner_filter_defaultcachespublic_summary">מטמון ברירת מחדל של אפליקציות ציבוריות. נגיש תחת Android/data בגרסאות אנדרואיד ישנות יותר. נמחק בעת הקשה על \"נקה מטמון\" בהגדרות המערכת.</string>
    <string name="appcleaner_filter_defaultcachesprivate_label">מטמון ברירת מחדל פרטי</string>
    <string name="appcleaner_filter_defaultcachesprivate_summary">מטמון ברירת מחדל של אפליקציות פרטיות. נמחק בעת הקשה על \"נקה מטמון\" בהגדרות המערכת.</string>
    <string name="appcleaner_include_systemapps_label">לכלול אפליקציות מערכת</string>
    <string name="appcleaner_include_systemapps_summary">כלול אפליקציות מערכת בסריקה.</string>
    <string name="appcleaner_include_runningapps_label">כלול אפליקציות פועלות</string>
    <string name="appcleaner_include_runningapps_summary">כלול אפליקציות שפועלות כעת שעלולות לגרום להפרעה.</string>
    <string name="appcleaner_include_inaccessible_label">כלול מטמונים בלתי נגישים</string>
    <string name="appcleaner_include_inaccessible_summary">כלול נתונים שלא ניתן לגשת אליהם ישירות אך ניתן למחוק אותם באמצעות הגדרות המערכת ואוטומטיות באמצעות שירות נגישות. </string>
    <string name="appcleaner_include_minimumsize_label">גודל מינימלי</string>
    <string name="appcleaner_include_minimumsize_summary">דלג על אפליקציות שבהן סכום הנתונים הזמניים נמוך מהמינימום.</string>
    <string name="appcleaner_include_minimumage_label">גיל מינימלי</string>
    <string name="appcleaner_include_minimumage_summary">דלג על קבצים צעירים מהגיל המינימלי.</string>
    <string name="appcleaner_automation_romtype_detection_label">זיהוי מערכת הפעלה</string>
    <string name="appcleaner_automation_romtype_detection_summary">אוטומציה מבוססת נגישות עלולה להיכשל אם SD Maid לא תזהה את מערכת ההפעלה שלך כראוי. השתמש בהגדרה זו כדי לעקוף את מערכת ההפעלה שזוהתה.</string>
    <string name="appcleaner_filter_codecache_label">מטמון קוד</string>
    <string name="appcleaner_filter_codecache_summary">מטמון קוד JVM. בלוקים של קוד בתים הידור לקוד מקורי.</string>
    <string name="appcleaner_filter_advertisement_label">נתוני פרסומות</string>
    <string name="appcleaner_filter_advertisement_summary">קבצים הקשורים לפרסומות, למשל. מדיה שמורה במטמון.</string>
    <string name="appcleaner_filter_bugreporting_label">דיווחים על תקלות</string>
    <string name="appcleaner_filter_bugreporting_summary">נתונים הקשורים לדיווח על באגים, למשל. יומני שגיאות או קריסת dump.</string>
    <string name="appcleaner_filter_analytics_label">ניתוח</string>
    <string name="appcleaner_filter_analytics_summary">נתונים הקשורים לניתוח, למשל. נתונים סטטיסטיים שמור עבור מה שאתה מקיש באפליקציה.</string>
    <string name="appcleaner_filter_hiddencaches_label">מטמונים מוסתרים</string>
    <string name="appcleaner_filter_hiddencaches_summary">מטמונים לשימוש כללי המאוחסנים מחוץ להישג ידה של המערכת.</string>
    <string name="appcleaner_filter_thumbnails_label">תמונות ממוזערות של מדיה</string>
    <string name="appcleaner_filter_thumbnails_summary">תמונות תצוגה מקדימה של תמונה, וידאו ואודיו.</string>
    <string name="appcleaner_filter_gamefiles_label">קבצי משחק</string>
    <string name="appcleaner_filter_gamefiles_summary">משאבים הקשורים למשחק וגורמים לו להיטען מחדש מהר יותר בהשקה הבאה במידת הצורך.</string>
    <string name="appcleaner_filter_offlinecache_label">מטמון לא מקוון</string>
    <string name="appcleaner_filter_offlinecache_summary">קבצים המאוחסנים לשימוש במצב לא מקוון, למשל. אריחי מפה.</string>
    <string name="appcleaner_filter_recyclebins_label">סלי מיחזור</string>
    <string name="appcleaner_filter_recyclebins_summary">קבצים שנמחקו אך הוכנסו לתיקיה מיוחדת כדי לאפשר לשחזר אותם.</string>
    <string name="appcleaner_filter_webview_label">קבצי תצוגת אינטרנט</string>
    <string name="appcleaner_filter_webview_summary">קבצים שנשמרו במטמון על ידי מופעי Webview בשימוש באפליקציות.</string>
    <string name="appcleaner_filter_shortcutservice_label">סמלי קיצורי דרך לאפליקציות</string>
    <string name="appcleaner_filter_shortcutservice_summary">סמלים ששמורים במטמון עבור קיצורי דרך לאפליקציות ותפריטי שיתוף.</string>
    <string name="appcleaner_filter_whatsapp_backups_label">גיבוי וואטסאפ</string>
    <string name="appcleaner_filter_whatsapp_backups_summary">מחק עותקים נוספים של גיבויי WhatsApp ושמור רק את העדכניים ביותר.</string>
    <string name="appcleaner_filter_whatsapp_received_summary">קבצים שהתקבלו מאנשים דרך וואטסאפ.</string>
    <string name="appcleaner_filter_whatsapp_received_label">קבצים שהתקבלו בוואטסאפ</string>
    <string name="appcleaner_filter_whatsapp_sent_label">קבצים שנשלחו בוואטסאפ</string>
    <string name="appcleaner_filter_whatsapp_sent_summary">קבצים שנשלחו מוואטסאפ לאחרים.</string>
    <string name="appcleaner_filter_telegram_label">קבצי מדיה של טלגרם</string>
    <string name="appcleaner_filter_telegram_summary">קבצים שהתקבלו או נשלחו דרך טלגרם.</string>
    <string name="appcleaner_filter_threema_label">Threema</string>
    <string name="appcleaner_filter_threema_summary">קבצים שהתקבלו דרך Threema.</string>
    <string name="appcleaner_filter_wechat_label">WeChat</string>
    <string name="appcleaner_filter_wechat_summary">קבצים שנשלחו או התקבלו בשיחות וברגעי WeChat.</string>
    <string name="appcleaner_filter_viber_label">Viber</string>
    <string name="appcleaner_filter_viber_summary">קבצי מדיה מאוחסנים במטמון שהורדו שוב בעת צפייה בצ\'אט.</string>
    <string name="appcleaner_filter_qqchat_label">QQ chat</string>
    <string name="appcleaner_filter_qqchat_summary">קבצים שנשלחו או התקבלו בשיחות צ\'אט QQ.</string>
