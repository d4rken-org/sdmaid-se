    <string name="squeezer_onboarding_video_quality_disclaimer">യഥാർത്ഥ വീഡിയോ ഗുണമേൻമ വ്യത്യാസപ്പെടാം</string>
    <string name="squeezer_onboarding_quality_label">ഗുണമേൻമ: %d%%</string>
