<resources>
    <string name="deduplicator_explanation_short">നിങ്ങളുടെ ഉപകരണത്തിൽ ഡ്യൂപ്ലിക്കേറ്റ് ഡേറ്റ കണ്ടെത്തുക.</string>
    <plurals name="deduplicator_result_x_clusters_processed">
        <item quantity="one">%d ഡ്യൂപ്ലിക്കേറ്റ് ഡിലീറ്റ് ചെയ്തു</item>
        <item quantity="other">%d ഡ്യൂപ്ലിക്കേറ്റുകൾ ഡിലീറ്റ് ചെയ്തു</item>
    </plurals>
    <plurals name="deduplicator_result_x_clusters_found">
        <item quantity="one">%d ഡ്യൂപ്ലിക്കേറ്റ് സെറ്റ് കണ്ടെത്തി</item>
        <item quantity="other">%d ഡ്യൂപ്ലിക്കേറ്റ് സെറ്റുകൾ കണ്ടെത്തി</item>
    </plurals>
    <string name="deduplicator_protection_deleteall_allowed_title">\"എല്ലാം ഡിലീറ്റ് ചെയ്യുക\" സാധ്യമാക്കുക</string>
    <string name="deduplicator_protection_deleteall_allowed_summary">ഒരു ഫയലും ബാക്കി ഇല്ലാതെ ഡ്യൂപ്ലിക്കേറ്റ് സെറ്റിലെ എല്ലാ ഫയലുകളും ഡിലീറ്റ് ചെയ്യാൻ അനുവദിക്കുന്ന ഓപ്ഷൻസ് കാണിക്കുക.</string>
    <string name="deduplicator_search_locations_title">തിരയൽ സ്ഥാനങ്ങൾ</string>
    <string name="deduplicator_search_locations_all_summary">ആക്‍സസ് ചെയ്യാൻ കഴിയുന്ന എല്ലാ ഇടങ്ങളും</string>
    <string name="deduplicator_keep_prefer_paths_summary">ഏത് ഡ്യൂപ്ലിക്കേറ്റ് സൂക്ഷിക്കണമെന്ന് തീരുമാനിക്കുമ്പോൾ, ഈ ലൊക്കേഷനുകളിൽ ഫയലുകൾ സൂക്ഷിക്കാൻ ഇഷ്ടപ്പെടുക.</string>
    <string name="deduplicator_skip_minsize_title">കുറഞ്ഞ വലുപ്പം</string>
    <string name="deduplicator_skip_minsize_description">കുറഞ്ഞ വലുപ്പത്തിൽ താഴെയുള്ള ഫയലുകൾ ഒഴിവാക്കുക.</string>
    <string name="deduplicator_skip_uncommon_title">അസാധാരണ ഫയൽ തരങ്ങൾ ഒഴിവാക്കുക</string>
    <string name="deduplicator_skip_uncommon_description">സാധാരണ മീഡിയ ഫയലുകൾ, ഡോക്യുമെന്റുകൾ, ആർക്കൈവുകൾ മാത്രം ഉൾപ്പെടുത്തുക.</string>
    <string name="deduplicator_detection_method_label">കണ്ടെത്തൽ രീതി</string>
    <string name="deduplicator_detection_method_checksum_title">ഉള്ളടക്ക ചെക്ക്സം</string>
    <string name="deduplicator_detection_method_checksum_summary">ഫയലുകൾക്കായി ചെക്ക്സം കണക്കാക്കി ഡ്യൂപ്ലിക്കേറ്റുകൾ നിർണ്ണയിക്കുക. ഒരേ ചെക്ക്സം ഉള്ള ഫയലുകൾക്ക് ഒരേ ഉള്ളടക്കമാണ്.</string>
    <string name="deduplicator_detection_method_phash_title">പെർസെപ്ച്വൽ ഹാഷ്</string>
    <string name="deduplicator_detection_method_phash_summary">ഉള്ളടക്ക സവിശേഷതകൾ വിശകലനം ചെയ്ത് പെർസെപ്ച്വൽ ഹാഷ് മൂല്യങ്ങൾ താരതമ്യം ചെയ്ത് സമാന ഫയലുകൾ കണ്ടെത്തുക. ⚠️ സമാനത അടിസ്ഥാനത്തിലുള്ള കണ്ടെത്തൽ തെറ്റായ ഫലങ്ങൾ നൽകിയേക്കാം, അതിന് സ്വമേധയായ പരിശോധന ആവശ്യമായി വരും.</string>
