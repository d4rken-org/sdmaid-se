    <string name="deduplicator_protection_deleteall_allowed_title">\"அனைத்தையும் நீக்கு\" சாத்தியமாக்கு</string>
    <string name="deduplicator_protection_deleteall_allowed_summary">நகல் தொகுப்பில் உள்ள அனைத்து கோப்புகளையும் நீக்க அனுமதிக்கும் விருப்பங்களைக் காட்டு, எந்த கோப்பும் மீதம் இருக்காதபடி.</string>
