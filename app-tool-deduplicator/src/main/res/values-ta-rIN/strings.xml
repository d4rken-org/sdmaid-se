    <string name="deduplicator_arbiter_title">நீக்கும் உத்தி</string>
    <string name="deduplicator_arbiter_summary">எந்தக் கோப்புகள் வைத்திருக்கப்படும் எந்தவை நீக்கப்படும் என்பதை அமைக்கவும்.</string>
    <string name="deduplicator_arbiter_explanation">நகல்களை நீக்கும் போது, SD Maid ஒவ்வொரு அளவுகோலையும் வரிசையாகச் சரிபார்த்து எந்தக் கோப்பை வைத்திருப்பது என்று முடிவு செய்கிறது. தெளிவான வெற்றியாளரை உருவாக்கும் முதல் அளவுகோல் முடிவை தீர்மானிக்கிறது. மறுவரிசைப்படுத்த இழுக்கவும், பயன்முறையை மாற்ற தட்டவும்.</string>
    <string name="deduplicator_arbiter_select_mode_title">பயன்முறையைத் தேர்ந்தெடு</string>
    <string name="deduplicator_arbiter_configure_paths_action">பாதைகளை அமைக்கவும்…</string>
    <string name="deduplicator_arbiter_criterium_duplicate_type_title">நகல் வகை</string>
    <string name="deduplicator_arbiter_criterium_duplicate_type_description">ஒத்த கோப்புகளை விட சரியான பொருத்தங்களை விரும்பு.</string>
    <string name="deduplicator_arbiter_criterium_media_provider_title">ஊடக குறியீடு</string>
    <string name="deduplicator_arbiter_criterium_media_provider_description">கோப்புகள் ஊடக வழங்குநரால் குறியீடு செய்யப்பட்டுள்ளதா என்பதைக் கருத்தில் கொள்.</string>
    <string name="deduplicator_arbiter_criterium_location_title">சேமிப்பு இடம்</string>
    <string name="deduplicator_arbiter_criterium_location_description">உள் அல்லது வெளி சேமிப்பகத்தில் உள்ள கோப்புகளை விரும்பு.</string>
    <string name="deduplicator_arbiter_criterium_nesting_title">கோப்புறை ஆழம்</string>
    <string name="deduplicator_arbiter_criterium_nesting_description">குறைவான அல்லது அதிக ஆழமான கோப்புறை கட்டமைப்புகளில் உள்ள கோப்புகளை விரும்பு.</string>
    <string name="deduplicator_arbiter_criterium_modified_title">மாற்றிய தேதி</string>
    <string name="deduplicator_arbiter_criterium_modified_description">மாற்றிய நேரத்தின் அடிப்படையில் பழைய அல்லது புதிய கோப்புகளை விரும்பு.</string>
    <string name="deduplicator_arbiter_criterium_size_title">கோப்பு அளவு</string>
    <string name="deduplicator_arbiter_criterium_size_description">அளவுகள் வேறுபடும் போது பெரிய அல்லது சிறிய கோப்புகளை விரும்பு.</string>
