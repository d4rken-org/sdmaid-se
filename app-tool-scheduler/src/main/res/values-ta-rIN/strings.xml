    <string name="scheduler_inaccurate_execution_hint">எதிர்பார்க்கப்படும் நிறைவேற்ற நேரங்கள் தகராறுகளாகும். பாட்டரியை பாதுகாக்கினால் தேதிகள் தாமதமாகலாம் அல்லது விரைவாகலாம்.</string>
    <string name="scheduler_no_active_schedules_subtitle">செயலிலுள்ள தேதிகள் இல்லை</string>
    <string name="scheduler_setting_nopowersaving_title">குறைந்த பாட்டரியில் தவிர்</string>
    <string name="scheduler_setting_nopowersaving_summary">சாதனம் சக்தி-சேமிப்பு முறையில் இருந்தால், திட்டமிடப்பட்ட நிறைவேற்றம் தவிர்க்கப்படும்.</string>
    <string name="scheduler_setting_charging_title">சார்ஜ் செய்யாதபோது தவிர்</string>
    <string name="scheduler_setting_charging_summary">சாதனம் சார்ஜ் செய்யவில்லை என்றால், திட்டமிடப்பட்ட நிறைவேற்றம் தவிர்க்கப்படும்.</string>
    <string name="scheduler_setting_automation_title">அணுகல் சேவை</string>
    <string name="scheduler_setting_automation_summary">அணுகல் சேவையைப் பயன்படுத்தும் செயல்களைச் சேர்க்கவும். பணிகள் நிறைவேற்றப்படுமோது SD Maid உங்கள் திரையுடன் தொடர்பு கொள்ள முடியவேண்டும் (அதாவது அது பூட்டப்படவில்லை).</string>
    <string name="scheduler_notification_channel_label">தேதி நிர்ணாயகர்</string>
