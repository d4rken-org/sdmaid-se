    <string name="swiper_label">Swiper</string>
    <string name="swiper_tool_description">Брзо средите фасцикле — превуците фајлове да задржите, обришете или прескочите.</string>
    <string name="swiper_dashcard_description">Средите одређене фасцикле брже него у менаџеру фајлова — само превуците сваки фајл.</string>
    <string name="swiper_start_action">Почни превлачење</string>
