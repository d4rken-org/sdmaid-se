    <string name="swiper_label">Swiper</string>
    <string name="swiper_tool_description">სწრაფად მოაწესრიგეთ საქაღალდეები — გადაფურცლეთ ფაილები შესანახად, წასაშლელად ან გამოსატოვებლად.</string>
    <string name="swiper_dashcard_description">მოაწესრიგეთ კონკრეტული საქაღალდეები ფაილების მენეჯერზე სწრაფად — უბრალოდ გადაფურცლეთ თითოეული ფაილი.</string>
