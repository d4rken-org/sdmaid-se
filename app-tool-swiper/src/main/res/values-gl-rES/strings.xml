    <string name="swiper_label">Swiper</string>
    <string name="swiper_tool_description">Ordena cartafoles rapidamente -- pasa o dedo polos ficheiros para gardar, eliminar ou saltar.</string>
    <string name="swiper_dashcard_description">Ordena cartafoles específicos máis rápido que cun explorador de ficheiros -- simplemente pasa o dedo en cada ficheiro.</string>
