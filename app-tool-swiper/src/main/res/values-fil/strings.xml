    <string name="swiper_label">Swiper</string>
    <string name="swiper_tool_description">Mabilis na linisin ang mga folder — mag-swipe ng mga file para itabi, burahin, o laktawan.</string>
    <string name="swiper_dashcard_description">Linisin ang mga tiyak na folder nang mas mabilis kaysa sa file explorer — i-swipe lang ang bawat file.</string>
    <string name="swiper_start_action">Magsimulang mag-swipe</string>
    <string name="swiper_continue_action">Ipagpatuloy ang session</string>
    <string name="swiper_sessions_description">Suriin ang mga file sa 3 simpleng hakbang:\n\n1. Pumili ng folder na i-scan\n2. Mag-swipe ng mga file para itabi, burahin, o laktawan\n3. Suriin ang mga pagpapasya at kumpirmahin\n\nWalang maaalis hanggang hindi mo na-tap ang huling delete button.</string>
