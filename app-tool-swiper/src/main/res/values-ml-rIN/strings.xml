<resources>
    <string name="swiper_label">Swiper</string>
    <string name="swiper_tool_description">ഫോർഡർുകൾ വേഗതിൽ വൃത്തിയാക്കുക — ഫയലുകൾ സൂക്ഷിക്കാൻ, ഡിലീറ്റ് ചെയ്യാൻ, അഥവാ ഒഴിവാക്കാൻ സ്വൈപ്പ് ചെയ്യുക.</string>
    <string name="swiper_dashcard_description">ഒരു ഫയൽ എക്സ്പ്ലോറർറർസറ്റുമിക്കാർ വേഗതിൽ നിർദ്ദിഷ്ട ഫോർഡർുകൾ വൃത്തിയാക്കുക — ഓരോ ഫയൽ സ്വൈപ്പ് ചെയ്യുക.</string>
    <string name="swiper_start_action">സ്വൈപ്പിംഗ് തുടങ്ങുക</string>
    <string name="swiper_continue_action">സെഷൻ തുടരുക</string>
    <string name="swiper_sessions_description">3 ലളുതായ ഘട്ടങ്ങളിൽ ഫയലുകൾ പരിശോധിക്കുക:\n\n1. സ്കാൻ ചെയ്യാൻ ഒരു ഫോർഡർ തിരഞ്ഞെടുക്കുക\n2. ഫയലുകൾ സൂക്ഷിക്കാൻ, ഡിലീറ്റ് ചെയ്യാൻ, അഥവാ ഒഴിവാക്കാൻ സ്വൈപ്പ് ചെയ്യുക\n3. നിങ്ങളുടെ തിരഞ്ഞെടുപ്പുകൾ പരിശോധിച്ച് സ്ഥിരീകരിക്കുക\n\nഅവസാന ഡിലീറ്റ് ബടൺൺൺൺൺൺൺൺണ് ടാപ് ചെയ്യുന്നതു വരെ ഒന്നും നീക്കപ്പെഡുന്നില്ല.</string>
