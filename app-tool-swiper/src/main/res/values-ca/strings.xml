    <string name="swiper_label">Escombrador</string>
    <string name="swiper_tool_description">Poseu ordre a les carpetes ràpidament: llisqueu els fitxers per mantenir-los, suprimir-los o ometre\'ls.</string>
    <string name="swiper_dashcard_description">Poseu ordre a carpetes específiques més ràpid que un explorador de fitxers: simplement llisqueu cada fitxer.</string>
    <string name="swiper_start_action">Comença a lliscar</string>
    <string name="swiper_continue_action">Continua la sessió</string>
    <string name="swiper_sessions_description">Reviseu els fitxers en 3 passos senzills:\n\n1. Trieu una carpeta per escanejar\n2. Llisqueu els fitxers per mantenir-los, suprimir-los o ometre\'ls\n3. Reviseu les decisions i confirmeu\n\nNo se suprimeix res fins que toqueu el botó final de supressió.</string>
