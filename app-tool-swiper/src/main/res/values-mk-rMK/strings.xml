    <string name="swiper_label">Swiper</string>
    <string name="swiper_tool_description">Расчистете папки брзо — лизгајте низ датотеки за задржување, бришење или прескокнување.</string>
    <string name="swiper_dashcard_description">Расчистете одредени папки побрзо од пребарувач на датотеки — само лизгајте секоја датотека.</string>
