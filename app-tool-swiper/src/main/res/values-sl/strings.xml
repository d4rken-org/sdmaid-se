    <string name="swiper_label">Drsnik</string>
    <string name="swiper_tool_description">Hitro uredite mape — povlecite datoteke, da jih ohranite, izbrišete ali preskočite.</string>
    <string name="swiper_dashcard_description">Uredite posamezne mape hitreje kot z upraviteljem datotek — samo povlecite vsako datoteko.</string>
