<resources>
    <string name="swiper_label">Swiper</string>
    <string name="swiper_tool_description">கோப்புறைகளை விரைவாக ஒழுங்குபடுத்தவும் -- கோப்புகளை வைக்க, நீக்க அல்லது தவிர்க்க ஸ்வைப் செய்யவும்.</string>
    <string name="swiper_dashcard_description">குறிப்பிட்ட கோப்புறைகளை கோப்பு நிர்வாகியை விட விரைவாக ஒழுங்குபடுத்தவும் -- ஒவ்வொரு கோப்பையும் ஸ்வைப் செய்யவும்.</string>
    <string name="swiper_start_action">ஸ்வைப் செய்யத் தொடங்கு</string>
    <string name="swiper_continue_action">அமர்வைத் தொடர்</string>
    <string name="swiper_sessions_description">3 எளிய படிகளில் கோப்புகளை மதிப்பாய்வு செய்யவும்:\n\n1. ஸ்கேன் செய்ய ஒரு கோப்புறையைத் தேர்ந்தெடுக்கவும்\n2. கோப்புகளை வைக்க, நீக்க அல்லது தவிர்க்க ஸ்வைப் செய்யவும்\n3. உங்கள் தேர்வுகளை மதிப்பாய்வு செய்து உறுதிப்படுத்தவும்\n\nஇறுதி நீக்கு பொத்தானைத் தட்டும் வரை எதுவும் நீக்கப்படாது.</string>
    <string name="swiper_select_folders_action">கோப்புறைகளைத் தேர்ந்தெடு</string>
