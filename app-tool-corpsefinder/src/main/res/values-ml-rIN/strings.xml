<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="corpsefinder_explanation_short">ഇതിനകം നീക്കം ചെയ്ത ആപ്പുകൾക്ക് അനുബന്ധമായ ഡേറ്റ.</string>
    <string name="corpsefinder_settings_summary">സ്‌കാൻ ഫിർത്തറുകളും അപകടസാധ്യത നിലകളും ക്രമീകരിക്കുക.</string>
    <string name="corpsefinder_settings_risk_keeper_title">ആഗ്രഹനീയ അവശിഷ്ടങ്ങൾ ഉൾപ്പെടുത്തുക</string>
    <string name="corpsefinder_settings_risk_keeper_summary">ആപ്പ് അൺഇൻസ്‌റോൾ ചെയ്‍തിരിക്കുന്നെങ്കിലും നിങ്ങൾ സൂക്ഷിക്കാൻ ആഗ്രഹിക്കുന്ന ഫയലുകൾ, ഉദാ: നിങ്ങൾ എടുത്ത ഫോട്ടോകൾ അല്ലെങ്കിൽ നിർമ്മിച്ച ബാക്കപ്പുകൾ.</string>
    <string name="corpsefinder_settings_risk_common_title">പൊതുവായ പേരുകൾ ഉൾപ്പെടുത്തുക</string>
    <string name="corpsefinder_settings_risk_common_summary">പൊതുവായി ഉപയോഗിക്കുന്ന പേരുകളുള്ള ഡേറ്റ, ഉദാ: \"Notes\" ഫോൾഡർ ഒരുപാട് അജ്ഞാത ആപ്പുകൾ ഉടമകളാണ്.</string>
    <string name="corpsefinder_watcher_title">അൺഇൻസ്‌റോൾ നിരീക്ഷകൻ</string>
    <string name="corpsefinder_watcher_summary">ഒരു ആപ്പ് നീക്കം ചെയ്യുമ്പോൾ അവശിഷ്ടങ്ങൾക്കായി സ്വയം സ്‌കാൻ ചെയ്യുക.</string>
    <string name="corpsefinder_watcher_autodelete_title">സ്വയംക്രിയ ഡിലീഷൻ</string>
    <string name="corpsefinder_watcher_autodelete_summary">അൺഇൻസ്‌റോൾ ചെയ്ത ആപ്പുമായി ബന്ധപ്പെട്ട അവശിഷ്ടങ്ങൾ സ്വയം ഡിലീറ്റ് ചെയ്യുക.</string>
