<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="corpsefinder_explanation_short">पहिले नै हटाइएका एप्सहरूसँग सम्बन्धित डाटा।</string>
    <string name="corpsefinder_settings_summary">स्क्यान फिल्टरहरू र जोखिम स्तरहरू समायोजन गर्नुहोस्।</string>
    <string name="corpsefinder_settings_risk_keeper_title">वांछनीय अवशेषहरू समावेश गर्नुहोस्</string>
    <string name="corpsefinder_settings_risk_keeper_summary">फाइलहरू जुन तपाईं राख्न चाहनुहुन्छ, एप अनइन्स्टल भएको भए पनि, जस्तै तपाईंले खिचेका फोटोहरू वा सिर्जना गरेका ब्याकअपहरू।</string>
    <string name="corpsefinder_settings_risk_common_title">सामान्य नामहरू समावेश गर्नुहोस्</string>
    <string name="corpsefinder_settings_risk_common_summary">सामान्यतया प्रयोग हुने नामहरू भएका डाटा, जस्तै \"Notes\" फोल्डर धेरै अज्ञात एप्सहरूको स्वामित्वमा छ।</string>
    <string name="corpsefinder_watcher_title">अनइन्स्टल वाचर</string>
    <string name="corpsefinder_watcher_summary">एप हटाउँदा स्वचालित रूपमा अवशेषहरूको लागि स्क्यान गर्नुहोस्।</string>
    <string name="corpsefinder_watcher_autodelete_title">स्वचालित मेटाउने</string>
    <string name="corpsefinder_watcher_autodelete_summary">अनइन्स्टल गरिएको एपसँग सम्बन्धित कुनै पनि अवशेषहरू स्वचालित रूपमा मेटाउनुहोस्।</string>
    <plurals name="corpsefinder_watcher_notification_scan_result">
        <item quantity="one">%2$s अनइन्स्टल गरेपछि %1$d अवशेष फेला परेको।</item>
        <item quantity="other">%2$s अनइन्स्टल गरेपछि %1$d अवशेषहरू फेला परेका।</item>
    </plurals>
    <plurals name="corpsefinder_watcher_notification_delete_result">
        <item quantity="one">सफाई सफल (%1$s): %2$s खाली गरिएको र %3$d वस्तु हटाइएको।</item>
        <item quantity="other">सफाई सफल (%1$s): %2$s खाली गरिएको र %3$d वस्तुहरू हटाइएका।</item>
    </plurals>
    <string name="corpsefinder_watcher_notification_delete_action">अवशेषहरू मेटाउनुहोस्</string>
    <string name="corpsefinder_filter_publicmedia_label">पब्लिक मिडिया</string>
    <string name="corpsefinder_filter_publicmedia_summary">पब्लिक मिडिया फाइलहरू, जस्तै मेसेन्जर एप्सहरू मार्फत प्राप्त फाइलहरू।</string>
    <string name="corpsefinder_filter_publicobb_label">OBB संसाधनहरू</string>
    <string name="corpsefinder_filter_publicobb_summary">अतिरिक्त एप संसाधनहरू, जस्तै गेम एसेटहरू।</string>
    <string name="corpsefinder_filter_publicdata_label">पब्लिक एप डाटा</string>
    <string name="corpsefinder_filter_publicdata_summary">गैर-संवेदनशील एप डाटा, जस्तै म्याप क्यासहरू।</string>
    <string name="corpsefinder_filter_sdcard_label">SD कार्ड</string>
    <string name="corpsefinder_filter_sdcard_summary">सामान्य पब्लिक भण्डारण, आन्तरिक र बाह्य (जस्तै SD कार्डहरू)।</string>
    <string name="corpsefinder_filter_privatedata_label">निजी एप डाटा</string>
    <string name="corpsefinder_filter_privatedata_summary">निजी एप डाटा, जस्तै प्रमाणहरू, एप सेटिङहरू तर ब्राउजर क्यासहरू पनि।</string>
    <string name="corpsefinder_filter_dalvik_label">Dalvik क्यास</string>
    <string name="corpsefinder_filter_dalvik_summary">क्यास गरिएको एप कार्यान्वयन डाटा।</string>
    <string name="corpsefinder_filter_artprofiles_label">ART प्रोफाइलहरू</string>
    <string name="corpsefinder_filter_artprofiles_summary">ART प्रोफाइलहरू Android द्वारा अनुप्रयोग कार्यक्षमता अनुकूलन गर्न प्रयोग गरिन्छ।</string>
    <string name="corpsefinder_filter_applib_label">एप लाइब्रेरीहरू</string>
    <string name="corpsefinder_filter_applib_summary">एप सम्बन्धित लाइब्रेरी डाटा।</string>
    <string name="corpsefinder_filter_appsource_label">एप स्रोतहरू</string>
    <string name="corpsefinder_filter_appsource_summary">एप स्थापना डाटा, जहाँ APKs जान्छन्।</string>
    <string name="corpsefinder_filter_appsource_private_label">निजी एप स्रोतहरू</string>
    <string name="corpsefinder_filter_appsource_private_summary">प्रतिबन्धित एप स्थापना डाटा, जस्तै सुरक्षित तेस्रो पक्ष एप्सहरू।</string>
    <string name="corpsefinder_filter_appasec_label">एन्क्रिप्टेड एप संसाधनहरू</string>
    <string name="corpsefinder_filter_appasec_summary">एन्क्रिप्टेड एप संसाधनहरू, जस्तै गेम एसेटहरू।</string>
