<resources>
    <string name="corpsefinder_explanation_short">Daten, die zu bereits entfernten Apps gehören.</string>
    <string name="corpsefinder_settings_summary">Passe Scanfilter und Risikostufen an.</string>
    <string name="corpsefinder_settings_risk_keeper_title">Erwünschte Reste einbeziehen</string>
    <string name="corpsefinder_settings_risk_keeper_summary">Dateien, die Du vielleicht behalten möchtest, auch wenn die App deinstalliert ist, z.B. Fotos, die Du aufgenommen hast, oder Sicherungskopien, die Du erstellt hast.</string>
