<resources>
    <string name="exclusion_manager_title">விலக்கல் மேலாளர்</string>
    <string name="exclusion_manager_desc">கோப்பு மற்றும் பயன்பாட்டு விலக்கல்களை நிர்வகிக்கவும்.</string>
    <string name="exclusion_explanation_body1">கோப்புகள் மற்றும் பயன்பாடுகளை SD Maid இன் செயல்பாடுகளிலிருந்து விலக்கவும்.</string>
    <string name="exclusion_add_new_hint">முதலில் SD Maid தேடவிட்டு, பின்னர் நீங்கள் விலக்க விரும்பும் முடிவில் சந்தர்ப்ப பட்டியைப் பயன்படுத்தி புதிய விலக்கல்களைச் சேர்க்கவும்.</string>
    <string name="exclusion_create_action">விலக்கலை உருவாக்கு</string>
    <string name="exclusion_edit_action">விலக்கலைத் தருணி</string>
