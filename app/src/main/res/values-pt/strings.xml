    <string name="setup_saf_card_title">Quadro de acesso ao armazenamento</string>
    <string name="setup_saf_card_body">Melhorar os resultados, concedendo acesso ao SD Maid a áreas adicionais.</string>
    <string name="setup_saf_card_body2">Na maioria dos casos, a janela abrirá com o caminho correto pré-selecionado. As entradas ficam verdes quando o acesso é concedido. </string>
