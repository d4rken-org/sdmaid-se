    <string name="setup_usagestats_title">გამოყენების სტატისტიკა</string>
    <string name="setup_usagestats_body">გამოყენების სტატისტიკის ნებართვა ანიჭებს წვდომას აპის სხვა დეტალებზე. SD Maid იყენებს მას დამატებითი ქეშის ზომის დასადგენად.</string>
    <string name="setup_usagestats_hint">საჭიროა ხელმისაწვდომობის სერვისზე დაფუძნებული ქეშის წაშლისთვის.</string>
    <string name="setup_notification_title">შეტყობინებები</string>
    <string name="setup_notification_body">მიეცით საშუალება SD Maid-ს გამოაქვეყნოს შეტყობინებები, რათა გაცნობოთ მიმდინარე ოპერაციების ან მნიშვნელოვანი მოვლენების შესახებ.</string>
    <string name="setup_notification_hint">შეტყობინებები გამოიყენება ზომიერად 🤞</string>
    <string name="setup_feature_requires_additional_setup_x">ამ ფუნქციას სჭირდება დამატებითი დაყენების ელემენტების დასრულება: %s</string>
    <string name="setup_acs_card_title">მარტივი წვდომის სერვისი</string>
    <string name="setup_acs_card_body">ხელმისაწვდომობის სერვისი საშუალებას აძლევს SD Maid-ს ურთიერთობა თქვენს ეკრანთან და მოსაწყენი მოქმედებების ავტომატიზაცია, მაგ. \"ქეშის გასუფთავების\" შეხება რამდენიმე ეკრანზე.</string>
    <string name="setup_acs_card_body2">SD Maid არ გამოიყენებს ხელმისაწვდომობის სერვისს თქვენი თანხმობის გარეშე, ყოველთვის აჩვენებს გამოჩენილ (გაუქმებულ) ინდიკატორს აქტიურობისას და არ გამოიყენებს მას ინფორმაციის შესაგროვებლად.</string>
    <string name="setup_acs_state_enabled">Წვდომის სერვისი ჩართულია</string>
    <string name="setup_acs_state_disabled">წვდომის სერვისი გამორთულია</string>
    <string name="setup_acs_state_running">წვდომის სერვისი გაშვებულია</string>
    <string name="setup_acs_state_ondemand">სერვისი გაეშვება მოთხოვნისამებრ</string>
    <string name="setup_acs_state_stopped">წვდომის სერვისი შეჩერებულია</string>
    <string name="setup_acs_state_stopped_hint">სერვისი ჩართულია, მაგრამ არ მუშაობს. გადართეთ გამორთული/ჩართული ან გადატვირთეთ მოწყობილობა. შეამოწმეთ, რომ SD Maid არ \"ოპტიმიზდება\" სისტემის მიერ.</string>
    <string name="setup_acs_state_stopped_hint_miui">თუ გარკვეული პერიოდის შემდეგ სერვისი გაითიშება, სცადეთ სისტემის პარამეტრებში SD Maid-ის ოფციის „ავტომატური დაწყება“ ჩართვა.</string>
    <string name="setup_acs_consent_positive_action">სერვისის ჩართვა და წვდომის მინიჭება</string>
    <string name="setup_acs_consent_negative_action">არ გამოიყენოთ მარტივი წვდომის სერვისი</string>
    <string name="setup_acs_allow_hint">თუ ეკრანის კიდეზე ხედავთ პატარა ხატულას, მაშინ თქვენ შემთხვევით ჩართეთ \"მასახვრეტი\" ვარიანტი.</string>
    <string name="setup_acs_disallow_hint">თუ გადაიფიქრებთ, შეგიძლიათ კვლავ შეცვალოთ ეს პარამეტრი პარამეტრებში შესვლით და დაყენების გადატვირთვით.</string>
    <string name="setup_acs_appops_restriction_title">შეზღუდული პარამეტრები</string>
    <string name="setup_acs_appops_restriction_body">არ შეგიძლიათ SD Maids-ის წვდომის სერვისის ჩართვა? Android 13+ შეიძლება დაწესდეს შეზღუდვები აპებზე, რომლებიც არ არის დაინსტალირებული Google Play-ზე. გააუქმეთ ეს შეზღუდვები სისტემის დეტალების გვერდიდან SD Maid-ისთვის. ვარიანტი მდებარეობს ზედა მარჯვენა კუთხეში კონტექსტურ მენიუში.</string>
    <string name="setup_inventory_card_title">აპების ინვენტარი</string>
    <string name="setup_inventory_card_body">SD Maid-მა უნდა იცოდეს რომელი აპები გაქვთ, რათა იპოვოს ფაილები, რომლებიც არ ეკუთვნის დაინსტალირებულ აპებს.</string>
    <string name="setup_inventory_card_extra">მოძებნეთ ნებართვა, რომელსაც ეწოდება \"აპების ჩამონათვალი\" ან \"ყველა პაკეტის შეკითხვა\".</string>
    <string name="setup_inventory_invalid_message">სისტემამ მოგვაწოდა დაინსტალირებული აპების არასწორი ჩამონათვალი (მაგ. ძალიან ცოტა ან ზოგიერთი დაკარგული იყო). გადადით სისტემის პარამეტრებზე და მიეცით SD Maid-ს წვდომა \"აპების ჩამონათვალზე\".</string>
    <string name="dataarea_warningcard_empty_message">SD Maid-მა ვერ იპოვა მონაცემთა ზონა, რომლის სკანირებაც შესაძლებელია. დაასრულეთ დაყენება?</string>
