    <string name="setup_saf_missing_app_error">Documents UI აპი მიუწვდომელია. ეს არის ჩაშენებული სისტემური აპი და ხელმისაწვდომი უნდა იყოს ყველა Android მოწყობილობაზე.</string>
    <string name="setup_manage_storage_card_title">მეხსიერების მართვა</string>
    <string name="setup_manage_storage_card_body">ნება მიეცით SD Maid-ს მართოს თქვენი მეხსიერება.</string>
    <string name="setup_manage_storage_card_body2">ძირითადი წვდომა საჯარო მეხსიერებაზე, მაგ. \"Download/\" და \"DCIM/\", მაგრამ არა ყოველთვის \"Android/data\".</string>
    <string name="setup_root_card_title">Root წვდომა</string>
    <string name="setup_root_card_body">უნდა გამოიყენოს SD Maid-მა root წვდომა, თუ ის ხელმისაწვდომია? Root წვდომა შეიძლება გამოყენებულ იქნას დამატებითი სისტემის საქაღალდეების და პირადი აპლიკაციის მონაცემების შესამოწმებლად.</string>
    <string name="setup_root_state_ready_label">Root წვდომა მზადაა.</string>
    <string name="setup_root_state_waiting_label">Root წვდომის მოლოდინი.</string>
    <string name="setup_root_enable_root_use_label">Გამოიყენეთ root წვდომა, თუ ეს შესაძლებელია</string>
    <string name="setup_root_disable_root_use_label">არ გამოიყენოთ root წვდომა</string>
    <string name="setup_root_card_body2">ხელმისაწვდომია მხოლოდ root მოწყობილობებზე. თუ თქვენ არ გააკეთეთ ეს მოდიფიკაცია, მაშინ თქვენი მოწყობილობა არ არის დაყენებული და ეს პარამეტრი არ მოქმედებს.</string>
    <string name="setup_shizuku_card_title">Shizuku</string>
    <string name="setup_shizuku_card_body">მიეცით SD Maid-ს Shizuku-ს გამოყენების ნება შესაძლოა სადაც კი შეიძლება, შედეგების გასაუმჯობესებლად და ფუნქციების ასაქმედად.</string>
    <string name="setup_shizuku_card_body2">ამ პარამეტრს არ აქვს ეფექტი, თუ Shizuku აპი არ არის დაყენებული თქვენს მოწყობილობაზე.</string>
    <string name="setup_shizuku_card_root_info">Shizuku root წვდომასთან ერთად არ ამქმედებს დამატებით ფუნქციებს, მაგრამ აუმჯობესებს სანდოობას. SD Maid გამოიყენებს მას როგორც სარეზერვო მეთოდს.</string>
    <string name="setup_shizuku_state_ready_label">Shizuku კავშირი მზადაა.</string>
    <string name="setup_shizuku_state_waiting_label">Shizuku-სთან კავშირის მოლოდინი.</string>
    <string name="setup_shizuku_enable_shizuku_use_label">გამოიყენეთ Shizuku თუ ხელმისაწვდომია</string>
    <string name="setup_shizuku_disable_shizuku_use_label">არ გამოიყენოთ Shizuku</string>
    <string name="setup_dismiss_hint">პარამეტრების მენიუს მეშვეობით შეგიძლიათ კვლავ იპოვოთ დაყენების ეკრანი.</string>
