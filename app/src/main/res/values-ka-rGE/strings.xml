    <string name="onboarding_welcome_title">მოგესალმებით</string>
    <string name="onboarding_welcome_body1">SD Maid SE მართავს ფაილებს, აპებს და მეხსიერებას.</string>
    <string name="onboarding_welcome_body2">მოიპოვეთ შენახვის ადგილი სხვა აპების უკან გაწმენდით. წაშალეთ დახარჯული ფაილები და წაშალეთ დარჩენილი მონაცემები.</string>
    <string name="onboarding_welcome_body_beta">ეს არის ბეტა (სატესტო) კონსტრუქცია. განაგრძეთ იუმორის გრძნობით და სარეზერვო გეგმით. გთხოვთ, შეატყობინოთ თქვენს წინაშე არსებულ პრობლემებს.</string>
    <string name="onboarding_welcome_continue_action">გაგრძელება</string>
    <string name="onboarding_versus_title">SD Maid / SD Maid SE</string>
    <string name="onboarding_versus_body1">SD Maid SE (აგრეთვე SD Maid 2) არის SD Maid-ის (აგრეთვე SD Maid 1) მემკვიდრე. ახალი აპი, ოპტიმიზირებული თანამედროვე Android-სთვის.</string>
    <string name="onboarding_versus_body2">მისი წინამორბედის არქიტექტურა 7 წელზე მეტია და არ არის შექმნილი Android-ის ახალი ვერსიების გამოწვევებისთვის. განვითარების გასაგრძელებლად აუცილებელი იყო სრული რედიზაინი.</string>
    <string name="onboarding_versus_body3">იფიქრეთ SD Maid SE-ზე გადასვლაზე გაუმჯობესებული შედეგებისთვის.</string>
    <string name="onboarding_versus_body4">SD Maid 1-ის \"პრო სტატუსი\" სამწუხაროდ არ გადატანადია SD Maid 2/SE-ზე. 12 წლის უფასო განახლების შემდეგ, საჭიროა ახალი შესყიდვა განვითარების გასაგრძელებლად (დეველოპერის გამოსაკვებად).</string>
    <string name="onboarding_versus_continue_action">გაგრძელება</string>
    <string name="onboarding_privacy_title">კონფიდენციალურობა</string>
    <string name="onboarding_privacy_body1">SD Maid-ს არ აქვს რეკლამები და არ ყიდის მომხმარებლის მონაცემებს.</string>
    <string name="onboarding_privacy_bugreport_toggle_body">შეცდომების შესახებ შეტყობინებები იგზავნება, როდესაც ხდება შეცდომები და შეიძლება შეიცავდეს დეტალებს თქვენს მოწყობილობაზე არსებული აპებისა და ფაილების შესახებ. ანგარიშები მეხმარება შეცდომების გამოსწორებაში და აპის გაუმჯობესებაში.</string>
    <string name="onboarding_privacy_bugreport_toggle">შეცდომების ავტომატური შეტყობინებების დაშვება</string>
    <string name="onboarding_privacy_bugreport_toggle_hint">ეს პარამეტრები შეიძლება შეიცვალოს პარამეტრებში.</string>
