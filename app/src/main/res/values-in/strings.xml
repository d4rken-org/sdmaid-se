    <string name="setup_saf_card_title">Kerangka akses penyimpanan</string>
    <string name="setup_saf_card_body">Tingkatkan hasil dengan memberikan akses SD Maid ke area tambahan.</string>
    <string name="setup_saf_card_body2">Dalam kebanyakan kasus, jendela akan terbuka dengan jalur yang benar yang telah dipilih sebelumnya. Entri berubah menjadi hijau saat akses diberikan. </string>
    <string name="setup_saf_error_wrong_path">Anda memilih jalur yang salah</string>
    <string name="setup_saf_missing_app_error">Aplikasi Documents UI tidak tersedia. Ini adalah aplikasi sistem bawaan dan harus tersedia di semua perangkat Android.</string>
    <string name="setup_manage_storage_card_title">Kelola penyimpanan</string>
    <string name="setup_manage_storage_card_body">Izinkan SD Maid mengelola penyimpanan Anda.</string>
    <string name="setup_manage_storage_card_body2">Akses dasar ke penyimpanan publik, e.g. \"Download/\" dan \"DCIM/\", tetapi tidak selalu \"Android/data\".</string>
    <string name="setup_root_card_title">Akses root</string>
    <string name="setup_root_card_body">Haruskah SD Maid menggunakan akses root jika tersedia? Akses root dapat digunakan untuk memeriksa folder sistem dan data aplikasi pribadi.</string>
    <string name="setup_root_state_ready_label">Akses root siap.</string>
    <string name="setup_root_state_waiting_label">Menunggu akses root.</string>
    <string name="setup_root_enable_root_use_label">Gunakan akses root jika tersedia</string>
    <string name="setup_root_disable_root_use_label">Jangan gunakan akses root</string>
    <string name="setup_root_card_body2">Hanya tersedia pada perangkat yang di-root. Jika Anda belum melakukan pengubahan, maka perangkat Anda belum di-root dan pengaturan ini tidak berpengaruh.</string>
    <string name="setup_shizuku_card_title">Shizuku</string>
    <string name="setup_shizuku_card_body">Izinkan SD Maid untuk menggunakan Shizuku jika memungkinkan untuk mendapatkan hasil yang lebih baik dan mengaktifkan fitur-fitur tertentu.</string>
    <string name="setup_shizuku_card_body2">Pengaturan ini tidak berpengaruh jika aplikasi Shizuku tidak dipasang pada perangkat Anda.</string>
    <string name="setup_shizuku_card_root_info">Kombinasi Shizuku dan akses root tidak membuka fitur baru, melainkan meningkatkan keandalan. SD Maid menggunakannya sebagai metode alternatif.</string>
    <string name="setup_shizuku_state_ready_label">Hubungan dengan Shizuku sudah siap.</string>
    <string name="setup_shizuku_state_waiting_label">Menunggu penghubungan dengan Shizuku.</string>
    <string name="setup_shizuku_enable_shizuku_use_label">Gunakan Shizuku jika tersedia</string>
    <string name="setup_shizuku_disable_shizuku_use_label">Jangan gunakan Shizuku</string>
    <string name="setup_dismiss_hint">Kamu dapat menemukan layar penyiapan lagi melalui menu pengaturan.</string>
    <string name="setup_permission_granted_label">Izin diberikan</string>
    <string name="setup_permission_error_label">Kesalahan perizinan</string>
    <string name="setup_usagestats_title">Statistik penggunaan</string>
    <string name="setup_usagestats_body">Izin statistik penggunaan memberi akses ke lebih banyak detail aplikasi. SD Maid menggunakannya untuk menentukan ukuran cache tambahan.</string>
    <string name="setup_usagestats_hint">Diperlukan untuk penghapusan cache berbasis layanan aksesibilitas.</string>
    <string name="setup_notification_title">Notifikasi</string>
    <string name="setup_notification_body">Izinkan SD Maid untuk mengirim notifikasi untuk memberitahu Anda mengenai perintah yang sedang dijalankan atau peristiwa penting.</string>
    <string name="setup_notification_hint">Notifikasi digunakan dengan hemat 🤞</string>
    <string name="setup_feature_requires_additional_setup_x">Fitur ini mengharuskan Anda untuk melengkapi item pengaturan tambahan: %s</string>
    <string name="setup_acs_card_title">Layanan aksesibilitas</string>
    <string name="setup_acs_card_body">Layanan aksesibilitas memungkinkan SD Maid untuk berinteraksi dengan layar Anda dan mengotomatiskan tindakan yang membosankan, mis. mengetuk \"Hapus cache\" di beberapa layar.</string>
    <string name="setup_acs_card_body2">SD Maid tidak akan menggunakan layanan aksesibilitas tanpa persetujuan Anda, akan selalu menampilkan indikator yang menonjol (dapat dibatalkan) saat aktif dan tidak akan menggunakannya untuk mengumpulkan informasi.</string>
    <string name="setup_acs_state_enabled">Layanan aksesibilitas diaktifkan</string>
    <string name="setup_acs_state_disabled">Layanan aksesibilitas dinonaktifkan</string>
    <string name="setup_acs_state_running">Layanan aksesibilitas sedang berjalan</string>
    <string name="setup_acs_state_ondemand">Layanan akan diluncurkan sesuai permintaan</string>
    <string name="setup_acs_state_stopped">Layanan aksesibilitas dihentikan</string>
    <string name="setup_acs_state_stopped_hint">Layanan diaktifkan, tetapi tidak berjalan. Nyalakan/matikan layanan atau mulai ulang perangkat Anda. Pastikan SD Maid tidak \"dioptimalkan\" oleh sistem.</string>
    <string name="setup_acs_state_stopped_hint_miui">Jika layanan terus dinonaktifkan setelah beberapa saat, coba aktifkan opsi \"Mulai Otomatis\" untuk SD Maid di pengaturan sistem.</string>
    <string name="setup_acs_consent_positive_action">Aktifkan layanan dan berikan akses</string>
    <string name="setup_acs_consent_negative_action">Jangan gunakan layanan aksesibilitas</string>
    <string name="setup_acs_allow_hint">Jika Anda melihat ikon kecil di tepi layar, maka Anda secara tidak sengaja mengaktifkan opsi \"jalan pintas\".</string>
    <string name="setup_acs_disallow_hint">Jika Anda berubah pikiran, Anda dapat mengubah opsi ini lagi dengan masuk ke pengaturan dan memulai ulang penyiapan.</string>
    <string name="setup_acs_appops_restriction_title">Pengaturan terbatas</string>
    <string name="setup_acs_appops_restriction_body">Tidak dapat mengaktifkan layanan aksesibilitas SD Maid? Android 13+ dapat menerapkan batasan untuk aplikasi yang tidak diinstal melalui Google Play. Ubah batasan ini dari halaman detail sistem untuk SD Maid. Pilihannya ada di menu konteks di pojok kanan atas.</string>
    <string name="setup_inventory_card_title">Inventaris aplikasi</string>
    <string name="setup_inventory_card_body">SD Maid perlu mengetahui aplikasi apa yang Anda miliki untuk mencari file yang tidak terkait dengan aplikasi yang terinstal.</string>
    <string name="setup_inventory_card_extra">Cari izin yang disebut \"Daftar Aplikasi\" atau \"Kueri semua paket\".</string>
    <string name="setup_inventory_invalid_message">Sistem memberikan daftar aplikasi terinstal yang tidak valid (misalnya, terlalu sedikit atau ada yang hilang). Buka pengaturan sistem dan izinkan SD Maid mengakses \"Daftar aplikasi\".</string>
