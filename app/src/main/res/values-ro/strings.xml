    <string name="setup_manage_storage_card_body2">Acces de bază la stocarea publică, ex: \"Download/\" și \"DCIM/\", dar nu întotdeauna \"Android/data\".</string>
    <string name="setup_root_card_title">Acces root</string>
    <string name="setup_root_card_body">Ar trebui ca SD Maid să folosească accesul root dacă este disponibil? Accesul root poate fi folosit pentru a verifica folderele de sistem și datele private ale aplicației.</string>
    <string name="setup_root_state_ready_label">Accesul root este gata.</string>
