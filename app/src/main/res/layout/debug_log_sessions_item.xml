<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <FrameLayout
        android:layout_width="24dp"
        android:layout_height="24dp">

        <ImageView
            android:id="@+id/status_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_file_chart_outline_24"
            app:tint="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/zipping_indicator"
            style="@style/Widget.Material3.CircularProgressIndicator.ExtraSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="?attr/colorPrimary"
            app:indicatorSize="20dp"
            app:trackThickness="2dp" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/time_label"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurface"
            tools:text="5 min ago" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/size_label"
            style="@style/TextAppearance.Material3.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="1.2 MB" />

    </LinearLayout>

    <ImageView
        android:id="@+id/stop_action"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/debug_debuglog_sessions_stop_action"
        android:padding="6dp"
        android:src="@drawable/ic_cancel"
        android:visibility="gone"
        app:tint="?attr/colorError"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/delete_action"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/general_delete_action"
        android:padding="6dp"
        android:src="@drawable/ic_delete"
        app:tint="?attr/colorOnSurfaceVariant" />

</LinearLayout>
