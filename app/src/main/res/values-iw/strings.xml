    <string name="onboarding_welcome_title">ברוכים הבאים</string>
    <string name="onboarding_welcome_body1">SD Maid SE - מנהל קבצים, אפליקציות ואחסון.</string>
    <string name="onboarding_welcome_body2">השג שטח אחסון בעזרת ניקוי שאריות של אפליקציות אחרות. מחק קבצים לא נחוצים או זמניים והסר שאריות של נתונים.</string>
    <string name="onboarding_welcome_body_beta">זוהי גרסאת בטא (בדיקות), השתמשו בה עם חוש הומור ותכנית גיבוי. דווחו בבקשה על בעיות שנתקלתם בהן.</string>
    <string name="onboarding_welcome_continue_action">המשך</string>
    <string name="onboarding_versus_title">SD Maid / SD Maid SE</string>
    <string name="onboarding_versus_body1">SD Maid SE (aka. SD Maid 2) היא היורשת של SD Maid (aka. SD Maid 1). אפליקציה חדשה, מותאמת לאנדרואיד מודרנית.</string>
    <string name="onboarding_versus_body2">הארכיטקטורה של קודמו היא בת יותר מ- 7 שנים ואינה מיועדת לאתגרים של גרסאות אנדרואיד חדשות יותר. היה צורך בתכנון מחדש מלא כדי להמשיך בפיתוח.</string>
    <string name="onboarding_versus_body3">שקול לעבור ל-SD Maid SE לתוצאות משופרות.</string>
    <string name="onboarding_versus_body4">\"סטטוס פרו\" של SD Maid 1, למרבה הצער, אינו ניתן להעברה ל-SD Maid 2/SE. לאחר 12 שנים של עדכונים בחינם, נדרשת רכישה חדשה כדי לקיים את הפיתוח (להאכיל את המפתח).</string>
    <string name="onboarding_versus_continue_action">המשך</string>
