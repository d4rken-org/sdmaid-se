    <string name="appcontrol_toggle_app_enable_description">একটি অ্যাপ্লিকেশান সক্রিয় করে এটিকে চালানোর অনুমতি দেয় এবং যদি এটির কোনো কার্যকলাপ থাকে তবে এটি আপনার লঞ্চারে দৃশ্যমান করতে পারে৷</string>
