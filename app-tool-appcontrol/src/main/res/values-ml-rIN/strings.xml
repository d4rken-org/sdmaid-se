<resources>
    <string name="appcontrol_explanation_short">നിങ്ങളുടെ ഉപകരണത്തിൽ ഇൻസ്റ്റാൾ ചെയ്ത ആപ്പുകൾ.</string>
    <string name="appcontrol_toggle_app_selection_action">ആപ്പുകൾ ടോഗിൾ ചെയ്യുക</string>
    <string name="appcontrol_toggle_app_enable_action">ആപ്പ് പ്രവർത്തനക്ഷമമാക്കുക</string>
    <string name="appcontrol_toggle_app_disable_action">ആപ്പ് നിഷ്ക്രിയമാക്കുക</string>
    <string name="appcontrol_toggle_app_enable_description">ഒരു ആപ്പ് പ്രവർത്തനക്ഷമമാക്കുന്നത് അത് പ്രവർത്തിക്കാൻ അനുവദിക്കുകയും, ഒരു ആക്റ്റിവിറ്റി ഉണ്ടെങ്കിൽ ലോഞ്ചറിൽ ദൃശ്യമാക്കുകയും ചെയ്യാം.</string>
    <string name="appcontrol_toggle_app_disable_description">ഒരു ആപ്പ് നിഷ്ക്രിയമാക്കുന്നത് അത് പ്രവർത്തിക്കുന്നതിൽ നിന്ന് തടയുകയും മെനുകളിൽ നിന്ന് മറയ്ക്കുകയും ചെയ്യും. ഡേറ്റ നഷ്ടമില്ല.</string>
    <string name="appcontrol_appstore_open_title">ആപ്പ് സ്റ്റോറിൽ തുറക്കുക</string>
    <string name="appcontrol_appstore_open_description">ഈ ആപ്പ് ഇൻസ്റ്റാൾ ചെയ്ത ആപ്പ് സ്റ്റോറിൽ ഇത് തുറക്കുക.</string>
    <string name="appcontrol_systemsettings_open_description">ഈ ആപ്പിനായി ഉപകരണത്തിന്റെ സിസ്റ്റം ക്രമീകരണങ്ങൾ തുറക്കുക.</string>
    <string name="appcontrol_app_launch_title">ആപ്പ് സമാരംഭിക്കുക</string>
    <string name="appcontrol_app_launch_description">ഈ ആപ്പിന്റെ പ്രാഥമിക ആക്റിവിറ്റി സമാരംഭിക്കുക.</string>
    <string name="appcontrol_app_forcestop_title">ഫോർസ് സ്റ്റോപ്പ്</string>
    <string name="appcontrol_app_forcestop_description">ആപ്പ് നിര്ത്തുക. ഉപകരണം റീബൂട് ചെയ്യുന്നത് \u0d35രെ കിആപ്പ് തുറക്കുന്നത് വരെ സ്വയം ആരംഭിക്കുന്നതിൽ നിന്ന് തടയുക.</string>
    <string name="appcontrol_app_uninstall_description">ഈ ആപ്പ് ഉപകരണത്തിൽ നിന്ന് അൻ ഇൻസ്റ്റാൾ ചെയ്യുക.</string>
