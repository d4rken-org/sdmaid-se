<resources>
    <string name="appcontrol_explanation_short">உங்கள் சாதனத்தில் நிறுவப்பட்ட பயன்பாடுகள்.</string>
    <string name="appcontrol_toggle_app_selection_action">பயன்பாடுகளை மாற்று</string>
    <string name="appcontrol_toggle_app_enable_action">பயன்பாடை இயக்கு</string>
    <string name="appcontrol_toggle_app_disable_action">பயன்பாடை முடக்கு</string>
    <string name="appcontrol_toggle_app_enable_description">பயன்பாடை இயக்குவது அதை இயங்க அனுமதிக்கும் மற்றும் அதில் செயல்பாடு இருந்தால் உங்கள் லாஞ்சரில் தெரியுமாக இருக்கலாம்.</string>
    <string name="appcontrol_toggle_app_disable_description">பயன்பாடை முடக்குவது அதை இயங்கவிடாமல் தடுக்கும் மற்றும் பட்டியல்களிலிருந்து மறைக்கும். தரவு இழப்பு இல்லை.</string>
    <string name="appcontrol_appstore_open_title">பயன்பாட்டு கடையில் திறக்கு</string>
    <string name="appcontrol_appstore_open_description">இந்த பயன்பாடை அது நிறுவப்பட்ட பயன்பாட்டு கடையில் திறக்கவும்.</string>
    <string name="appcontrol_systemsettings_open_description">இந்த பயன்பாட்டிற்கான உங்கள் சாதனத்தின் கணினி அமைப்புகளைத் திறக்கவும்.</string>
    <string name="appcontrol_app_launch_title">பயன்பாடைத் தொடங்கு</string>
    <string name="appcontrol_app_launch_description">இந்த பயன்பாட்டின் முக்கிய செயல்பாடைத் தொடங்கு.</string>
    <string name="appcontrol_app_forcestop_title">வலையுள்ள நிறுத்தம்</string>
    <string name="appcontrol_app_forcestop_description">செயலியை நிறுத்து. நீங்கள் திறக்கும் வரை அல்லது சாதனம் மறுதொடக்கம் செய்யும் வரை தானாகவே தொடங்குவதைத் தடு.</string>
    <string name="appcontrol_app_uninstall_description">இந்த பயன்பாடை உங்கள் சாதனத்திலிருந்து அன்இன்ஸ்டால் செய்வது.</string>
    <string name="appcontrol_app_exclude_add_title">பயன்பாடை விலக்கு</string>
    <string name="appcontrol_app_exclude_add_description">இந்த பயன்பாடை SD Maid இன் மற்ற செயல்பாடுகளிலிருந்து விலக்கு.</string>
    <string name="appcontrol_app_exclude_edit_title">விலக்கலைத் தருணி</string>
    <string name="appcontrol_app_exclude_edit_description">இந்த பயன்பாடு தற்போது ஒன்று அல்லது அதிகமான கருவிகளிலிருந்து விலக்கப்பட்டுள்ளது.</string>
