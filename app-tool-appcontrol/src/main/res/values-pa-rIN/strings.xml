    <string name="appcontrol_explanation_short">ਤੁਹਾਡੇ ਡਿਵਾਈਸ \'ਤੇ ਸਥਾਪਿਤ ਐਪਾਂ।</string>
    <string name="appcontrol_toggle_app_selection_action">ਐਪਾਂ ਨੂੰ ਟੌਗਲ ਕਰੋ</string>
    <string name="appcontrol_toggle_app_enable_action">ਐਪ ਨੂੰ ਸਮਰੱਥ ਕਰੋ</string>
    <string name="appcontrol_toggle_app_disable_action">ਐਪ ਨੂੰ ਅਸਮਰੱਥ ਕਰੋ</string>
    <string name="appcontrol_toggle_app_enable_description">ਐਪ ਨੂੰ ਸਮਰੱਥ ਕਰਨਾ ਇਸਨੂੰ ਚੱਲਣ ਦੀ ਇਜਾਜ਼ਤ ਦਿੰਦਾ ਹੈ ਅਤੇ ਜੇ ਇਸਦੀ ਕੋਈ ਐਕਟੀਵਿਟੀ ਹੈ ਤਾਂ ਇਸਨੂੰ ਤੁਹਾਡੇ ਲਾਂਚਰ ਵਿੱਚ ਦਿਖਾਈ ਦੇ ਸਕਦਾ ਹੈ।</string>
    <string name="appcontrol_toggle_app_disable_description">ਐਪ ਨੂੰ ਅਸਮਰੱਥ ਕਰਨਾ ਇਸਨੂੰ ਚੱਲਣ ਤੋਂ ਰੋਕਦਾ ਹੈ ਅਤੇ ਇਸਨੂੰ ਮੀਨੂ ਤੋਂ ਲੁਕਾ ਦਿੰਦਾ ਹੈ। ਕੋਈ ਡਾਟਾ ਦਾ ਨੁਕਸਾਨ ਨਹੀਂ ਹੁੰਦਾ।</string>
    <string name="appcontrol_appstore_open_title">ਐਪ ਸਟੋਰ ਵਿੱਚ ਖੋਲ੍ਹੋ</string>
    <string name="appcontrol_appstore_open_description">ਇਸ ਐਪ ਨੂੰ ਉਸ ਐਪ ਸਟੋਰ ਵਿੱਚ ਖੋਲ੍ਹੋ ਜਿੱਥੋਂ ਇਹ ਸਥਾਪਿਤ ਕੀਤੀ ਗਈ ਸੀ।</string>
    <string name="appcontrol_systemsettings_open_description">ਇਸ ਐਪ ਲਈ ਆਪਣੇ ਡਿਵਾਈਸ ਦੀਆਂ ਸਿਸਟਮ ਸੈਟਿੰਗਾਂ ਖੋਲ੍ਹੋ।</string>
    <string name="appcontrol_app_launch_title">ਐਪ ਚਲਾਓ</string>
