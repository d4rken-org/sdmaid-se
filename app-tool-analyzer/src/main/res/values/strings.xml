    <string name="analyzer_storage_type_primary_title">Primary storage</string>
    <string name="analyzer_storage_type_primary_description">The primary storage of your device. Contains the internal SD card, private storage for apps and system data.</string>
    <string name="analyzer_storage_type_secondary_title">Secondary storage</string>
    <string name="analyzer_storage_type_secondary_description">A secondary storage, usually a removable SD card. Contains media files and data from apps that support it.</string>
    <string name="analyzer_storage_type_tertiary_title">Portable storage</string>
    <string name="analyzer_storage_type_tertiary_description">A portable storage, e.g. a flash drive plugged into your USB port.</string>
    <string name="analyzer_storage_content_title">Storage content</string>
    <string name="analyzer_storage_content_type_app_label">Apps</string>
    <string name="analyzer_storage_content_type_app_description">Space occupied by installed apps and their data (i.e. application files, data and caches).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Permissions are missing</string>
    <string name="analyzer_storage_content_type_media_label">User files</string>
    <string name="analyzer_storage_content_type_media_description">Captured pictures, recorded videos or downloaded data. Any data that doesn\'t belong to a specific app.</string>
    <string name="analyzer_storage_content_type_system_label">System data</string>
    <string name="analyzer_storage_content_type_system_description">System apps and system data. Apps and data from other users, if several user accounts are set on this device.</string>
    <string name="analyzer_storage_content_app_code_label">App code</string>
    <string name="analyzer_storage_content_app_code_description">Application files, libraries and resources. This space can be freed by uninstalling the app or archiving it (available on newer Android version).</string>
    <string name="analyzer_storage_content_app_data_label">App data</string>
    <string name="analyzer_storage_content_app_data_description">Data, settings and caches.</string>
    <string name="analyzer_storage_content_app_media_label">App media</string>
    <string name="analyzer_storage_content_app_media_description">Media files from this app, e.g. received WhatsApp photos.</string>
    <string name="analyzer_storage_content_app_extra_label">Extra app files</string>
    <string name="analyzer_storage_content_app_extra_description">Extra data that this app has placed outside of the default paths, e.g. photos or downloads.</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">This app occupies %1$s on \"%2$s\".</string>
    <string name="analyzer_app_details_app_is_archived">This app has been archived.</string>
