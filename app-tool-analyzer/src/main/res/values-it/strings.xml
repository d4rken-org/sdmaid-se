    <string name="analyzer_storage_type_primary_title">Archivio principale</string>
    <string name="analyzer_storage_type_primary_description">L\'archiviazione primaria del tuo dispositivo. Contiene la memoria di sistema e quella di applicazioni e dati dell\'utente.</string>
    <string name="analyzer_storage_type_secondary_title">Archivio secondario</string>
    <string name="analyzer_storage_type_secondary_description">L\'archiviazione secondaria, di solito una MicroSD. Contiene file multimediali e dati dalle applicazioni che la supportano.</string>
    <string name="analyzer_storage_type_tertiary_title">Memoria esterna</string>
    <string name="analyzer_storage_type_tertiary_description">Una memoria esterna, ad esempio un\'unità flash collegata alla porta USB.</string>
    <string name="analyzer_storage_content_title">Contenuto della memoria</string>
    <string name="analyzer_storage_content_type_app_label">App</string>
    <string name="analyzer_storage_content_type_app_description">Spazio occupato da app installate e dai loro dati (cioè file di app, dati e cache).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Permessi mancanti</string>
    <string name="analyzer_storage_content_type_media_label">File Utente</string>
    <string name="analyzer_storage_content_type_media_description">Foto e video dalla fotocamera o dati scaricati. Tutti i dati che non appartengono a una specifica app.</string>
    <string name="analyzer_storage_content_type_system_label">Dati di sistema</string>
    <string name="analyzer_storage_content_type_system_description">App di sistema e dati di sistema. Applicazioni e dati di altri utenti, se ci sono più account utente in questo dispositivo.</string>
    <string name="analyzer_storage_content_type_system_other_label">Altro</string>
    <string name="analyzer_storage_content_type_system_info">File che non rientrano nelle categorie App o File utente. Solo navigazione — l\'eliminazione non è supportata. Alcune aree potrebbero essere incomplete a causa di restrizioni di accesso.</string>
    <string name="analyzer_storage_content_type_system_other_desc">File di sistema e altri dati a cui SD Maid non ha potuto accedere o categorizzare. Il sistema operativo limita l\'elenco dei contenuti di alcune aree.</string>
    <string name="analyzer_storage_content_app_code_label">Codice app</string>
    <string name="analyzer_storage_content_app_code_description">File di applicazioni, librerie e risorse. Questo spazio può essere liberato disinstallando l\'app oppure archiviandola (disponibile nella versione di android più recente).</string>
    <string name="analyzer_storage_content_app_data_label">Dati app</string>
    <string name="analyzer_storage_content_app_data_description">Dati, impostazioni e cache.</string>
    <string name="analyzer_storage_content_app_media_label">App media</string>
    <string name="analyzer_storage_content_app_media_description">File multimediali di applicazioni, ad esempio foto ricevute su WhatsApp.</string>
    <string name="analyzer_storage_content_app_extra_label">File extra di app</string>
    <string name="analyzer_storage_content_app_extra_description">Dati aggiuntivi che l\'app ha posizionato al di fuori dei percorsi predefiniti, ad esempio foto o download.</string>
