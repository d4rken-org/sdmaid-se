    <string name="analyzer_storage_type_primary_title">プライマリストレージ</string>
    <string name="analyzer_storage_type_primary_description">デバイスのプライマリストレージ。内部SDカード、アプリとシステムデータ用のプライベートストレージが含まれています。</string>
    <string name="analyzer_storage_type_secondary_title">セカンダリストレージ</string>
    <string name="analyzer_storage_type_secondary_description">セカンダリストレージ、通常はリムーバブルSDカード。メディアファイルとそれをサポートするアプリからのデータが含まれています。</string>
    <string name="analyzer_storage_type_tertiary_title">ポータブルストレージ</string>
