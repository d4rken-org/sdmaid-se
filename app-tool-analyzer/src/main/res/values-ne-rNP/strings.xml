<resources>
    <string name="analyzer_explanation_short">तपाईंको उपकरणमा के कुराले ठाउँ ओगटेको छ भनेर पत्ता लगाउनुहोस्।</string>
    <string name="analyzer_progress_scanning_device">भण्डारण उपकरणहरू खोज्दै</string>
    <string name="analyzer_progress_scanning_storage">भण्डारण स्क्यान गर्दै</string>
    <string name="analyzer_progress_scanning_apps">Apps स्क्यान गर्दै</string>
    <string name="analyzer_progress_scanning_userfiles">प्रयोगकर्ता फाइलहरू खोज्दै</string>
    <string name="analyzer_progress_scanning_system">सिस्टम डेटा स्क्यान गर्दै</string>
    <string name="analyzer_device_storage_title">उपकरण भण्डारण</string>
    <string name="analyzer_content_access_opaque">प्रत्यक्ष पहुँच उपलब्ध छैन</string>
    <string name="analyzer_storage_type_primary_title">प्राथमिक भण्डारण</string>
    <string name="analyzer_storage_type_primary_description">तपाईंको उपकरणको प्राथमिक भण्डारण। यसमा आन्तरिक SD card, apps का लागि निजी भण्डारण र सिस्टम डेटा समावेश छ।</string>
    <string name="analyzer_storage_type_secondary_title">द्वितीयक भण्डारण</string>
    <string name="analyzer_storage_type_secondary_description">द्वितीयक भण्डारण, सामान्यतया हटाउन मिल्ने SD card। यसमा मिडिया फाइलहरू र यसलाई समर्थन गर्ने apps का डेटा समावेश छ।</string>
    <string name="analyzer_storage_type_tertiary_title">पोर्टेबल भण्डारण</string>
    <string name="analyzer_storage_type_tertiary_description">पोर्टेबल भण्डारण, जस्तै तपाईंको USB port मा जडान गरिएको flash drive।</string>
    <string name="analyzer_storage_content_title">भण्डारण सामग्री</string>
    <string name="analyzer_storage_content_type_app_description">स्थापित apps र तिनीहरूको डेटाले ओगटेको ठाउँ (अर्थात् application फाइलहरू, डेटा र caches)।</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">अनुमतिहरू छुटेका छन्</string>
    <string name="analyzer_storage_content_type_media_label">प्रयोगकर्ता फाइलहरू</string>
    <string name="analyzer_storage_content_type_media_description">खिचिएका तस्बिरहरू, रेकर्ड गरिएका भिडियोहरू वा डाउनलोड गरिएका डेटा। कुनै विशेष app को नभएको कुनै पनि डेटा।</string>
    <string name="analyzer_storage_content_type_system_label">सिस्टम डेटा</string>
    <string name="analyzer_storage_content_type_system_description">सिस्टम apps र सिस्टम डेटा। यदि यस उपकरणमा धेरै प्रयोगकर्ता खाताहरू सेट छन् भने अन्य प्रयोगकर्ताहरूका Apps र डेटा।</string>
    <string name="analyzer_storage_content_app_code_label">App कोड</string>
    <string name="analyzer_storage_content_app_code_description">Application फाइलहरू, libraries र संसाधनहरू। यो ठाउँ app हटाएर वा archive गरेर (नयाँ Android version मा उपलब्ध) फ्री गर्न सकिन्छ।</string>
    <string name="analyzer_storage_content_app_data_label">App डेटा</string>
    <string name="analyzer_storage_content_app_data_description">डेटा, सेटिङहरू र caches।</string>
    <string name="analyzer_storage_content_app_media_label">App मिडिया</string>
    <string name="analyzer_storage_content_app_media_description">यस app बाट मिडिया फाइलहरू, जस्तै प्राप्त भएका WhatsApp फोटोहरू।</string>
    <string name="analyzer_storage_content_app_extra_label">अतिरिक्त app फाइलहरू</string>
    <string name="analyzer_storage_content_app_extra_description">यस app ले पूर्वनिर्धारित paths बाहिर राखेको अतिरिक्त डेटा, जस्तै फोटोहरू वा डाउनलोडहरू।</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">यो app ले \"%2$s\" मा %1$s ओगटेको छ।</string>
    <string name="analyzer_app_details_app_is_archived">यो app संग्रहित गरिएको छ।</string>
</resources>
