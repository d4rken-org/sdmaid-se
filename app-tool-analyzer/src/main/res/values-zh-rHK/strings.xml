    <string name="analyzer_storage_type_primary_title">主要儲存空間</string>
    <string name="analyzer_storage_type_primary_description">您裝置的主要儲存空間，包含內部「SD 卡」、應用程式和系統資料的私人儲存空間。</string>
    <string name="analyzer_storage_type_secondary_title">次要儲存空間</string>
    <string name="analyzer_storage_type_secondary_description">次要儲存空間，通常是卸除式 SD 卡。包含媒體檔案和受支援的應用程式資料。</string>
    <string name="analyzer_storage_type_tertiary_title">第三級儲存空間</string>
    <string name="analyzer_storage_type_tertiary_description">第三級儲存空間是額外的儲存裝置（例如 USB 隨身碟）。</string>
    <string name="analyzer_storage_content_title">儲存空間內容</string>
    <string name="analyzer_storage_content_type_app_label">應用程式</string>
    <string name="analyzer_storage_content_type_app_description">已安裝的應用程式及其資料 (即應用程式檔案、資料和快取) 佔用的空間。</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">權限遺失</string>
    <string name="analyzer_storage_content_type_media_label">使用者檔案</string>
    <string name="analyzer_storage_content_type_media_description">擷取的圖片、錄製的影片或已下載的資料，任何不屬於特定應用程式的資料。</string>
    <string name="analyzer_storage_content_type_system_label">系統資料</string>
    <string name="analyzer_storage_content_type_system_description">系統應用程式和系統資料，即來自其他使用者的應用程式和資料 (如果此裝置上有多位使用者)。</string>
    <string name="analyzer_storage_content_type_system_other_label">其他</string>
    <string name="analyzer_storage_content_type_system_info">不屬於「應用程式」或「使用者檔案」類別的檔案。僅供瀏覽——不支援刪除。由於存取限制，部分區域內容可能不完整。</string>
    <string name="analyzer_storage_content_type_system_other_desc">SD Maid 無法存取或分類的系統檔案及其他資料。作業系統限制列出某些區域的內容。</string>
    <string name="analyzer_storage_content_app_code_label">應用程式程式碼</string>
    <string name="analyzer_storage_content_app_code_description">APK 檔案和其他安裝相關檔案</string>
    <string name="analyzer_storage_content_app_data_label">應用程式資料</string>
    <string name="analyzer_storage_content_app_data_description">資料、設定和快取。</string>
    <string name="analyzer_storage_content_app_media_label">應用程式媒體</string>
    <string name="analyzer_storage_content_app_media_description">來自這個應用程式的媒體檔案，例如接收的 WhatsApp 相片。</string>
    <string name="analyzer_storage_content_app_extra_label">額外應用程式檔案</string>
    <string name="analyzer_storage_content_app_extra_description">這個應用程式放置在預設路徑之外的額外資料，例如相片和下載項目。</string>
