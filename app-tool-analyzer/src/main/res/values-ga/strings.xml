    <string name="analyzer_storage_type_primary_title">Príomhstóráil</string>
    <string name="analyzer_storage_type_primary_description">Príomhstór do ghléis. Cuimsíonn sé an cárta SD inmheánach, stór príobháideach d\'aipeanna agus sonraí córais.</string>
    <string name="analyzer_storage_type_secondary_title">Stór tánaisteach</string>
    <string name="analyzer_storage_type_secondary_description">Stór tánaisteach, de ghnáth cárta SD inbhainte. Cuimsíonn sé comhaid meán agus sonraí ó aipeanna a thacaíonn leis.</string>
    <string name="analyzer_storage_type_tertiary_title">Stór iniompartha</string>
    <string name="analyzer_storage_type_tertiary_description">Stór iniompartha, m.sh. tiomántán flash plugáilte isteach i do phort USB.</string>
    <string name="analyzer_storage_content_title">Ábhar stórála</string>
    <string name="analyzer_storage_content_type_app_label">Aipeanna</string>
    <string name="analyzer_storage_content_type_app_description">Spás atá á úsáid ag aipeanna suiteáilte agus a sonraí (is é sin comhaid feidhmchlár, sonraí agus taiscí).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Tá ceadanna ar iarraidh</string>
    <string name="analyzer_storage_content_type_media_label">Comhaid úsáideora</string>
    <string name="analyzer_storage_content_type_media_description">Pictiúir gabhtha, físeáin taifeadta nó sonraí íoslódáilte. Aon sonraí nach mbaineann le haip ar leith.</string>
    <string name="analyzer_storage_content_type_system_label">Sonraí córais</string>
    <string name="analyzer_storage_content_type_system_description">Aipeanna córais agus sonraí córais. Aipeanna agus sonraí ó úsáideoirí eile, má tá cuntais úsáideora iolracha socraithe ar an ngléas seo.</string>
    <string name="analyzer_storage_content_app_code_label">Cód aipe</string>
    <string name="analyzer_storage_content_app_code_description">Comhaid feidhmchláir, leabharlanna agus acmhainní. Is féidir an spás seo a shaoradh trí dhíshuiteáil an aip nó é a chur i gcartlann (ar fáil ar leaganacha Android níos nuaí).</string>
    <string name="analyzer_storage_content_app_data_label">Sonraí aipe</string>
    <string name="analyzer_storage_content_app_data_description">Sonraí, socruithe agus taiscí.</string>
    <string name="analyzer_storage_content_app_media_label">Meáin aipe</string>
    <string name="analyzer_storage_content_app_media_description">Comhaid meán ón aip seo, m.sh. grianghraif WhatsApp faighte.</string>
    <string name="analyzer_storage_content_app_extra_label">Comhaid aipe breise</string>
    <string name="analyzer_storage_content_app_extra_description">Sonraí breise atá curtha ag an aip seo lasmuigh de na conairí réamhshocraithe, m.sh. grianghraif nó íoslódálacha.</string>
