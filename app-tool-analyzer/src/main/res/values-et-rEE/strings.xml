    <string name="analyzer_storage_type_primary_title">Peamine hoiuruum</string>
    <string name="analyzer_storage_type_primary_description">Seadme peamine hoiuruum. Sisaldab sisemälu ja isiklikku hoiuruumi rakenduste ning süsteemiandmete jaoks.</string>
    <string name="analyzer_storage_type_secondary_title">Muu hoiuruum</string>
    <string name="analyzer_storage_type_secondary_description">Teisejärguline hoiuruum, tavaliselt eemaldatav SD-kaart. Sisaldab seda toetavat meediafaile ja rakenduste andmeid.</string>
    <string name="analyzer_storage_type_tertiary_title">Kaasaskantav mälu</string>
    <string name="analyzer_storage_type_tertiary_description">Näiteks USB-pessa pistetud mälupulk.</string>
    <string name="analyzer_storage_content_title">Hoiustatav sisu</string>
    <string name="analyzer_storage_content_type_app_label">Rakendused</string>
    <string name="analyzer_storage_content_type_app_description">Paigaldatud rakenduste ja nende andmete (nt rakenduse failid, andmed ja vahemälud) hoiuruum.</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Pole lube</string>
    <string name="analyzer_storage_content_type_media_label">Kasutaja failid</string>
    <string name="analyzer_storage_content_type_media_description">Jäädvustatud pildid, salvestatud videod või alla laaditud andmed. Kõik kindlale rakendusele mitte kuuluvad andmed.</string>
    <string name="analyzer_storage_content_type_system_label">Süsteemi andmed</string>
    <string name="analyzer_storage_content_type_system_description">Süsteemi rakendused ja andmed. Muude kasutajate rakendused ja andmed, kui seadmes on seadistatud mitu kasutajakontot.</string>
    <string name="analyzer_storage_content_type_system_other_label">Muu</string>
    <string name="analyzer_storage_content_type_system_info">Failid, mis ei kuulu rakenduste ega kasutajafailide kategooriatesse. Ainult sirvimine — kustutamine pole toetatud. Mõned alad võivad olla mittetäielikud juurdepääsupiirangute tõttu.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Süsteemifailid ja muud andmed, millele SD Maid ei saanud juurde pääseda ega kategoriseerida. Operatsioonisüsteem piirab mõnede alade sisu loetlemist.</string>
    <string name="analyzer_storage_content_app_code_label">Rakenduse kood</string>
    <string name="analyzer_storage_content_app_code_description">Rakenduse failid, teegid ja allikad. Sellle ruumi vabastamiseks eemaldage rakendus või arhiveerige see (saadaval uusimas Androidi versioonis).</string>
    <string name="analyzer_storage_content_app_data_label">Rakenduse andmed</string>
    <string name="analyzer_storage_content_app_data_description">Andmed, seaded ja vahemälud.</string>
    <string name="analyzer_storage_content_app_media_label">Rakenduse meedia</string>
    <string name="analyzer_storage_content_app_media_description">Selle rakenduse meediafailid, nt vastuvõetud WhatsAppi pildid.</string>
    <string name="analyzer_storage_content_app_extra_label">Rakenduse täiendavad failid</string>
    <string name="analyzer_storage_content_app_extra_description">Lisaandmed, mis ei asu rakenduse tavapärastes asukohtades, nt pildid või alla laaditud sisu.</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">Sellele rakendusele kuulub kohas \"%2$s\" %1$s.</string>
