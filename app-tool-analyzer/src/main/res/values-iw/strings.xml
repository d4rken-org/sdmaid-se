    <string name="analyzer_storage_type_primary_title">אחסון ראשי</string>
    <string name="analyzer_storage_type_primary_description">האחסון הראשי של המכשיר שלך. מכיל את כרטיס ה-SD הפנימי, אחסון פרטי לאפליקציות ונתוני מערכת.</string>
    <string name="analyzer_storage_type_secondary_title">אחסון משני</string>
    <string name="analyzer_storage_type_secondary_description">אחסון משני, בדרך כלל כרטיס SD נשלף. מכיל קבצי מדיה ונתונים מאפליקציות התומכות בכך.</string>
    <string name="analyzer_storage_type_tertiary_title">אחסון נייד</string>
    <string name="analyzer_storage_type_tertiary_description">אחסון נייד, למשל. כונן הבזק מחובר ליציאת ה-USB שלך.</string>
    <string name="analyzer_storage_content_title">תוכן אחסון</string>
    <string name="analyzer_storage_content_type_app_label">יישומים</string>
    <string name="analyzer_storage_content_type_app_description">מקום תפוס על ידי אפליקציות מותקנות והנתונים שלהן (כלומר קבצי יישומים, נתונים ומטמונים).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">חסרות הרשאות</string>
    <string name="analyzer_storage_content_type_media_label">קבצי משתמש</string>
    <string name="analyzer_storage_content_type_media_description">תמונות שצולמו, סרטונים מוקלטים או נתונים שהורדו. כל נתונים שאינם שייכים לאפליקציה מסוימת.</string>
    <string name="analyzer_storage_content_type_system_label">נתוני מערכת</string>
    <string name="analyzer_storage_content_type_system_description">אפליקציות מערכת ונתוני מערכת. אפליקציות ונתונים ממשתמשים אחרים, אם מוגדרים מספר חשבונות משתמש במכשיר זה.</string>
    <string name="analyzer_storage_content_type_system_other_label">אחר</string>
    <string name="analyzer_storage_content_type_system_info">קבצים שאינם מתאימים לקטגוריות אפליקציות או קבצי משתמש. עיון בלבד — מחיקה אינה נתמכת. ייתכן שחלק מהאזורים אינם שלמים עקב הגבלות גישה.</string>
    <string name="analyzer_storage_content_type_system_other_desc">קבצי מערכת ונתונים אחרים ש-SD Maid לא יכלה לגשת אליהם או לסווג. מערכת ההפעלה מגבילה את רישום תכולת חלק מהאזורים.</string>
    <string name="analyzer_storage_content_app_code_label">קוד אפליקציה</string>
    <string name="analyzer_storage_content_app_code_description">קבצי אפליקציות, ספריות ומשאבים. מקום זה יכול להתפנות על ידי הסרת האפליקציה או אירכובה (זמין בגירסאות אנדרואיד חדשות).</string>
    <string name="analyzer_storage_content_app_data_label">נתוני יישום</string>
    <string name="analyzer_storage_content_app_data_description">נתונים, הגדרות ומטמונים.</string>
    <string name="analyzer_storage_content_app_media_label">מדיה של אפליקציה</string>
    <string name="analyzer_storage_content_app_media_description">קבצי מדיה מאפליקציה זו, למשל. תמונות וואטסאפ שהתקבלו.</string>
    <string name="analyzer_storage_content_app_extra_label">קבצי אפליקציה נוספים</string>
    <string name="analyzer_storage_content_app_extra_description">נתונים נוספים שהאפליקציה הזו מיקמה מחוץ לנתיבי ברירת המחדל, למשל. תמונות או הורדות.</string>
