    <string name="analyzer_storage_type_primary_title">Primární úložiště</string>
    <string name="analyzer_storage_type_primary_description">Primární úložiště vašeho zařízení. Obsahuje interní SD kartu, soukromé úložiště pro aplikace a systémová data.</string>
    <string name="analyzer_storage_type_secondary_title">Sekundární úložiště</string>
    <string name="analyzer_storage_type_secondary_description">Sekundární úložiště, obvykle vyměnitelná SD karta. Obsahuje mediální soubory a data z aplikací, které jej podporují.</string>
    <string name="analyzer_storage_type_tertiary_title">Přenosné úložiště</string>
    <string name="analyzer_storage_type_tertiary_description">Přenosné úložiště, např. flash disk připojen k USB.</string>
    <string name="analyzer_storage_content_title">Obsah úložiště</string>
    <string name="analyzer_storage_content_type_app_label">Aplikace</string>
    <string name="analyzer_storage_content_type_app_description">Prostor obsazený instalovanými aplikacemi a jejich daty (např. soubory aplikace, data a mezipaměť).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Chybí oprávnění</string>
    <string name="analyzer_storage_content_type_media_label">Soubory uživatele</string>
    <string name="analyzer_storage_content_type_media_description">Pořízené fotky, nahraná videa nebo stažená data. Jakákoliv data, která nepatří ke konkrétní aplikaci.</string>
    <string name="analyzer_storage_content_type_system_label">Systémová data</string>
    <string name="analyzer_storage_content_type_system_description">Systémové aplikace a systémová data. Aplikace a data od jiných uživatelů, pokud je v tomto zařízení nastaveno více uživatelských účtů.</string>
    <string name="analyzer_storage_content_type_system_other_label">Ostatní</string>
    <string name="analyzer_storage_content_type_system_info">Soubory, které nespadají do kategorií Aplikace nebo Uživatelské soubory. Pouze procházení — mazání není podporováno. Některé oblasti mohou být neúplné z důvodu omezení přístupu.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Systémové soubory a další data, ke kterým SD Maid nemohl přistupovat nebo je zařadit. Operační systém omezuje výpis obsahu některých oblastí.</string>
    <string name="analyzer_storage_content_app_code_label">Kód aplikace</string>
    <string name="analyzer_storage_content_app_code_description">Soubory aplikace, knihovny a prostředky. Tento prostor může být uvolněn odinstalováním aplikace nebo její archivací (dostupné v novějších verzích Android).</string>
    <string name="analyzer_storage_content_app_data_label">Data aplikace</string>
    <string name="analyzer_storage_content_app_data_description">Data, nastavení a mezipaměti.</string>
    <string name="analyzer_storage_content_app_media_label">Média aplikace</string>
    <string name="analyzer_storage_content_app_media_description">Mediální soubory z této aplikace, např. fotky přijaté z WhatsApp.</string>
    <string name="analyzer_storage_content_app_extra_label">Další soubory aplikace</string>
    <string name="analyzer_storage_content_app_extra_description">Další data, která tato aplikace umístila mimo výchozí cesty, např. fotky nebo stažené soubory.</string>
