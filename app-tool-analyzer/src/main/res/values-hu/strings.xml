    <string name="analyzer_storage_type_primary_title">Elsődleges tároló</string>
    <string name="analyzer_storage_type_primary_description">A készülék elsődleges tárhelye. Tartalmazza a belső SD-kártyát, az alkalmazások és a rendszeradatok privát tárhelyét.</string>
    <string name="analyzer_storage_type_secondary_title">Másodlagos tároló</string>
    <string name="analyzer_storage_type_secondary_description">Másodlagos tároló, általában egy cserélhető SD-kártya. Tartalmazza a médiafájlokat és az azt támogató alkalmazások adatait.</string>
    <string name="analyzer_storage_type_tertiary_title">Hordozható tárhely</string>
    <string name="analyzer_storage_type_tertiary_description">Hordozható tárhely, pl. egy USB-portra csatlakoztatott pendrive.</string>
    <string name="analyzer_storage_content_title">Tárhely tartalma</string>
    <string name="analyzer_storage_content_type_app_label">Appok</string>
    <string name="analyzer_storage_content_type_app_description">A telepített alkalmazások és adataik (azaz az alkalmazásfájlok, adatok és gyorsítótárak) által elfoglalt hely.</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Hiányoznak az engedélyek</string>
    <string name="analyzer_storage_content_type_media_label">Felhasználói fájlok</string>
    <string name="analyzer_storage_content_type_media_description">Felvett képek, rögzített videók vagy letöltött adatok. Minden olyan adat, amely nem tartozik egy adott alkalmazáshoz.</string>
    <string name="analyzer_storage_content_type_system_label">Rendszeradatok</string>
    <string name="analyzer_storage_content_type_system_description">Rendszeralkalmazások és rendszeradatok.  Alkalmazások és adatok más felhasználóktól, ha több felhasználói fiók van beállítva ezen az eszközön.</string>
    <string name="analyzer_storage_content_type_system_other_label">Egyéb</string>
    <string name="analyzer_storage_content_type_system_info">Az Alkalmazások vagy Felhasználói fájlok kategóriákba nem illő fájlok. Csak böngészés — a törlés nem támogatott. Egyes területek hozzáférési korlátok miatt hiányosak lehetnek.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Rendszerfájlok és egyéb adatok, amelyekhez az SD Maid nem fért hozzá, vagy nem tudta kategórizálni. Az operációs rendszer korlátozza egyes területek tartalomának listázását.</string>
    <string name="analyzer_storage_content_app_code_label">App kód</string>
    <string name="analyzer_storage_content_app_code_description">Alkalmazási fájlok, könyvtárak és erőforrások. Ez a hely felszabadítható az alkalmazás eltávolításával vagy archiválásával (az újabb Android-verziókban elérhető).</string>
    <string name="analyzer_storage_content_app_data_label">App adatok</string>
    <string name="analyzer_storage_content_app_data_description">Adatok, beállítások és gyorsítótárak.</string>
    <string name="analyzer_storage_content_app_media_label">App média</string>
    <string name="analyzer_storage_content_app_media_description">Médiafájlok ebből az alkalmazásból, pl. a kapott WhatsApp-fotók.</string>
    <string name="analyzer_storage_content_app_extra_label">Extra alkalmazásfájlok</string>
    <string name="analyzer_storage_content_app_extra_description">Extra adatok, amelyeket ez az alkalmazás az alapértelmezett elérési útvonalakon kívül helyezett el, pl. fényképek vagy letöltések.</string>
