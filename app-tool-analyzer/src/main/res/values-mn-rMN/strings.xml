    <string name="analyzer_storage_type_primary_title">Үндсэн хадгалах сан</string>
    <string name="analyzer_storage_type_primary_description">Таны төхөөрөмжийн үндсэн санаа. Дотоодын SD карт, аппуудын хувийн санаа болон системийн өгөгдөлийг агуулна.</string>
    <string name="analyzer_storage_type_secondary_title">Хоёрдогч хадгалах сан</string>
    <string name="analyzer_storage_type_secondary_description">Хоёрдолгох SD карт зэрэг хүн санаа. Медиа файлууд болон үүнийг дэмжиглэх аппуудын өгөгдөлийг агуулна.</string>
    <string name="analyzer_storage_type_tertiary_title">Зөөвчлэх санаа</string>
    <string name="analyzer_storage_type_tertiary_description">Зөөвчлэх санаа, жишээ нь USB портонд холбосон флэш драйв.</string>
    <string name="analyzer_storage_content_title">Хадгалах сангийн агуулга</string>
    <string name="analyzer_storage_content_type_app_label">Аппликешнүүд</string>
    <string name="analyzer_storage_content_type_app_description">Суулагдсан аппууд болон тэдгээрийн хэвийг эзласан зай (өөрөөр хэрэглүүрийн файл, өгөгдөл болон кэш).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Зөвшөөрөл дутагүй байна</string>
    <string name="analyzer_storage_content_type_media_label">Хэрэглэгчийн файлууд</string>
    <string name="analyzer_storage_content_type_media_description">Бүртгэсэн зураг, бичлэгдсэн видео эсвэл татаж авсан өгөгдөл. Тухайлагдсан аппд харьяагүй огн өгөгдөл.</string>
    <string name="analyzer_storage_content_type_system_label">Системийн өгөгдөл</string>
    <string name="analyzer_storage_content_type_system_description">Системийн аппууд болон өгөгдөл. Энэ төхөөрөмжт олон харилцааны аппууд болон өгөгдөл, энэ төхөөрөмжт олон хэрэглэгчдийн бүлтгүүд хэрэглэгчийн бүртгэс өгөгдөлдэх аппууд болон өгөгдөл.</string>
    <string name="analyzer_storage_content_type_system_other_label">Бусад</string>
    <string name="analyzer_storage_content_type_system_info">Аппууд эсвэл Хэрэглэгчийн файлуудын ангилалд багтахгүй файлууд. Зөвхөн харах боломжтой — устгах дэмжигдэхгүй. Хандалтын хязгаарлалтаас шалтгаалан зарим хэсэг дутуу байж болно.</string>
    <string name="analyzer_storage_content_type_system_other_desc">SD Maid хандаж чадаагүй буюу ангилж чадаагүй системийн файлууд болон бусад өгөгдөл. Үйлдлийн систем зарим хэсгийн агуулгыг жагсаахыг хязгаарладаг.</string>
    <string name="analyzer_storage_content_app_code_label">Аппын код</string>
    <string name="analyzer_storage_content_app_code_description">Аппликацийн файл, номдаллагууд болон нөөц. Аппыг устгах эсвэл архивлахад (шинэ Android хувилбарт боломжтой) зайг чөлөөлж болно.</string>
    <string name="analyzer_storage_content_app_data_label">Аппын өгөгдөл</string>
    <string name="analyzer_storage_content_app_data_description">Өгөгдөл, тохиргоо болон кэш.</string>
    <string name="analyzer_storage_content_app_media_label">Аппын медиа</string>
    <string name="analyzer_storage_content_app_media_description">Энэ аппын медиа файлууд, жишээ нь WhatsApp-аар авсан зураг.</string>
    <string name="analyzer_storage_content_app_extra_label">Аппын нэмэлт файлууд</string>
    <string name="analyzer_storage_content_app_extra_description">Энэ апп үндсэн замаас гадна тавьсан нэмэлт өгөгдөл, жишээ нь зураг эсвэл татаж авсан файлууд.</string>
