    <string name="analyzer_storage_type_primary_title">Primêre berging</string>
    <string name="analyzer_storage_type_primary_description">Die primêre berging van jou toestel. Bevat die interne SD kaart, private berging vir toepassings en stelsel data.</string>
    <string name="analyzer_storage_type_secondary_title">Sekondêre berging</string>
    <string name="analyzer_storage_type_secondary_description">\'n Sekondêre berging, gewoonlik \'n verwyderde SD kaart. Bevat media lêers en data van toepassings wat dit ondersteun.</string>
    <string name="analyzer_storage_type_tertiary_title">Draagbare berging</string>
    <string name="analyzer_storage_type_tertiary_description">\'n Draagbare berging, bv. \'n flits skyf ingeprop in jou USB poort.</string>
    <string name="analyzer_storage_content_title">Berging inhoud</string>
    <string name="analyzer_storage_content_type_app_label">Toepassings</string>
    <string name="analyzer_storage_content_type_app_description">Ruimte beset deur geïnstalleerde toepassings en hul data (d.w.s. toepassing lêers, data en kas).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Toestemmings ontbreek</string>
    <string name="analyzer_storage_content_type_media_label">Gebruiker lêers</string>
    <string name="analyzer_storage_content_type_media_description">Gevangde foto\'s, opgenome video\'s of afgelaai data. Enige data wat nie aan \'n spesifieke toepassing behoort nie.</string>
    <string name="analyzer_storage_content_type_system_label">Stelsel data</string>
    <string name="analyzer_storage_content_type_system_description">Stelsel toepassings en stelsel data. Toepassings en data van ander gebruikers, as verskeie gebruiker rekeninge op hierdie toestel gestel is.</string>
    <string name="analyzer_storage_content_type_system_other_label">Ander</string>
    <string name="analyzer_storage_content_type_system_info">Lêers wat nie in die Programme- of Gebruikerslêers-kategorieë pas nie. Slegs blaai — verwydering word nie ondersteun nie. Sommige areas kan onvolledig wees weens toegangsbeperkings.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Stelsellêers en ander data waartoe SD Maid nie toegang gehad het of kon kategoriseer nie. Die bedryfstelsel beperk die lys van die inhoud van sommige areas.</string>
    <string name="analyzer_storage_content_app_code_label">Toepassing kode</string>
    <string name="analyzer_storage_content_app_code_description">Toepassing lêers, biblioteke en hulpbronne. Hierdie ruimte kan bevry word deur die toepassing te deïnstalleer of dit te argiveer (beskikbaar op nuwer Android weergawe).</string>
    <string name="analyzer_storage_content_app_data_label">Toepassing data</string>
    <string name="analyzer_storage_content_app_data_description">Data, instellings en kas.</string>
    <string name="analyzer_storage_content_app_media_label">Toepassing media</string>
    <string name="analyzer_storage_content_app_media_description">Media lêers van hierdie toepassing, bv. ontvang WhatsApp foto\'s.</string>
    <string name="analyzer_storage_content_app_extra_label">Ekstra toepassing lêers</string>
    <string name="analyzer_storage_content_app_extra_description">Ekstra data wat hierdie toepassing buite die verstek paaie geplaas het, bv. foto\'s of aflaaie.</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">Hierdie toepassing beset %1$s op \"%2$s\".</string>
    <string name="analyzer_app_details_app_is_archived">Hierdie toepassing is geargiveer.</string>
