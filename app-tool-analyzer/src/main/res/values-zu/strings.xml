    <string name="analyzer_storage_type_primary_title">Isitoreji esiyinhloko</string>
    <string name="analyzer_storage_type_primary_description">Isitoreji esiyinhloko sedivayisi yakho. Siqukethe ikhadi le-SD langaphakathi, isitoreji sangasese sezinhlelo zokusebenza nedatha yesistimu.</string>
    <string name="analyzer_storage_type_secondary_title">Isitoreji sesibili</string>
    <string name="analyzer_storage_type_secondary_description">Isitoreji sesibili, ngokuvamile ikhadi le-SD elisusekayo. Siqukethe amafayela emidiya nedatha evela ezinhlelweni zokusebenza ezisisekelayo.</string>
    <string name="analyzer_storage_type_tertiary_title">Isitoreji esiphathekayo</string>
    <string name="analyzer_storage_type_tertiary_description">Isitoreji esiphathekayo, isib. i-flash drive enamathiselwe emnyangweni wakho we-USB.</string>
    <string name="analyzer_storage_content_title">Okuqukethwe yisitoreji</string>
    <string name="analyzer_storage_content_type_app_label">Izinhlelo zokusebenza</string>
    <string name="analyzer_storage_content_type_app_description">Isikhala esihlalwa yizinhlelo zokusebenza ezifakiwe nedatha yazo (okuyinto, amafayela ezinhlelo zokusebenza, idatha nama-cache).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Izimvume zilahlekelwe</string>
    <string name="analyzer_storage_content_type_media_label">Amafayela omsebenzisi</string>
    <string name="analyzer_storage_content_type_media_description">Izithombe ezithathiwe, amavidiyo arekhotiwe noma idatha elandiwe. Noma iyiphi idatha engeyona eyinhlelo lokusebenza elithile.</string>
    <string name="analyzer_storage_content_type_system_label">Idatha yesistimu</string>
    <string name="analyzer_storage_content_type_system_description">Izinhlelo zokusebenza zesistimu nedatha yesistimu. Izinhlelo zokusebenza nedatha kwabanye abasebenzisi, uma ama-akhawunti abasebenzisi ambalwa esetiwe kule divayisi.</string>
    <string name="analyzer_storage_content_type_system_other_label">Okunye</string>
    <string name="analyzer_storage_content_type_system_info">Amafayela angafaneli izigaba ze-Apps noma izifayela zomsebenzisi. Bhrowza kuphela — ukususa akusekelelwa. Ezinye izindawo zingaba nekhona okuswelekayo ngenxa yemikhawulo yokungena.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Amafayela esikhungo namanye idatha i-SD Maid engakwazi ukungena noma ukuhlukanisa. Uhlelo lwokusebenza luvimba ukubhaliswa kwamazwi ezindaweni ezithile.</string>
    <string name="analyzer_storage_content_app_code_label">Ikhodi yohlelo</string>
    <string name="analyzer_storage_content_app_code_description">Amafayela ohlelo, amathala ezincwadi nezinsiza. Lesi sikhala singakhululwa ngokususa uhlelo noma ngokusibekela (sitholakala kwinguqulo entsha ye-Android).</string>
    <string name="analyzer_storage_content_app_data_label">Idatha yohlelo</string>
    <string name="analyzer_storage_content_app_data_description">Idatha, izilungiselelo nama-cache.</string>
    <string name="analyzer_storage_content_app_media_label">Imidiya yohlelo</string>
    <string name="analyzer_storage_content_app_media_description">Amafayela emidiya avela kulo hlelo, isib. izithombe ze-WhatsApp ezitholiwe.</string>
    <string name="analyzer_storage_content_app_extra_label">Amafayela ohlelo engeziwe</string>
    <string name="analyzer_storage_content_app_extra_description">Idatha engeziwe lolu hlelo oluyibeke ngaphandle kwezindlela ezijwayelekile, isib. izithombe noma okwandiwe.</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">Lolu hlelo luhlala ku-%1$s ku-\"%2$s\".</string>
    <string name="analyzer_app_details_app_is_archived">Lolu hlelo lubekelwe.</string>
