    <string name="analyzer_storage_type_primary_title">Primārā krātuve</string>
    <string name="analyzer_storage_type_primary_description">Jūsu ierīces primārā krātuve. Satur iekšējo SD karti, lietotnes privāto krātuvi un sistēmas datus.</string>
    <string name="analyzer_storage_type_secondary_title">Sekundārā krātuve</string>
    <string name="analyzer_storage_type_secondary_description">Sekundārā krātuve, parāsti nōninamā SD karte. Satur multivides failus un datus no lietotnēm, kas to atbalsta.</string>
    <string name="analyzer_storage_type_tertiary_title">Pārnosāmā krātuve</string>
    <string name="analyzer_storage_type_tertiary_description">Pārnosāmā krātuve, piem., zibatmiņa, kas pievienota USB portam.</string>
