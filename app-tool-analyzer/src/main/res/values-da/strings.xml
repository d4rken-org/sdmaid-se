    <string name="analyzer_storage_type_primary_title">Primær lager</string>
    <string name="analyzer_storage_type_primary_description">Det primære lager på din enhed. Indeholder det interne SD-kort samt privat lager til apps og systemdata.</string>
    <string name="analyzer_storage_type_secondary_title">Sekundær lager</string>
    <string name="analyzer_storage_type_secondary_description">Et sekundært lager, normalt et udtageligt SD-kort. Indeholder mediefiler og data fra apps, som understøtter det.</string>
    <string name="analyzer_storage_type_tertiary_title">Flytbart lager</string>
    <string name="analyzer_storage_type_tertiary_description">En flytbar lagerenhed, f.eks. et USB-drev tilsluttet din USB-port.</string>
    <string name="analyzer_storage_content_title">Lagerindhold</string>
    <string name="analyzer_storage_content_type_app_label">Apps</string>
    <string name="analyzer_storage_content_type_app_description">Plads optaget af installerede apps og deres data (dvs. programfiler, data og cacher).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Tilladelser mangler</string>
    <string name="analyzer_storage_content_type_media_label">Brugerfiler</string>
    <string name="analyzer_storage_content_type_media_description">Billeder, videooptagelser eller downloadede data. Al data, der ikke hører til en bestemt app.</string>
    <string name="analyzer_storage_content_type_system_label">Systemdata</string>
    <string name="analyzer_storage_content_type_system_description">Systemapps og -data. Apps og data fra andre brugere, hvis enheden har flere brugerkonti.</string>
    <string name="analyzer_storage_content_type_system_other_label">Andet</string>
    <string name="analyzer_storage_content_type_system_info">Filer der ikke passer ind i kategorierne Apps eller Brugerfiler. Gennemse kun — sletning understøttes ikke. Nogle områder kan være ufuldstændige på grund af adgangsbegrænsninger.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Systemfiler og andre data, som SD Maid ikke kunne få adgang til eller kategorisere. Operativsystemet begrænser visningen af indholdet i nogle områder.</string>
    <string name="analyzer_storage_content_app_code_label">Appkode</string>
    <string name="analyzer_storage_content_app_code_description">Programfiler, biblioteker og ressourcer. Denne plads kan frigøres ved at afinstallere eller arkivere appen (tilgængelig på nyere Android-versioner).</string>
    <string name="analyzer_storage_content_app_data_label">Appdata</string>
    <string name="analyzer_storage_content_app_data_description">Data, indstillinger og cacher.</string>
    <string name="analyzer_storage_content_app_media_label">Appmedier</string>
    <string name="analyzer_storage_content_app_media_description">Mediefiler fra denne app, f.eks. modtagne WhatsApp-fotos.</string>
    <string name="analyzer_storage_content_app_extra_label">Ekstra appfiler</string>
    <string name="analyzer_storage_content_app_extra_description">Ekstra data, som denne app har gemt uden for standardstierne, f.eks. fotos eller downloads.</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">Denne app optager %1$s på \"%2$s\".</string>
    <string name="analyzer_app_details_app_is_archived">Denne app er blevet arkiveret.</string>
    <string name="analyzer_storage_trend_delta_in_7d">%s på 7d</string>
