    <string name="analyzer_storage_type_primary_title">Hauptspeicher</string>
    <string name="analyzer_storage_type_primary_description">Der Hauptspeicher Deines Geräts. Enthält die interne SD-Karte, nicht-öffentlichen Speicher für Apps und Systemdaten.</string>
    <string name="analyzer_storage_type_secondary_title">Sekundärer Speicher</string>
    <string name="analyzer_storage_type_secondary_description">Ein sekundärer Speicher, normalerweise eine herausnehmbare SD-Karte. Enthält Mediendateien und Daten von Apps, die ihn unterstützen.</string>
    <string name="analyzer_storage_type_tertiary_title">Tragbarer Speicher</string>
    <string name="analyzer_storage_type_tertiary_description">Ein tragbarer Speicher, z.B. ein Flash-Laufwerk, der an Ihren USB-Port angeschlossen ist.</string>
    <string name="analyzer_storage_content_title">Speicherinhalt</string>
    <string name="analyzer_storage_content_type_app_label">Apps</string>
    <string name="analyzer_storage_content_type_app_description">Von installierten Apps und deren Daten (z.B. Anwendungsdateien, Daten und Caches) belegter Speicherplatz.</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Berechtigungen fehlen</string>
    <string name="analyzer_storage_content_type_media_label">Benutzerdateien</string>
    <string name="analyzer_storage_content_type_media_description">Aufgenommene Bilder und Videos oder heruntergeladene Daten. Alle Daten, die nicht zu einer bestimmten App gehören.</string>
    <string name="analyzer_storage_content_type_system_label">Systemdaten</string>
    <string name="analyzer_storage_content_type_system_description">System-Apps und Systemdaten. Apps und Daten von anderen Benutzern, falls mehrere Benutzerkonten auf diesem Gerät eingerichtet sind.</string>
    <string name="analyzer_storage_content_type_system_other_label">Andere</string>
    <string name="analyzer_storage_content_type_system_info">Dateien, die nicht in die Kategorien „Apps“ oder „Benutzerdateien“ passen. Nur durchsuchen — Löschen wird nicht unterstützt. Einige Bereiche können aufgrund von Zugriffsbeschränkungen unvollständig sein.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Systemdateien und andere Daten, auf die SD Maid nicht zugreifen oder die es nicht kategorisieren konnte. Das Betriebssystem schränkt das Auflisten der Inhalte einiger Bereiche ein.</string>
    <string name="analyzer_storage_content_app_code_label">App-Code</string>
    <string name="analyzer_storage_content_app_code_description">Anwendungsdateien, Bibliotheken und Ressourcen. Dieser Speicherplatz kann freigegeben werden, indem die App deinstalliert oder archiviert wird (verfügbar bei neueren Android-Versionen).</string>
    <string name="analyzer_storage_content_app_data_label">App-Daten</string>
    <string name="analyzer_storage_content_app_data_description">Daten, Einstellungen und Caches.</string>
    <string name="analyzer_storage_content_app_media_label">App-Medien</string>
    <string name="analyzer_storage_content_app_media_description">Mediendateien von dieser App, z.B. empfangene WhatsApp Fotos.</string>
    <string name="analyzer_storage_content_app_extra_label">Zusätzliche App-Dateien</string>
    <string name="analyzer_storage_content_app_extra_description">Zusätzliche Daten, die diese App außerhalb der Standardpfade platziert hat, z.B. Fotos oder Downloads.</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">Diese App belegt %1$s auf \"%2$s\".</string>
    <string name="analyzer_app_details_app_is_archived">Diese App wurde archiviert.</string>
    <string name="analyzer_storage_trend_delta_in_7d">%s in 7T</string>
