    <string name="analyzer_storage_type_primary_title">Primarna pohrana</string>
    <string name="analyzer_storage_type_primary_description">Primarna pohrana vašeg uređaja. Sadrži internu SD karticu, privatnu pohranu za aplikacije i sistemske podatke.</string>
    <string name="analyzer_storage_type_secondary_title">Sekundarna pohrana</string>
    <string name="analyzer_storage_type_secondary_description">Sekundarna pohrana, obično uklonjiva SD kartica. Sadrži medijske datoteke i podatke iz aplikacija koje to podržavaju.</string>
    <string name="analyzer_storage_type_tertiary_title">Prijenosna pohrana</string>
    <string name="analyzer_storage_type_tertiary_description">Prijenosna pohrana, npr. memorijski pogon priključen na USB priključak.</string>
    <string name="analyzer_storage_content_title">Sadržaj pohrane</string>
    <string name="analyzer_storage_content_type_app_label">Aplikacije</string>
    <string name="analyzer_storage_content_type_app_description">Prostor koji zauzimaju instalirane aplikacije i njihovi podaci (tj. datoteke aplikacija, podaci i predmemorije).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Nedostaju dopuštenja</string>
    <string name="analyzer_storage_content_type_media_label">Korisničke datoteke</string>
    <string name="analyzer_storage_content_type_media_description">Snimljene slike, videozapisi ili preuzeti podaci. Svi podaci koji ne pripadaju određenoj aplikaciji.</string>
    <string name="analyzer_storage_content_type_system_label">Sistemski podaci</string>
    <string name="analyzer_storage_content_type_system_description">Aplikacije sustava i sistemski podaci. Aplikacije i podaci drugih korisnika, ako je na ovom uređaju postavljeno više korisničkih računa.</string>
    <string name="analyzer_storage_content_type_system_other_label">Ostalo</string>
    <string name="analyzer_storage_content_type_system_info">Datoteke koje ne odgovaraju kategorijama Aplikacije ili Korisničke datoteke. Samo pregled — brisanje nije podržano. Neka područja mogu biti nepotpuna zbog ograničenja pristupa.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Sistemske datoteke i drugi podaci kojima SD Maid nije mogao pristupiti ili ih kategorizirati. Operativni sustav ograničava popis sadržaja nekih područja.</string>
    <string name="analyzer_storage_content_app_code_label">Kod aplikacije</string>
    <string name="analyzer_storage_content_app_code_description">Datoteke aplikacije, biblioteke i resursi. Ovaj se prostor može osloboditi deinstaliranjem aplikacije ili njenim arhiviranjem (dostupno u novijim verzijama Androida).</string>
    <string name="analyzer_storage_content_app_data_label">Podaci aplikacije</string>
    <string name="analyzer_storage_content_app_data_description">Podaci, postavke i predmemorije.</string>
    <string name="analyzer_storage_content_app_media_label">Mediji aplikacije</string>
    <string name="analyzer_storage_content_app_media_description">Medijske datoteke iz ove aplikacije, npr. primljene WhatsApp fotografije.</string>
    <string name="analyzer_storage_content_app_extra_label">Dodatne datoteke aplikacije</string>
    <string name="analyzer_storage_content_app_extra_description">Dodatni podaci koje je ova aplikacija postavila izvan zadanih putanja, npr. fotografije ili preuzimanja.</string>
