    <string name="analyzer_storage_type_primary_title">Primär lagring</string>
    <string name="analyzer_storage_type_primary_description">Den primära lagringen för din enhet. Innehåller det interna SD-kortet, privat lagring för appar och systemdata.</string>
    <string name="analyzer_storage_type_secondary_title">Sekundär lagring</string>
    <string name="analyzer_storage_type_secondary_description">En sekundär lagring, vanligtvis ett flyttbart SD-kort. Innehåller mediafiler och data från appar som stöder det.</string>
    <string name="analyzer_storage_type_tertiary_title">Portabel lagring</string>
    <string name="analyzer_storage_type_tertiary_description">En portabel lagring, t.ex. en USB-enhet ansluten till din USB-port.</string>
    <string name="analyzer_storage_content_title">Lagringsinnehåll</string>
    <string name="analyzer_storage_content_type_app_label">Appar</string>
    <string name="analyzer_storage_content_type_app_description">Utrymme upptaget av installerade appar och deras data (dvs. applikationsfiler, data och cache).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Behörigheter saknas</string>
    <string name="analyzer_storage_content_type_media_label">Användarfiler</string>
    <string name="analyzer_storage_content_type_media_description">Tagna bilder, inspelade videor eller nedladdad data. All data som inte tillhör en specifik app.</string>
    <string name="analyzer_storage_content_type_system_label">Systemdata</string>
    <string name="analyzer_storage_content_type_system_description">Systemappar och systemdata. Appar och data från andra användare, om flera användarkonton är inställda på denna enhet.</string>
    <string name="analyzer_storage_content_type_system_other_label">Övriga</string>
    <string name="analyzer_storage_content_type_system_info">Filer som inte passar in i kategorierna Appar eller Användarfiler. Bläddra endast — borttagning stöds inte. Vissa områden kan vara ofullständiga på grund av åtkomstbegränsningar.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Systemfiler och andra data som SD Maid inte kunde komma åt eller kategorisera. Operativsystemet begränsar listning av innehållet i vissa områden.</string>
    <string name="analyzer_storage_content_app_code_label">Appkod</string>
    <string name="analyzer_storage_content_app_code_description">Applikationsfiler, bibliotek och resurser. Detta utrymme kan frigöras genom att avinstallera appen eller arkivera den (tillgängligt på nyare Android-versioner).</string>
    <string name="analyzer_storage_content_app_data_label">Appdata</string>
    <string name="analyzer_storage_content_app_data_description">Data, inställningar och cache.</string>
    <string name="analyzer_storage_content_app_media_label">Appmedier</string>
    <string name="analyzer_storage_content_app_media_description">Mediafiler från denna app, t.ex. mottagna WhatsApp-foton.</string>
    <string name="analyzer_storage_content_app_extra_label">Extra appfiler</string>
    <string name="analyzer_storage_content_app_extra_description">Extra data som denna app har placerat utanför standardsökvägarna, t.ex. foton eller nedladdningar.</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">Denna app upptar %1$s på \"%2$s\".</string>
    <string name="analyzer_app_details_app_is_archived">Denna app har arkiverats.</string>
    <string name="analyzer_storage_trend_delta_in_7d">%s på 7d</string>
