    <string name="analyzer_storage_type_primary_title">Asosiy xotira</string>
    <string name="analyzer_storage_type_primary_description">Qurilmangizning asosiy xotirasi. Ichki SD karta, ilovalar uchun shaxsiy xotira va tizim ma\'lumotlarini o\'z ichiga oladi.</string>
    <string name="analyzer_storage_type_secondary_title">Ikkilamchi xotira</string>
    <string name="analyzer_storage_type_secondary_description">Ikkilamchi xotira, odatda olinadigan SD karta. Media fayllar va uni qo\'llab-quvvatlaydigan ilovalardan ma\'lumotlarni o\'z ichiga oladi.</string>
    <string name="analyzer_storage_type_tertiary_title">Ko\'chma xotira</string>
    <string name="analyzer_storage_type_tertiary_description">Ko\'chma xotira, masalan, USB portingizga ulangan flesh-disk.</string>
    <string name="analyzer_storage_content_title">Xotira tarkibi</string>
    <string name="analyzer_storage_content_type_app_label">Ilovalar</string>
    <string name="analyzer_storage_content_type_app_description">O\'rnatilgan ilovalar va ularning ma\'lumotlari tomonidan egallangan joy (ya\'ni ilova fayllari, ma\'lumotlar va keshlar).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Ruxsatlar etishmayapti</string>
    <string name="analyzer_storage_content_type_media_label">Foydalanuvchi fayllari</string>
    <string name="analyzer_storage_content_type_media_description">Olingan rasmlar, yozilgan videolar yoki yuklab olingan ma\'lumotlar. Muayyan ilovaga tegishli bo\'lmagan har qanday ma\'lumot.</string>
    <string name="analyzer_storage_content_type_system_label">Tizim ma\'lumotlari</string>
    <string name="analyzer_storage_content_type_system_description">Tizim ilovalari va tizim ma\'lumotlari. Agar ushbu qurilmada bir nechta foydalanuvchi hisobi o\'rnatilgan bo\'lsa, boshqa foydalanuvchilarning ilovalari va ma\'lumotlari.</string>
    <string name="analyzer_storage_content_type_system_other_label">Boshqa</string>
    <string name="analyzer_storage_content_type_system_info">Ilovalar yoki Foydalanuvchi fayllari toifalariga mos kelmaydigan fayllar. Faqat ko\'rish — o\'chirish qo\'llab-quvvatlanmaydi. Ba\'zi bo\'limlar kirish cheklovlari sababli to\'liq bo\'lmasligi mumkin.</string>
    <string name="analyzer_storage_content_type_system_other_desc">SD Maid kira olmagan yoki toifalay olmagan tizim fayllari va boshqa ma\'lumotlar. Operatsion tizim ba\'zi bo\'limlar mazmunini ko\'rsatishni cheklaydi.</string>
    <string name="analyzer_storage_content_app_code_label">Ilova kodi</string>
    <string name="analyzer_storage_content_app_code_description">Ilova fayllari, kutubxonalar va resurslar. Bu joyni ilovani o\'chirish yoki arxivlash orqali bo\'shatish mumkin (yangi Android versiyalarida mavjud).</string>
    <string name="analyzer_storage_content_app_data_label">Ilova ma\'lumotlari</string>
    <string name="analyzer_storage_content_app_data_description">Ma\'lumotlar, sozlamalar va keshlar.</string>
    <string name="analyzer_storage_content_app_media_label">Ilova media</string>
    <string name="analyzer_storage_content_app_media_description">Ushbu ilovadan media fayllar, masalan, qabul qilingan WhatsApp rasmlari.</string>
    <string name="analyzer_storage_content_app_extra_label">Qo\'shimcha ilova fayllari</string>
    <string name="analyzer_storage_content_app_extra_description">Ushbu ilova standart yo\'llardan tashqarida joylashtirgan qo\'shimcha ma\'lumotlar, masalan, rasmlar yoki yuklamalar.</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">Ushbu ilova \"%2$s\" da %1$s joy egallaydi.</string>
    <string name="analyzer_app_details_app_is_archived">Ushbu ilova arxivlangan.</string>
