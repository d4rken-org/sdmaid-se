    <string name="analyzer_storage_type_primary_title">Primaire opslag</string>
    <string name="analyzer_storage_type_primary_description">De primaire opslag van je apparaat. Bevat de interne SD-kaart, privéopslag voor apps en systeemgegevens.</string>
    <string name="analyzer_storage_type_secondary_title">Secundaire opslag</string>
    <string name="analyzer_storage_type_secondary_description">Een tweede opslag, meestal een verwisselbare SD-kaart. Bevat mediabestanden en gegevens van apps die dit ondersteunen.</string>
    <string name="analyzer_storage_type_tertiary_title">Draagbare opslag</string>
    <string name="analyzer_storage_type_tertiary_description">Een draagbare opslag, bijv. een USB-stick die op je USB-poort is aangesloten.</string>
    <string name="analyzer_storage_content_title">Inhoud van de opslag</string>
    <string name="analyzer_storage_content_type_app_label">Apps</string>
    <string name="analyzer_storage_content_type_app_description">Ruimte die wordt ingenomen door geïnstalleerde apps en hun gegevens (d.w.z. toepassingsbestanden, gegevens en caches).</string>
    <string name="analyzer_storage_content_type_app_setup_incomplete_hint">Machtigingen ontbreken</string>
    <string name="analyzer_storage_content_type_media_label">Gebruikers bestanden</string>
    <string name="analyzer_storage_content_type_media_description">Gemaakte foto\'s, opgenomen video\'s of gedownloade gegevens. Alle gegevens die niet bij een specifieke app horen.</string>
    <string name="analyzer_storage_content_type_system_label">Systeem gegevens</string>
    <string name="analyzer_storage_content_type_system_description">Systeem-apps en systeemgegevens. Apps en gegevens van andere gebruikers, als er meerdere gebruikersaccounts op dit apparaat zijn ingesteld.</string>
    <string name="analyzer_storage_content_type_system_other_label">Andere</string>
    <string name="analyzer_storage_content_type_system_info">Bestanden die niet in de categorieën Apps of Gebruikersbestanden passen. Alleen bladeren — verwijderen wordt niet ondersteund. Sommige gebieden zijn mogelijk onvolledig vanwege toegangsbeperkingen.</string>
    <string name="analyzer_storage_content_type_system_other_desc">Systeembestanden en andere gegevens waartoe SD Maid geen toegang had of die niet gecategoriseerd konden worden. Het besturingssysteem beperkt het weergeven van de inhoud van sommige gebieden.</string>
    <string name="analyzer_storage_content_app_code_label">App code</string>
    <string name="analyzer_storage_content_app_code_description">Applicatiebestanden, bibliotheken en bronnen. Deze ruimte kan vrijgemaakt worden door de app te verwijderen of te archiveren (beschikbaar op nieuwere Android-versie).</string>
    <string name="analyzer_storage_content_app_data_label">App gegevens</string>
    <string name="analyzer_storage_content_app_data_description">Gegevens, instellingen en caches.</string>
    <string name="analyzer_storage_content_app_media_label">App media</string>
    <string name="analyzer_storage_content_app_media_description">Mediabestanden van deze app, bijv. ontvangen WhatsApp-foto\'s.</string>
    <string name="analyzer_storage_content_app_extra_label">Extra app bestanden</string>
    <string name="analyzer_storage_content_app_extra_description">Extra gegevens die deze app buiten de standaard paden heeft geplaatst, bijv. foto\'s of downloads.</string>
    <string name="analyzer_app_details_app_occupies_x_on_y">Deze app neemt %1$s in beslag op \"%2$s\".</string>
    <string name="analyzer_app_details_app_is_archived">Deze app is gearchiveerd.</string>
